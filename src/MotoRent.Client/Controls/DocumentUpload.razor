            var filePath = Path.Combine(uploadDir, fileName);
            await File.WriteAllBytesAsync(filePath, fileBytes);

            // Perform OCR extraction
            var extractedData = await this.OcrService.ExtractDocumentDataAsync(filePath, this.DocumentType);
            this.m_extractedData = extractedData;

            // Calculate relative path for storage
            var uploadsDir = Path.Combine(Directory.GetCurrentDirectory(), basePath);
            this.m_uploadedFilePath = filePath.StartsWith(uploadsDir)
                ? filePath[uploadsDir.Length..].TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)
                : filePath;

            // Create preview URL
            this.m_previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(fileBytes)}";

            // Save document if renterId is provided
            int? documentId = null;
            if (this.RenterId.HasValue)
            {
                var username = this.RequestContext.GetUserName() ?? "system";
                var document = await this.OcrService.SaveDocumentAsync(
                    this.RenterId.Value,
                    this.DocumentType,
                    filePath,
                    extractedData,
                    username);
                documentId = document.DocumentId;
            }

            // Notify parent
            await this.OnDocumentUploaded.InvokeAsync(new DocumentUploadResult
            {
                DocumentId = documentId,
                FilePath = this.m_uploadedFilePath,
                ExtractedData = extractedData
            });

            if (extractedData != null && !string.IsNullOrEmpty(extractedData.FullName))
            {
                this.ShowSuccess("Document processed successfully");
            }
            else
            {
                this.ShowInfo("Document uploaded. OCR extraction may need manual verification.");
            }
        }
        catch (Exception ex)
        {
            this.ShowError($"Error processing document: {ex.Message}");
        }
        finally
        {
            this.m_uploading = false;
            this.StateHasChanged();
        }
    }

    private void ClearDocument()
    {
        this.m_previewUrl = null;
        this.m_extractedData = null;
        this.m_uploadedFilePath = null;
    }

    private async Task RetryOcr()
    {
        if (string.IsNullOrEmpty(this.m_uploadedFilePath)) return;

        // TODO: Call reprocess endpoint
        this.ShowInfo("Retrying OCR...");
    }

    private async Task ApplyExtractedData()
    {
        if (this.m_extractedData != null)
        {
            await this.OnDataExtracted.InvokeAsync(this.m_extractedData);
            this.ShowSuccess("Data applied to form");
        }
    }
}
