@inject IJSRuntime JS

<div class="dropdown country-picker">
    <button id="@m_toggleId"
            class="btn btn-outline-secondary dropdown-toggle w-100 d-flex align-items-center justify-content-between"
            type="button"
            data-bs-toggle="dropdown"
            data-bs-auto-close="true"
            aria-expanded="false">
        <span class="d-flex align-items-center">
            @if (!string.IsNullOrEmpty(Value))
            {
                var selected = s_countries.FirstOrDefault(c => c.Name == Value);
                if (selected != default)
                {
                    <span class="flag flag-xs flag-country-@selected.Code me-2"></span>
                }
                <span>@Value</span>
            }
            else
            {
                <span class="text-secondary">@(Placeholder ?? "")</span>
            }
        </span>
    </button>
    <div class="dropdown-menu w-100 p-0">
        <div class="d-flex flex-column" style="max-height: 300px; overflow: hidden;">
            <div class="p-2 border-bottom">
                <input type="text" class="form-control form-control-sm" placeholder="Search..."
                       @bind="m_searchText" @bind:event="oninput" @onclick:stopPropagation="true" />
            </div>
            <div style="overflow-y: auto; flex: 1;">
                @foreach (var country in FilteredCountries)
                {
                    <button class="dropdown-item d-flex align-items-center @(Value == country.Name ? "active" : "")"
                            type="button"
                            @onclick="@(() => SelectCountry(country.Name))">
                        <span class="flag flag-xs flag-country-@country.Code me-2"></span>
                        <span>@country.Name</span>
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }

    private string? m_searchText;
    private string m_toggleId = $"country-picker-{Guid.NewGuid():N}";

    private static readonly (string Code, string Name)[] s_countries =
    [
        ("cn", "China"),
        ("my", "Malaysia"),
        ("in", "India"),
        ("ru", "Russia"),
        ("kr", "South Korea"),
        ("jp", "Japan"),
        ("la", "Laos"),
        ("sg", "Singapore"),
        ("us", "United States"),
        ("vn", "Vietnam"),
        ("gb", "United Kingdom"),
        ("de", "Germany"),
        ("au", "Australia"),
        ("fr", "France"),
        ("kh", "Cambodia"),
        ("id", "Indonesia"),
        ("tw", "Taiwan"),
        ("mm", "Myanmar"),
        ("ph", "Philippines"),
        ("se", "Sweden"),
        ("ca", "Canada"),
        ("nl", "Netherlands"),
        ("ch", "Switzerland"),
        ("dk", "Denmark"),
        ("ae", "United Arab Emirates"),
        ("th", "Thailand")
    ];

    private IEnumerable<(string Code, string Name)> FilteredCountries =>
        string.IsNullOrWhiteSpace(m_searchText)
            ? s_countries
            : s_countries.Where(c => c.Name.Contains(m_searchText, StringComparison.OrdinalIgnoreCase));

    private async Task SelectCountry(string name)
    {
        Value = name;
        m_searchText = null;
        await ValueChanged.InvokeAsync(name);
        await JS.InvokeVoidAsync("eval",
            $"bootstrap.Dropdown.getOrCreateInstance(document.getElementById('{m_toggleId}'))?.hide()");
    }
}
