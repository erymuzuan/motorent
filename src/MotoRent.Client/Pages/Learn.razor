@page "/learn"
@page "/learn/{Lang}"
@page "/learn/{Lang}/{DocName}"
@using Microsoft.AspNetCore.Authorization
@using MotoRent.Client.Services
@using MotoRent.Client.Components
@using MotoRent.Client.Controls
@using System.Net.Http.Json
@attribute [AllowAnonymous]
@layout Layout.PublicLayout
@inherits LocalizedComponentBase<Learn>
@inject MarkdownService MarkdownService
@inject HttpClient HttpClient

<MotoRentPageTitle>@(this.m_currentDocTitle != null ? $"{this.m_currentDocTitle} - {Localizer["Learn"]}" : Localizer["Learn"])</MotoRentPageTitle>

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">
                    @Localizer["HelpAndDocumentation"]
                </h2>
            </div>
            <div class="col-auto">
                <DocLanguageSwitcher CurrentLang="@this.CurrentLang" CurrentDoc="@this.DocName" />
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row g-4">
            @* Sidebar Navigation *@
            <div class="col-md-3 d-none d-md-block">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">@Localizer["Documentation"]</h3>
                        @if (this.CurrentLang == "th")
                        {
                            <span class="badge bg-primary-lt">TH</span>
                        }
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var doc in this.m_manifest.Where(d => !d.FileName.Contains("superadmin", StringComparison.OrdinalIgnoreCase)).OrderBy(d => d.Order))
                        {
                            <a href="@GetDocUrl(doc.FileName)"
                               class="list-group-item list-group-item-action @(this.DocName == doc.FileName ? "active" : "")">
                                @doc.Title
                            </a>
                        }
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <span class="avatar avatar-sm bg-primary-lt me-2">
                                <i class="ti ti-robot"></i>
                            </span>
                            <h4 class="m-0">@Localizer["AskGemini"]</h4>
                        </div>
                        <p class="text-secondary small">
                            @Localizer["GeminiSearchDescription"]
                        </p>
                        <div class="input-icon">
                            <input type="text" class="form-control" placeholder="@Localizer["SearchDocs"]..." @bind="this.m_searchQuery" @onkeyup="this.HandleSearchKeyUp" />
                            <span class="input-icon-addon">
                                <i class="ti ti-search"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @* Main Content *@
            <div class="col-md-9">
                @if (this.m_usedFallback)
                {
                    <div class="alert alert-info mb-3">
                        <div class="d-flex align-items-center">
                            <i class="ti ti-info-circle me-2"></i>
                            <span>@Localizer["TranslationNotAvailable"]</span>
                        </div>
                    </div>
                }
                <div class="card">
                    <div class="card-body">
                        <LoadingSkeleton Loading="@this.Loading" Mode="LoadingSkeleton.PlaceholderMode.Card">
                            <div class="markdown">
                                @((MarkupString)this.m_htmlContent)
                            </div>
                        </LoadingSkeleton>
                    </div>
                </div>

                @if (this.m_manifest.Any())
                {
                    var sortedManifest = this.m_manifest.Where(d => !d.FileName.Contains("superadmin", StringComparison.OrdinalIgnoreCase)).OrderBy(d => d.Order).ToList();
                    var currentIndex = sortedManifest.FindIndex(d => d.FileName == this.DocName);
                    <div class="d-flex justify-content-between mt-4">
                        @if (currentIndex > 0)
                        {
                            <a href="@GetDocUrl(sortedManifest[currentIndex - 1].FileName)" class="btn btn-outline-primary">
                                <i class="ti ti-chevron-left me-1"></i> @sortedManifest[currentIndex - 1].Title
                            </a>
                        }
                        else
                        {
                            <div></div>
                        }

                        @if (currentIndex >= 0 && currentIndex < sortedManifest.Count - 1)
                        {
                            <a href="@GetDocUrl(sortedManifest[currentIndex + 1].FileName)" class="btn btn-outline-primary">
                                @sortedManifest[currentIndex + 1].Title <i class="ti ti-chevron-right ms-1"></i>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<DocumentationChat />

@code {
    [Parameter] public string? Lang { get; set; }
    [Parameter] public string? DocName { get; set; }

    private List<DocItem> m_manifest = [];
    private string m_htmlContent = "";
    private string? m_currentDocTitle = null;
    private string m_searchQuery = "";
    private bool m_usedFallback = false;
    private string m_lastLoadedLang = "";
    private bool Loading { get; set; } = true;

    private string CurrentLang => ValidateLang(this.Lang);

    private static string ValidateLang(string? lang) => lang is "th" or "en" ? lang : "en";

    protected override async Task OnParametersSetAsync()
    {
        // Load manifest for the current language if changed
        if (this.m_lastLoadedLang != this.CurrentLang || this.m_manifest.Count == 0)
        {
            await this.LoadManifestAsync();
            this.m_lastLoadedLang = this.CurrentLang;
        }

        // Default to first doc if not specified
        if (string.IsNullOrEmpty(this.DocName) && this.m_manifest.Any())
        {
            this.DocName = this.m_manifest.OrderBy(d => d.Order).First().FileName;
        }

        if (!string.IsNullOrEmpty(this.DocName))
        {
            this.m_currentDocTitle = this.m_manifest.FirstOrDefault(d => d.FileName == this.DocName)?.Title;
            await this.LoadDocumentAsync();
        }
        else
        {
            this.Loading = false;
        }
    }

    private async Task LoadManifestAsync()
    {
        try
        {
            var docsFolder = MarkdownService.GetDocsFolder(this.CurrentLang);
            var absoluteUri = this.NavigationManager.ToAbsoluteUri($"{docsFolder}/manifest.json").ToString();
            this.m_manifest = await this.HttpClient.GetFromJsonAsync<List<DocItem>>(absoluteUri) ?? [];
        }
        catch (Exception ex)
        {
            this.Logger.LogWarning(ex, "Error loading manifest for {Lang}, falling back to English", this.CurrentLang);
            // Fall back to English manifest
            try
            {
                var absoluteUri = this.NavigationManager.ToAbsoluteUri("user.guides/manifest.json").ToString();
                this.m_manifest = await this.HttpClient.GetFromJsonAsync<List<DocItem>>(absoluteUri) ?? [];
            }
            catch
            {
                this.m_manifest = [];
            }
        }
    }

    private async Task LoadDocumentAsync()
    {
        this.Loading = true;
        this.StateHasChanged();

        try
        {
            var (html, usedFallback) = await this.MarkdownService.RenderMarkdownWithFallbackAsync(this.DocName!, this.CurrentLang);
            this.m_htmlContent = html;
            this.m_usedFallback = usedFallback;
        }
        catch (Exception ex)
        {
            this.Logger.LogError(ex, "Error loading document: {DocName} ({Lang})", this.DocName, this.CurrentLang);
            this.m_htmlContent = "<h1>Error</h1><p>Failed to load documentation.</p>";
            this.m_usedFallback = false;
        }
        finally
        {
            this.Loading = false;
            this.StateHasChanged();
        }
    }

    private string GetDocUrl(string fileName)
    {
        return $"/learn/{this.CurrentLang}/{fileName}";
    }

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // TODO: Navigate to search or open chat
        }
    }
}