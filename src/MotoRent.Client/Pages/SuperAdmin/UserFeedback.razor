@page "/super-admin/feedback"
@rendermode InteractiveServer
@inherits LocalizedComponentBase<UserFeedback>
@using Microsoft.AspNetCore.Authorization
@using MotoRent.Domain.Core
@using MotoRent.Services.Core
@attribute [Authorize(Roles = UserAccount.SUPER_ADMIN)]
@inject FeedbackService FeedbackService

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<div class="container-xl mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">@Localizer["HeaderTitle"]</h4>
            <p class="text-secondary mb-0">@Localizer["HeaderSubtitle"]</p>
        </div>
    </div>

    @* Stats Cards *@
    <div class="row row-deck row-cards mb-3">
        <div class="col-sm-6 col-lg-4">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-secondary text-white avatar">
                                <i class="ti ti-message-report"></i>
                            </span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">@m_stats.TotalCount</div>
                            <div class="text-secondary">@Localizer["StatTotal"]</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-info text-white avatar">
                                <i class="ti ti-bell"></i>
                            </span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">@m_stats.NewCount</div>
                            <div class="text-secondary">@Localizer["StatNew"]</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-danger text-white avatar">
                                <i class="ti ti-bug"></i>
                            </span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">@m_stats.ErrorReportCount</div>
                            <div class="text-secondary">@Localizer["StatErrors"]</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Filters *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">@Localizer["FilterStatus"]</label>
                    <select class="form-select" @bind="m_statusFilter" @bind:after="LoadAsync">
                        <option value="">@Localizer["FilterAll"]</option>
                        @foreach (var status in Enum.GetValues<FeedbackStatus>())
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">@Localizer["FilterType"]</label>
                    <select class="form-select" @bind="m_typeFilter" @bind:after="LoadAsync">
                        <option value="">@Localizer["FilterAll"]</option>
                        @foreach (var type in Enum.GetValues<FeedbackType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@Localizer["FilterAccount"]</label>
                    <input type="text" class="form-control" placeholder="@Localizer["FilterAccountPlaceholder"]"
                           @bind="m_accountFilter" @bind:after="LoadAsync" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">@Localizer["FilterSearch"]</label>
                    <input type="text" class="form-control" placeholder="@Localizer["FilterSearchPlaceholder"]"
                           @bind="m_searchFilter" @bind:after="LoadAsync" />
                </div>
            </div>
        </div>
    </div>

    @if (m_loading)
    {
        <div class="progress progress-sm mb-4">
            <div class="progress-bar progress-bar-indeterminate"></div>
        </div>
    }

    @* Feedback Table *@
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped">
                <thead>
                    <tr>
                        <th>@Localizer["ColTime"]</th>
                        <th>@Localizer["ColType"]</th>
                        <th>@Localizer["ColStatus"]</th>
                        <th>@Localizer["ColAccount"]</th>
                        <th>@Localizer["ColUser"]</th>
                        <th>@Localizer["ColDescription"]</th>
                        <th class="w-1"></th>
                        <th class="w-1"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fb in m_feedbacks)
                    {
                        <tr class="cursor-pointer" @onclick="() => ViewDetails(fb.FeedbackId)">
                            <td>
                                <span title="@fb.Timestamp.ToString("g")">@GetTimeAgo(fb.Timestamp)</span>
                            </td>
                            <td>
                                <span class="badge @GetTypeBadgeClass(fb.Type)">@fb.Type</span>
                            </td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(fb.Status)">@fb.Status</span>
                            </td>
                            <td>@(fb.AccountNo ?? "-")</td>
                            <td>@(fb.UserName ?? "-")</td>
                            <td>
                                <div class="text-truncate" style="max-width: 250px;" title="@fb.Description">
                                    @fb.Description
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(fb.ScreenshotStoreId))
                                {
                                    <i class="ti ti-photo text-primary" title="@Localizer["HasScreenshot"]"></i>
                                }
                            </td>
                            <td>
                                <div class="btn-list flex-nowrap" @onclick:stopPropagation>
                                    <button type="button" class="btn btn-sm btn-ghost-secondary"
                                            @onclick="() => ViewDetails(fb.FeedbackId)" title="@Localizer["ViewDetails"]">
                                        <i class="ti ti-eye"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-ghost-danger"
                                            @onclick="() => Delete(fb.FeedbackId)" title="@Localizer["Delete"]">
                                        <i class="ti ti-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (m_feedbacks.Count == 0 && !m_loading)
        {
            <div class="card-body">
                <div class="empty">
                    <div class="empty-icon">
                        <i class="ti ti-mood-happy" style="font-size: 3rem;"></i>
                    </div>
                    <p class="empty-title">@Localizer["EmptyTitle"]</p>
                    <p class="empty-subtitle text-secondary">
                        @Localizer["EmptySubtitle"]
                    </p>
                </div>
            </div>
        }

        @* Pagination *@
        @if (m_totalRows > m_pageSize)
        {
            <div class="card-footer d-flex align-items-center">
                <p class="m-0 text-secondary">
                    @Localizer["PaginationShowing", $"{((m_page - 1) * m_pageSize) + 1}", $"{Math.Min(m_page * m_pageSize, m_totalRows)}", $"{m_totalRows}"]
                </p>
                <ul class="pagination m-0 ms-auto">
                    <li class="page-item @(m_page == 1 ? "disabled" : "")">
                        <a class="page-link" href="javascript:" @onclick="() => GoToPage(m_page - 1)">
                            <i class="ti ti-chevron-left"></i>
                        </a>
                    </li>
                    @for (var i = 1; i <= Math.Min(m_totalPages, 5); i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(m_page == pageNum ? "active" : "")">
                            <a class="page-link" href="javascript:" @onclick="() => GoToPage(pageNum)">@pageNum</a>
                        </li>
                    }
                    <li class="page-item @(m_page == m_totalPages ? "disabled" : "")">
                        <a class="page-link" href="javascript:" @onclick="() => GoToPage(m_page + 1)">
                            <i class="ti ti-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        }
    </div>
</div>

@code {
    private List<Feedback> m_feedbacks = [];
    private FeedbackStats m_stats = new(0, 0, 0);
    private bool m_loading = true;

    // Filters
    private string? m_statusFilter;
    private string? m_typeFilter;
    private string? m_accountFilter;
    private string? m_searchFilter;

    // Pagination
    private int m_page = 1;
    private int m_pageSize = 20;
    private int m_totalRows;
    private int m_totalPages => (int)Math.Ceiling((double)m_totalRows / m_pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
        await LoadAsync();
    }

    private async Task LoadStatsAsync()
    {
        m_stats = await FeedbackService.GetStatsAsync();
    }

    private async Task LoadAsync()
    {
        m_loading = true;
        try
        {
            var filter = BuildFilter();
            var lo = await FeedbackService.GetFeedbacksAsync(filter, m_page, m_pageSize);
            m_feedbacks = lo.ItemCollection.ToList();
            m_totalRows = lo.TotalRows;
        }
        finally
        {
            m_loading = false;
        }
    }

    private FeedbackFilter BuildFilter()
    {
        FeedbackStatus? status = null;
        if (!string.IsNullOrEmpty(m_statusFilter) && Enum.TryParse<FeedbackStatus>(m_statusFilter, out var s))
            status = s;

        FeedbackType? type = null;
        if (!string.IsNullOrEmpty(m_typeFilter) && Enum.TryParse<FeedbackType>(m_typeFilter, out var t))
            type = t;

        return new FeedbackFilter(status, type, m_accountFilter, null, m_searchFilter);
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > m_totalPages) return;
        m_page = page;
        await LoadAsync();
    }

    private async Task ViewDetails(int feedbackId)
    {
        await DialogService
            .Create<FeedbackDetailsDialog>(Localizer["DialogTitle"].Value)
            .WithParameter(x => x.FeedbackId, feedbackId)
            .WithSize(MotoRent.Client.Services.ModalSize.ExtraLarge)
            .ShowDialogAsync();

        await LoadAsync();
        await LoadStatsAsync();
    }

    private async Task Delete(int feedbackId)
    {
        var confirmed = await DialogService.ConfirmYesNoAsync(
            Localizer["ConfirmDelete"].Value,
            Localizer["ConfirmDeleteTitle"].Value);

        if (!confirmed) return;

        await FeedbackService.DeleteAsync(feedbackId);
        ShowSuccess(Localizer["FeedbackDeleted"].Value);
        await LoadAsync();
        await LoadStatsAsync();
    }

    private string GetTypeBadgeClass(FeedbackType type) => type switch
    {
        FeedbackType.ErrorReport => "bg-danger",
        FeedbackType.General => "bg-info",
        _ => "bg-secondary"
    };

    private string GetStatusBadgeClass(FeedbackStatus status) => status switch
    {
        FeedbackStatus.New => "bg-info",
        FeedbackStatus.Reviewed => "bg-primary",
        FeedbackStatus.InProgress => "bg-warning",
        FeedbackStatus.Resolved => "bg-success",
        FeedbackStatus.Dismissed => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetTimeAgo(DateTimeOffset timestamp)
    {
        var diff = DateTimeOffset.Now - timestamp;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return timestamp.ToString("MMM d");
    }
}
