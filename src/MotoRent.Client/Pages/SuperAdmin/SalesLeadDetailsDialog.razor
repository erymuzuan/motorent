@using MotoRent.Domain.Core
@using MotoRent.Domain.DataContext
@using MotoRent.Client.Controls
@inherits LocalizedDialogBase<SalesLead, SalesLeadDetailsDialog>
@inject CoreDataContext CoreContext
@inject IJSRuntime JS

<div class="modal-body">
    @if (Entity is null)
    {
        <div class="alert alert-warning">
            <i class="ti ti-alert-triangle me-2"></i>
            @Localizer["LeadNotFound"]
        </div>
    }
    else
    {
        @* Contact Information Card *@
        <div class="card mb-3">
            <div class="card-header">
                <i class="ti ti-user me-2"></i>@Localizer["ContactInformation"]
            </div>
            <div class="card-body">
                <div class="d-flex align-items-start">
                    <span class="avatar avatar-lg me-3 bg-green-lt" style="font-size: 1.5rem;">
                        @(Entity.Name?.FirstOrDefault().ToString().ToUpperInvariant() ?? "?")
                    </span>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h4 class="mb-0">@Entity.Name</h4>
                            <span class="badge @GetStatusBadgeClass(Entity.Status)" style="font-size: 0.85rem;">
                                @Localizer[$"Status{Entity.Status}"]
                            </span>
                        </div>
                        <dl class="row mb-0">
                            <dt class="col-3">@Localizer["Email"]</dt>
                            <dd class="col-9">
                                <div class="d-flex align-items-center">
                                    <span class="me-2">@Entity.Email</span>
                                    <button type="button" class="btn btn-ghost-secondary btn-sm btn-icon"
                                            @onclick="@(() => CopyToClipboardAsync(Entity.Email))" title="@Localizer["CopyEmail"]">
                                        <i class="ti ti-copy"></i>
                                    </button>
                                </div>
                            </dd>

                            <dt class="col-3">@Localizer["Phone"]</dt>
                            <dd class="col-9">@(Entity.Phone ?? "-")</dd>

                            <dt class="col-3">@Localizer["Company"]</dt>
                            <dd class="col-9">@(Entity.Company ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        @* Interest Details Card *@
        <div class="card mb-3">
            <div class="card-header">
                <i class="ti ti-bulb me-2"></i>@Localizer["InterestDetails"]
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="d-flex align-items-center">
                            <span class="text-secondary me-2">@Localizer["PlanInterested"]:</span>
                            <span class="badge @GetPlanBadgeClass(Entity.PlanInterested)">
                                @(Entity.PlanInterested?.ToString() ?? "-")
                            </span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex align-items-center">
                            <span class="text-secondary me-2">@Localizer["FleetSize"]:</span>
                            <span class="fw-medium">@(Entity.FleetSize?.ToString() ?? "-")</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex align-items-center">
                            <span class="text-secondary me-2">@Localizer["Source"]:</span>
                            <span class="fw-medium">@GetSourceDisplay(Entity.Source)</span>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Entity.Message))
                {
                    <div class="mt-3">
                        <label class="form-label text-secondary">@Localizer["Message"]</label>
                        <div class="bg-light p-3 rounded border" style="white-space: pre-wrap;">@Entity.Message</div>
                    </div>
                }
            </div>
        </div>

        @* Enterprise Requirements Card (conditional) *@
        @if (Entity.PlanInterested == SubscriptionPlan.Customized)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <i class="ti ti-building-enterprise me-2"></i>@Localizer["EnterpriseRequirements"]
                </div>
                <div class="card-body">
                    @if (Entity.EnterpriseRequirements.Count > 0)
                    {
                        <div class="row g-2">
                            @foreach (var req in GetAllRequirements())
                            {
                                var isSelected = Entity.EnterpriseRequirements.Contains(req.Key);
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        @if (isSelected)
                                        {
                                            <i class="ti ti-check text-success me-2"></i>
                                        }
                                        else
                                        {
                                            <i class="ti ti-x text-muted me-2"></i>
                                        }
                                        <span class="@(isSelected ? "" : "text-muted")">@Localizer[req.Value]</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">@Localizer["NoRequirementsSelected"]</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(Entity.CustomRequirements))
                    {
                        <div class="mt-3">
                            <label class="form-label text-secondary">@Localizer["CustomRequirements"]</label>
                            <div class="bg-light p-3 rounded border" style="white-space: pre-wrap;">@Entity.CustomRequirements</div>
                        </div>
                    }
                </div>
            </div>
        }

        @* Timeline Card *@
        <div class="card">
            <div class="card-header">
                <i class="ti ti-calendar me-2"></i>@Localizer["Timeline"]
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-4">
                        <i class="ti ti-calendar-plus me-1 text-muted"></i>@Localizer["Created"]
                    </dt>
                    <dd class="col-8">@Entity.CreatedTimestamp.LocalDateTime.ToString("dd MMM yyyy HH:mm")</dd>

                    <dt class="col-4">
                        <i class="ti ti-flask me-1 text-muted"></i>@Localizer["TrialStarted"]
                    </dt>
                    <dd class="col-8">
                        @if (Entity.TrialStartedAt.HasValue)
                        {
                            @Entity.TrialStartedAt.Value.LocalDateTime.ToString("dd MMM yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>

                    <dt class="col-4">
                        <i class="ti ti-circle-check me-1 text-muted"></i>@Localizer["Converted"]
                    </dt>
                    <dd class="col-8">
                        @if (Entity.ConvertedAt.HasValue)
                        {
                            @Entity.ConvertedAt.Value.LocalDateTime.ToString("dd MMM yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    }
</div>

<div class="modal-footer">
    @if (Entity is not null)
    {
        <div class="me-auto d-flex align-items-center">
            <label class="form-label mb-0 me-2">@Localizer["Status"]:</label>
            <select class="form-select form-select-sm" style="width: 150px;" @bind="m_selectedStatus" @bind:after="OnStatusChanged">
                <option value="Lead">@Localizer["StatusLead"]</option>
                <option value="Trial">@Localizer["StatusTrial"]</option>
                <option value="Customer">@Localizer["StatusCustomer"]</option>
                <option value="Lost">@Localizer["StatusLost"]</option>
            </select>
        </div>

        @if (m_hasChanges)
        {
            <button type="button" class="btn btn-primary" @onclick="SaveChangesAsync" disabled="@Saving">
                @if (Saving)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                <i class="ti ti-device-floppy me-2"></i>
                @Localizer["SaveChanges"]
            </button>
        }
    }
    <button type="button" class="btn btn-ghost-secondary" @onclick="Cancel">
        @CommonLocalizer["Close"]
    </button>
</div>

@code {
    private string m_selectedStatus = "Lead";
    private bool m_hasChanges;

    protected override void OnParametersSet()
    {
        if (Entity is not null)
        {
            m_selectedStatus = Entity.Status.ToString();
        }
    }

    private void OnStatusChanged()
    {
        if (Entity is null) return;

        var newStatus = Enum.Parse<LeadStatus>(m_selectedStatus);
        m_hasChanges = newStatus != Entity.Status;
    }

    private async Task SaveChangesAsync()
    {
        if (Entity is null) return;

        Saving = true;
        try
        {
            var newStatus = Enum.Parse<LeadStatus>(m_selectedStatus);
            Entity.Status = newStatus;

            // Set timestamps based on status
            if (newStatus == LeadStatus.Trial && !Entity.TrialStartedAt.HasValue)
            {
                Entity.TrialStartedAt = DateTimeOffset.Now;
            }
            else if (newStatus == LeadStatus.Customer && !Entity.ConvertedAt.HasValue)
            {
                Entity.ConvertedAt = DateTimeOffset.Now;
            }

            using var session = CoreContext.OpenSession(UserName);
            session.Attach(Entity);
            await session.SubmitChanges("Update lead status");

            m_hasChanges = false;
            ShowSuccess(Localizer["StatusUpdated"].Value);
        }
        catch (Exception ex)
        {
            ShowError($"{Localizer["ErrorSaving"].Value}: {ex.Message}");
        }
        finally
        {
            Saving = false;
        }
    }

    private async Task CopyToClipboardAsync(string? text)
    {
        if (string.IsNullOrEmpty(text)) return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            ShowSuccess(Localizer["CopiedToClipboard"].Value);
        }
        catch
        {
            ShowError(Localizer["FailedToCopy"].Value);
        }
    }

    private string GetSourceDisplay(LeadSource source) => source switch
    {
        LeadSource.ContactForm => Localizer["SourceContactForm"].Value,
        LeadSource.PricingPage => Localizer["SourcePricingPage"].Value,
        LeadSource.Manual => Localizer["SourceManual"].Value,
        LeadSource.Referral => Localizer["SourceReferral"].Value,
        LeadSource.SocialMedia => Localizer["SourceSocialMedia"].Value,
        LeadSource.Event => Localizer["SourceEvent"].Value,
        _ => source.ToString()
    };

    private static Dictionary<string, string> GetAllRequirements() => new()
    {
        ["SelfHosted"] = "ReqSelfHosted",
        ["CustomBranding"] = "ReqCustomBranding",
        ["SSO"] = "ReqSSO",
        ["ApiIntegration"] = "ReqApiIntegration",
        ["LegacyMigration"] = "ReqLegacyMigration",
        ["MultiLocation"] = "ReqMultiLocation",
        ["DedicatedSupport"] = "ReqDedicatedSupport",
        ["DataResidency"] = "ReqDataResidency"
    };

    private static string GetStatusBadgeClass(LeadStatus status) => status switch
    {
        LeadStatus.Lead => "bg-blue text-white",
        LeadStatus.Trial => "bg-yellow text-dark",
        LeadStatus.Customer => "bg-green text-white",
        LeadStatus.Lost => "bg-secondary text-white",
        _ => "bg-secondary text-white"
    };

    private static string GetPlanBadgeClass(SubscriptionPlan? plan) => plan switch
    {
        SubscriptionPlan.Free => "bg-secondary-lt",
        SubscriptionPlan.Pro => "bg-blue-lt",
        SubscriptionPlan.Ultra => "bg-purple-lt",
        SubscriptionPlan.Customized => "bg-orange-lt",
        _ => "bg-secondary-lt"
    };
}
