@page "/settings/templates/designer"
@page "/settings/templates/designer/{TemplateId:int}"
@using Microsoft.AspNetCore.Authorization
@using MotoRent.Domain.Core
@using MotoRent.Domain.Entities
@using MotoRent.Domain.Models
@using MotoRent.Services
@using MotoRent.Services.Core
@using MotoRent.Client.Components.Templates
@using MotoRent.Client.Services
@implements IAsyncDisposable
@attribute [Authorize(Policy = "RequireTenantOrgAdmin")]
@inherits LocalizedComponentBase<DocumentTemplateDesigner>
@inject DocumentTemplateService TemplateService
@inject DocumentTemplateAiService AiService
@inject DesignerState DesignerState
@inject ITemplateDataResolver DataResolver
@inject IHtmlTemplateRenderer HtmlRenderer
@inject OrganizationService OrganizationService
@inject IJSRuntime JS

<MotoRentPageTitle>@this.Localizer["PageTitle"]</MotoRentPageTitle>

@* ─── Top Bar ─── *@
<div class="designer-topbar">
    <div class="designer-topbar-left">
        <a href="/settings/templates" class="designer-back-btn" title="@this.Localizer["Dashboard"]">
            <i class="ti ti-arrow-left"></i>
        </a>
        <img src="images/icons/ios/40.png" alt="Logo" height="24" class="designer-logo" />
        <input type="text" class="designer-inline-name" @bind="this.m_template.Name"
               placeholder="@this.Localizer["NamePlaceholder"]" />
    </div>
    <div class="designer-topbar-actions">
        <button type="button" class="btn btn-ghost-secondary btn-sm btn-icon"
                title="@this.Localizer["ToggleLeftPanel"]"
                @onclick="() => this.DesignerState.ToggleLeftPanel()">
            <i class="ti @(this.DesignerState.LeftCollapsed ? "ti-layout-sidebar-right" : "ti-layout-sidebar-left-collapse")"></i>
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="this.TriggerImportFileAsync" disabled="@this.m_importing">
            @if (this.m_importing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                @this.Localizer["ImportProcessing"]
            }
            else
            {
                <i class="ti ti-file-import me-1"></i>
                @this.Localizer["ImportFromDocument"]
            }
        </button>
        <InputFile @ref="this.m_importFileInput" OnChange="this.HandleImportFileAsync"
                   accept=".pdf,.jpg,.jpeg,.png,.webp" style="display:none" />
        <button type="button" class="btn btn-outline-secondary btn-sm"
                @onclick="() => this.m_showAiSidebar = !this.m_showAiSidebar">
            <i class="ti ti-sparkles me-1"></i>
            @this.Localizer["AiSuggester"]
        </button>
        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="this.TogglePreview">
            <i class="ti ti-eye me-1"></i>
            @this.Localizer["Preview"]
        </button>
        <button type="button" class="btn btn-primary btn-sm" @onclick="this.SaveTemplateAsync" disabled="@this.m_saving">
            @if (this.m_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            else
            {
                <i class="ti ti-device-floppy me-1"></i>
            }
            @this.Localizer["SaveTemplate"]
        </button>
        <a href="/settings/templates" class="btn btn-ghost-secondary btn-sm">
            <i class="ti ti-layout-dashboard me-1"></i>
            @this.Localizer["Dashboard"]
        </a>
        <button type="button" class="btn btn-ghost-secondary btn-sm btn-icon"
                title="@this.Localizer["ToggleRightPanel"]"
                @onclick="() => this.DesignerState.ToggleRightPanel()">
            <i class="ti @(this.DesignerState.RightCollapsed ? "ti-layout-sidebar-left" : "ti-layout-sidebar-right-collapse")"></i>
        </button>
    </div>
</div>

@* ─── Main Body ─── *@
<LoadingSkeleton Loading="@this.m_loading" Mode="LoadingSkeleton.PlaceholderMode.Card">
    <div class="designer-layout @(this.DesignerState.LeftCollapsed ? "left-collapsed" : "") @(this.DesignerState.RightCollapsed ? "right-collapsed" : "")"
         @ref="this.m_containerRef">

        @* ─── Left Panel ─── *@
        <div class="designer-panel designer-panel-left">
            @if (!this.DesignerState.LeftCollapsed)
            {
                @* Pages Section *@
                <div class="designer-section-header">
                    <span class="designer-section-label">@this.Localizer["Pages"]</span>
                </div>
                <div class="designer-pages-list">
                    @for (var i = 0; i < this.m_layout.Pages.Count; i++)
                    {
                        var idx = i;
                        var docPage = this.m_layout.Pages[i];
                        <div class="designer-page-item @(this.DesignerState.CurrentPageIndex == idx ? "active" : "")"
                             @onclick="() => this.DesignerState.SetCurrentPage(idx)">
                            <i class="ti ti-file-text me-2"></i>
                            <span class="designer-page-name">@docPage.Name</span>
                        </div>
                    }
                </div>

                <div class="designer-divider"></div>

                @* Elements Section *@
                <div class="designer-section-header">
                    <span class="designer-section-label">@this.Localizer["StandardElements"]</span>
                </div>
                <div class="designer-elements-list">
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("heading")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "heading"'>
                        <i class="ti ti-heading"></i> <span>@this.Localizer["Heading"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("text")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "text"'>
                        <i class="ti ti-type"></i> <span>@this.Localizer["TextBlock"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("table")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "table"'>
                        <i class="ti ti-table"></i> <span>@this.Localizer["DataTable"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("image")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "image"'>
                        <i class="ti ti-photo"></i> <span>@this.Localizer["ImageLogo"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("divider")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "divider"'>
                        <i class="ti ti-minus"></i> <span>@this.Localizer["DividerLine"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("signature")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "signature"'>
                        <i class="ti ti-pencil"></i> <span>@this.Localizer["Signature"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("two-columns")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "two-columns"'>
                        <i class="ti ti-columns"></i> <span>@this.Localizer["TwoColumns"]</span>
                    </button>
                    <button class="designer-element-btn"
                            @onclick='() => this.AddBlock("spacer")' draggable="true"
                            @ondragstart='() => this.DesignerState.DraggingBlockType = "spacer"'>
                        <i class="ti ti-separator-horizontal"></i> <span>@this.Localizer["Spacer"]</span>
                    </button>
                </div>
            }
        </div>

        @* Left Splitter *@
        <div class="designer-splitter" data-panel="left"></div>

        @* ─── Canvas (center) ─── *@
        <div class="designer-panel designer-panel-canvas">
            <DocumentCanvas Layout="this.m_layout"
                            Page="this.CurrentPage"
                            SelectedBlock="this.DesignerState.SelectedBlock"
                            OnBlockSelected="b => this.DesignerState.SetSelectedBlock(b)"
                            OnBlockAdded="this.AddBlock"/>

            @* Page Navigation Footer *@
            <div class="designer-canvas-footer">
                <button class="btn btn-ghost-secondary btn-sm btn-icon" @onclick="this.PreviousPage"
                        disabled="@(this.DesignerState.CurrentPageIndex <= 0)">
                    <i class="ti ti-chevron-left"></i>
                </button>
                <span class="designer-page-indicator">
                    @this.Localizer["PageXOfY", this.DesignerState.CurrentPageIndex + 1, this.m_layout.Pages.Count]
                </span>
                <button class="btn btn-ghost-secondary btn-sm btn-icon" @onclick="this.NextPage"
                        disabled="@(this.DesignerState.CurrentPageIndex >= this.m_layout.Pages.Count - 1)">
                    <i class="ti ti-chevron-right"></i>
                </button>
                <div class="designer-page-actions">
                    <button class="btn btn-ghost-primary btn-sm" @onclick="this.AddPage">
                        <i class="ti ti-plus me-1"></i> @this.Localizer["AddPage"]
                    </button>
                    @if (this.m_layout.Pages.Count > 1)
                    {
                        <button class="btn btn-ghost-danger btn-sm" @onclick="this.DeleteCurrentPage">
                            <i class="ti ti-trash me-1"></i> @this.Localizer["DeletePage"]
                        </button>
                    }
                </div>
            </div>
        </div>

        @* Right Splitter *@
        <div class="designer-splitter" data-panel="right"></div>

        @* ─── Right Panel ─── *@
        <div class="designer-panel designer-panel-right">
            @if (!this.DesignerState.RightCollapsed)
            {
                @* Right Panel Tabs *@
                <div class="designer-right-tabs">
                    <button class="designer-tab @(this.DesignerState.ActiveRightTab == "properties" ? "active" : "")"
                            @onclick='() => this.DesignerState.SetRightTab("properties")'>
                        @this.Localizer["PropertiesTab"]
                    </button>
                    <button class="designer-tab @(this.DesignerState.ActiveRightTab == "page" ? "active" : "")"
                            @onclick='() => this.DesignerState.SetRightTab("page")'>
                        @this.Localizer["PageTab"]
                    </button>
                    <button class="designer-tab @(this.DesignerState.ActiveRightTab == "data" ? "active" : "")"
                            @onclick='() => this.DesignerState.SetRightTab("data")'>
                        @this.Localizer["DataTab"]
                    </button>
                </div>

                <div class="designer-right-content">
                    @if (this.DesignerState.ActiveRightTab == "properties")
                    {
                        <BlockPropertyEditor Block="this.DesignerState.SelectedBlock"
                                             OnDeleteRequested="this.DeleteSelectedBlock"/>
                    }
                    else if (this.DesignerState.ActiveRightTab == "page")
                    {
                        @* Page Settings *@
                        <div class="p-3">
                            <div class="mb-3">
                                <label class="form-label">@this.Localizer["PageName"]</label>
                                <input type="text" class="form-control" @bind="this.CurrentPage.Name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">@this.Localizer["DocumentType"]</label>
                                <select class="form-select" @bind="this.m_documentType">
                                    @foreach (DocumentType type in Enum.GetValues(typeof(DocumentType)))
                                    {
                                        <option value="@type">@type</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-0">
                                <label class="form-label">@this.Localizer["Description"]</label>
                                <textarea class="form-control" @bind="this.m_template.Description" rows="2"
                                          placeholder="@this.Localizer["DescriptionPlaceholder"]"></textarea>
                            </div>
                        </div>
                    }
                    else if (this.DesignerState.ActiveRightTab == "data")
                    {
                        @* AI Suggester / Data Tab *@
                        <div class="p-3">
                            <div class="mb-3">
                                <label class="form-label">@this.Localizer["AiContextLabel"]</label>
                                <textarea class="form-control" @bind="this.m_aiContext" rows="3"
                                          placeholder="@this.Localizer["AiContextPlaceholder"]"></textarea>
                            </div>
                            <button class="btn btn-primary w-100 mb-3" @onclick="this.GetAiSuggestions"
                                    disabled="@this.m_loadingAi">
                                @if (this.m_loadingAi)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                @this.Localizer["SuggestClauses"]
                            </button>
                            <div class="list-group list-group-flush border-top overflow-auto" style="max-height: 400px;">
                                @foreach (var suggestion in this.m_aiSuggestions)
                                {
                                    <div class="list-group-item p-3 border-bottom cursor-pointer hover-bg-light"
                                         @onclick="() => this.AddClauseToLayout(suggestion)">
                                        <div class="text-secondary small mb-2">@this.Localizer["ClickToAdd"]</div>
                                        <div class="fw-medium text-wrap">@suggestion</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</LoadingSkeleton>

@* Preview Modal *@
@if (this.m_showPreview)
{
    <div class="modal modal-blur fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@this.Localizer["PreviewTitle"]</h5>
                    <button type="button" class="btn-close" @onclick="this.TogglePreview"></button>
                </div>
                <div class="modal-body p-0" style="height: 600px; overflow-y: auto;">
                    <iframe srcdoc="@this.m_previewHtml" style="width: 100%; height: 100%; border: none;"></iframe>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            @onclick="this.TogglePreview">@this.CommonLocalizer["Close"]</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public int? TemplateId { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }

    private const long MAX_IMPORT_FILE_SIZE = 10 * 1024 * 1024;

    private DocumentTemplate m_template = new();
    private DocumentLayout m_layout = new();
    private bool m_loading = true;
    private bool m_saving;
    private bool m_showPreview;
    private string? m_previewHtml;
    private ElementReference m_containerRef;
    private IJSObjectReference? m_jsModule;
    private bool m_splitterInitialized;

    // AI Features
    private bool m_showAiSidebar = true;
    private string m_aiContext = "";
    private List<string> m_aiSuggestions = [];
    private bool m_loadingAi;

    // Import
    private InputFile? m_importFileInput;
    private bool m_importing;

    private string MainSectionName => this.Localizer["MainContent"];

    private DocumentPage CurrentPage => this.m_layout.Pages.Count > this.DesignerState.CurrentPageIndex
        ? this.m_layout.Pages[this.DesignerState.CurrentPageIndex]
        : this.m_layout.Pages.Last();

    private DocumentType m_documentType
    {
        get => this.m_template.Type;
        set
        {
            this.m_template.Type = value;
            this.DesignerState.DocumentType = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        this.DesignerState.OnStateChanged += this.StateHasChanged;
        await this.LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            this.m_jsModule = await this.JS.InvokeAsync<IJSObjectReference>("import", "./js/designer-splitter.js");
        }

        if (this.m_jsModule != null && !this.m_loading && !this.m_splitterInitialized)
        {
            this.m_splitterInitialized = true;
            await this.m_jsModule.InvokeVoidAsync("initSplitter", this.m_containerRef, DotNetObjectReference.Create(this));
        }
    }

    [JSInvokable]
    public void OnPanelResized(int leftWidth, int rightWidth)
    {
        this.DesignerState.LeftPanelWidth = leftWidth;
        this.DesignerState.RightPanelWidth = rightWidth;
    }

    [JSInvokable]
    public void OnPanelToggle(string panel)
    {
        if (panel == "left")
            this.DesignerState.ToggleLeftPanel();
        else
            this.DesignerState.ToggleRightPanel();

        this.InvokeAsync(this.StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        this.DesignerState.OnStateChanged -= this.StateHasChanged;
        if (this.m_jsModule != null)
        {
            await this.m_jsModule.InvokeVoidAsync("dispose", this.m_containerRef);
            await this.m_jsModule.DisposeAsync();
        }
    }

    private async Task GetAiSuggestions()
    {
        this.m_loadingAi = true;
        try
        {
            this.m_aiSuggestions = await this.AiService.GetSuggestedClausesAsync(this.m_template.Type, this.m_aiContext);
        }
        catch (Exception ex)
        {
            this.ShowError(this.Localizer["AiSuggestionFailed", ex.Message]);
        }
        finally
        {
            this.m_loadingAi = false;
        }
    }

    private void AddClauseToLayout(string clause)
    {
        var section = this.GetMainSection();
        var block = new TextBlock { Content = clause };
        section.Blocks.Add(block);
        this.DesignerState.SetSelectedBlock(block);
        this.ShowSuccess(this.Localizer["ClauseAdded"]);
    }

    private async Task TriggerImportFileAsync()
    {
        if (this.m_jsModule != null && this.m_importFileInput?.Element != null)
        {
            await this.m_jsModule.InvokeVoidAsync("triggerFileInput", this.m_importFileInput.Element);
        }
    }

    private async Task HandleImportFileAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > MAX_IMPORT_FILE_SIZE)
        {
            this.ShowError(this.Localizer["ImportFailed"]);
            return;
        }

        this.m_importing = true;
        try
        {
            await using var stream = file.OpenReadStream(MAX_IMPORT_FILE_SIZE);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            var layout = await this.AiService.ExtractTemplateLayoutAsync(fileBytes, file.ContentType, this.m_template.Type);
            if (layout?.Pages is { Count: > 0 })
            {
                foreach (var page in layout.Pages)
                {
                    foreach (var section in page.Sections)
                    {
                        this.CurrentPage.Sections.Add(section);
                    }
                }
                this.ShowSuccess(this.Localizer["ImportSuccess"]);
            }
            else if (layout?.Sections is { Count: > 0 })
            {
                foreach (var section in layout.Sections)
                {
                    this.CurrentPage.Sections.Add(section);
                }
                this.ShowSuccess(this.Localizer["ImportSuccess"]);
            }
            else
            {
                this.ShowError(this.Localizer["ImportFailed"]);
            }
        }
        catch
        {
            this.ShowError(this.Localizer["ImportFailed"]);
        }
        finally
        {
            this.m_importing = false;
        }
    }

    private async Task LoadDataAsync()
    {
        this.m_loading = true;
        try
        {
            if (this.TemplateId > 0)
            {
                var template = await this.TemplateService.GetTemplateByIdAsync(this.TemplateId.Value);
                if (template != null)
                {
                    this.m_template = template;
                    var layout = await this.TemplateService.GetTemplateLayoutAsync(this.m_template.StoreId);
                    if (layout != null) this.m_layout = layout;
                }
            }
            else
            {
                this.m_template = new DocumentTemplate
                {
                    Type = Enum.TryParse<DocumentType>(this.Type, true, out var t) ? t : DocumentType.Receipt,
                    Status = DocumentTemplateStatus.Draft
                };
                this.m_layout = new DocumentLayout
                {
                    Sections = [new LayoutSection { Name = this.MainSectionName }]
                };
            }

            this.m_layout.EnsurePages();
            this.DesignerState.CurrentPageIndex = 0;
            this.DesignerState.DocumentType = this.m_template.Type;
        }
        catch (Exception ex)
        {
            this.ShowError(this.Localizer["LoadError", ex.Message]);
        }
        finally
        {
            this.m_loading = false;
        }
    }

    private void DeleteSelectedBlock()
    {
        if (this.DesignerState.SelectedBlock == null) return;

        foreach (var section in this.CurrentPage.Sections)
        {
            if (section.Blocks.Contains(this.DesignerState.SelectedBlock))
            {
                section.Blocks.Remove(this.DesignerState.SelectedBlock);
                this.DesignerState.SetSelectedBlock(null);
                return;
            }
        }
    }

    private void AddBlock(string type)
    {
        var section = this.GetMainSection();
        LayoutBlock block = type switch
        {
            "heading" => new HeadingBlock { Content = this.Localizer["NewHeading"], Level = 2, HorizontalAlignment = "Center", IsBold = true },
            "text" => new TextBlock { Content = this.Localizer["NewTextBlock"], HorizontalAlignment = "Left" },
            "image" => new ImageBlock { Width = 200 },
            "table" => new TableBlock
            {
                Columns =
                [
                    new TableColumn { Header = this.Localizer["TableColumnItem"], BindingPath = "Description" },
                    new TableColumn { Header = this.Localizer["TableColumnQuantity"], BindingPath = "Quantity" },
                    new TableColumn { Header = this.Localizer["TableColumnPrice"], BindingPath = "Price" }
                ]
            },
            "divider" => new DividerBlock { Thickness = 1, Color = "#eeeeee" },
            "signature" => new SignatureBlock { Label = this.Localizer["AuthorizedSignature"] },
            "two-columns" => new TwoColumnBlock(),
            "spacer" => new SpacerBlock { Height = 20 },
            _ => new TextBlock { Content = this.Localizer["NewBlock"] }
        };

        section.Blocks.Add(block);
        this.DesignerState.SetSelectedBlock(block);
    }

    private async Task TogglePreview()
    {
        if (!this.m_showPreview)
        {
            var sampleData = await this.GetSampleDataAsync();
            this.m_previewHtml = this.HtmlRenderer.RenderHtml(this.m_layout, sampleData);
        }

        this.m_showPreview = !this.m_showPreview;
    }

    private async Task<Dictionary<string, object?>> GetSampleDataAsync()
    {
        var org = await this.OrganizationService.GetOrganizationByAccountNoAsync(this.AccountNo);
        var staff = new User { FullName = this.UserName, UserName = this.UserName };
        var booking = new Booking { BookingRef = "PRV-001", CustomerName = "John Preview" };
        return this.DataResolver.Resolve(booking, org ?? new Organization { Name = "Preview Org" }, staff);
    }

    private async Task SaveTemplateAsync()
    {
        if (string.IsNullOrWhiteSpace(this.m_template.Name))
        {
            this.ShowError(this.Localizer["NameRequired"]);
            return;
        }

        this.m_saving = true;
        try
        {
            var result = await this.TemplateService.SaveTemplateAsync(this.m_template, this.m_layout, this.UserName);
            if (result.Success)
            {
                this.ShowSuccess(this.Localizer["SaveSuccess"]);
                if (this.TemplateId == null || this.TemplateId == 0)
                {
                    this.NavigationManager.NavigateTo($"/settings/templates/designer/{this.m_template.DocumentTemplateId}");
                }
            }
            else
            {
                this.ShowError(this.Localizer["SaveError", result.Message ?? this.Localizer["UnknownError"]]);
            }
        }
        finally
        {
            this.m_saving = false;
        }
    }

    private LayoutSection GetMainSection()
    {
        var page = this.CurrentPage;
        if (!page.Sections.Any())
        {
            page.Sections.Add(new LayoutSection { Name = this.MainSectionName });
        }

        return page.Sections.Last();
    }

    private void AddPage()
    {
        var newPage = new DocumentPage
        {
            Name = $"Page {this.m_layout.Pages.Count + 1}",
            Sections = [new LayoutSection { Name = this.MainSectionName }]
        };
        this.m_layout.Pages.Add(newPage);
        this.DesignerState.SetCurrentPage(this.m_layout.Pages.Count - 1);
    }

    private void DeleteCurrentPage()
    {
        if (this.m_layout.Pages.Count <= 1) return;

        this.m_layout.Pages.RemoveAt(this.DesignerState.CurrentPageIndex);
        var newIndex = Math.Min(this.DesignerState.CurrentPageIndex, this.m_layout.Pages.Count - 1);
        this.DesignerState.SetCurrentPage(newIndex);
    }

    private void PreviousPage()
    {
        if (this.DesignerState.CurrentPageIndex > 0)
            this.DesignerState.SetCurrentPage(this.DesignerState.CurrentPageIndex - 1);
    }

    private void NextPage()
    {
        if (this.DesignerState.CurrentPageIndex < this.m_layout.Pages.Count - 1)
            this.DesignerState.SetCurrentPage(this.DesignerState.CurrentPageIndex + 1);
    }
}
