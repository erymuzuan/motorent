@using MotoRent.Domain.Entities
@using MotoRent.Domain.Models
@inherits LocalizedDialogBase<PricingRule, PricingRuleDialog>

<form id="@FormId" @onsubmit="SaveAsync" @onsubmit:preventDefault>
    <div class="modal-body">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label required">@Localizer["RuleName"]</label>
                <input type="text" class="form-control" @bind="Entity.Name" required
                       placeholder="@Localizer["RuleNamePlaceholder"]" />
            </div>

            <div class="col-md-4">
                <label class="form-label required">@Localizer["RuleType"]</label>
                <select class="form-select" @bind="Entity.RuleType" @bind:after="OnRuleTypeChanged" required>
                    @foreach (var type in Enum.GetValues<PricingRuleType>())
                    {
                        <option value="@type">@Localizer[type.ToString()]</option>
                    }
                </select>
            </div>

            <div class="col-12">
                <hr class="my-2" />
                <h6 class="mb-3">@Localizer["DateConfiguration"]</h6>
            </div>

            @if (Entity.RuleType == PricingRuleType.DayOfWeek)
            {
                <div class="col-12">
                    <label class="form-label required">@Localizer["SelectDays"]</label>
                    <div class="d-flex flex-column gap-1">
                        @foreach (DayOfWeek day in Enum.GetValues<DayOfWeek>())
                        {
                            var d = day;
                            var isSelected = Entity.ApplicableDaysOfWeek.Contains(d);
                            <label class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       checked="@isSelected"
                                       @onchange="@(e => ToggleDay(d, (bool)(e.Value ?? false)))" />
                                <span class="form-check-label">@Localizer[day.ToString()]</span>
                            </label>
                        }
                    </div>
                    @if (Entity.ApplicableDaysOfWeek.Count == 0)
                    {
                        <small class="text-danger">@Localizer["SelectAtLeastOneDay"]</small>
                    }
                </div>
            }
            else
            {
                <div class="col-md-6">
                    <label class="form-label required">@Localizer["StartDate"]</label>
                    <input type="date" class="form-control" lang="en" @bind="m_startDate" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label required">@Localizer["EndDate"]</label>
                    <input type="date" class="form-control" lang="en" @bind="m_endDate" required />
                </div>

                <div class="col-12">
                    <label class="form-check form-switch">
                        <input type="checkbox" class="form-check-input" @bind="Entity.IsRecurring" />
                        <span class="form-check-label">@Localizer["RecurringYearly"]</span>
                    </label>
                    <small class="form-hint">@Localizer["RecurringYearlyDescription"]</small>
                </div>
            }

            <div class="col-12">
                <hr class="my-2" />
                <h6 class="mb-3">@Localizer["PricingAdjustment"]</h6>
            </div>

            <div class="col-md-3">
                <label class="form-label required">@Localizer["Multiplier"]</label>
                <div class="input-group">
                    <input type="number" class="form-control" @bind="Entity.Multiplier"
                           min="0.1" max="10" step="0.05" required />
                    <span class="input-group-text">x</span>
                </div>
                <small class="form-hint">@Localizer["MultiplierHint"]</small>
            </div>

            <div class="col-md-3">
                <label class="form-label">@Localizer["AmountAdjustment"]</label>
                <div class="input-group">
                    <span class="input-group-text">@BaseCurrencySymbol</span>
                    <input type="number" class="form-control" @bind="Entity.AmountAdjustment"
                           step="1" />
                </div>
                <small class="form-hint">@Localizer["AmountAdjustmentHint"]</small>
            </div>

            <div class="col-md-3">
                <label class="form-label">@Localizer["MinRate"]</label>
                <div class="input-group">
                    <span class="input-group-text">@BaseCurrencySymbol</span>
                    <input type="number" class="form-control" @bind="Entity.MinRate"
                           min="0" step="1" />
                </div>
                <small class="form-hint">@Localizer["MinRateHint"]</small>
            </div>

            <div class="col-md-3">
                <label class="form-label">@Localizer["MaxRate"]</label>
                <div class="input-group">
                    <span class="input-group-text">@BaseCurrencySymbol</span>
                    <input type="number" class="form-control" @bind="Entity.MaxRate"
                           min="0" step="1" />
                </div>
                <small class="form-hint">@Localizer["MaxRateHint"]</small>
            </div>

            <div class="col-12">
                <div class="alert @GetPreviewAlertClass()">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="ti @GetPreviewIcon() ti-lg"></i>
                        </div>
                        <div>
                            <h4 class="alert-title">@Localizer["PricePreview"]</h4>
                            <div class="text-secondary">
                                @Localizer["BaseRateExample"]: @(BaseCurrencySymbol)500/day
                                <i class="ti ti-arrow-right mx-2"></i>
                                <strong>@(BaseCurrencySymbol)@(((500 * Entity.Multiplier) + Entity.AmountAdjustment).ToString("N0"))/day</strong>
                                (@FormatAdjustment())
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <hr class="my-2" />
                <h6 class="mb-3">@Localizer["AdvancedOptions"]</h6>
            </div>

            <div class="col-md-6">
                <label class="form-label">@Localizer["Priority"]</label>
                <input type="number" class="form-control" @bind="Entity.Priority"
                       min="1" max="1000" />
                <small class="form-hint">@Localizer["PriorityHint"]</small>
            </div>

            <div class="col-md-6">
                <label class="form-label">@Localizer["VehicleType"]</label>
                <select class="form-select" @bind="Entity.VehicleType">
                    <option value="">@Localizer["AllVehicles"]</option>
                    <option value="Motorbike">@Localizer["Motorbike"]</option>
                    <option value="Car">@Localizer["Car"]</option>
                    <option value="JetSki">@Localizer["JetSki"]</option>
                    <option value="Boat">@Localizer["Boat"]</option>
                    <option value="Van">@Localizer["Van"]</option>
                </select>
                <small class="form-hint">@Localizer["VehicleTypeHint"]</small>
            </div>

            <div class="col-12">
                <label class="form-check form-switch">
                    <input type="checkbox" class="form-check-input" @bind="Entity.ApplyToPackage"
                           @bind:after="OnApplyToPackageChanged" />
                    <span class="form-check-label">@Localizer["ApplyToPackage"]</span>
                </label>
                <small class="form-hint">@Localizer["ApplyToPackageHint"]</small>
            </div>

            @if (Entity.ApplyToPackage)
            {
                <div class="col-12">
                    <label class="form-label required">@Localizer["SelectPackages"]</label>
                    <div class="d-flex flex-column gap-1" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var pkg in m_packages)
                        {
                            var p = pkg;
                            var isSelected = IsPackageSelected(p);
                            <label class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       checked="@isSelected"
                                       @onchange="@(e => TogglePackage(p, (bool)(e.Value ?? false)))" />
                                <span class="form-check-label">@p.Display</span>
                            </label>
                        }
                    </div>
                    @if (Entity.TargetPackages.Count == 0)
                    {
                        <small class="text-danger">@Localizer["SelectAtLeastOnePackage"]</small>
                    }
                </div>
            }

            <div class="col-12">
                <label class="form-check form-switch">
                    <input type="checkbox" class="form-check-input" @bind="Entity.IsActive" />
                    <span class="form-check-label">@Localizer["Active"]</span>
                </label>
                <small class="form-hint">@Localizer["ActiveHint"]</small>
            </div>
        </div>
    </div>
</form>

<div class="modal-footer">
    <button type="button" class="btn btn-ghost-secondary" @onclick="Cancel">
        @Localizer["Cancel"]
    </button>
    <button type="submit" form="@FormId" class="btn btn-primary" disabled="@Saving">
        @if (Saving)
        {
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
        }
        <i class="ti ti-device-floppy me-1"></i>
        @SaveButtonText
    </button>
</div>

@code {
    private DateTime m_startDate;
    private DateTime m_endDate;
    private List<PackageOption> m_packages = [];

    protected override async Task OnInitializedAsync()
    {
        this.FormValid = true;
        this.m_startDate = Entity.StartDate.ToDateTime(TimeOnly.MinValue);
        this.m_endDate = Entity.EndDate.ToDateTime(TimeOnly.MinValue);

        // Migrate legacy single-day to multi-day format
        if (Entity.RuleType == PricingRuleType.DayOfWeek &&
            Entity.ApplicableDaysOfWeek.Count == 0 &&
            Entity.ApplicableDayOfWeek.HasValue)
        {
            Entity.ApplicableDaysOfWeek.Add(Entity.ApplicableDayOfWeek.Value);
        }

        // Load packages from all active FleetModels
        await LoadPackagesAsync();
    }

    private async Task LoadPackagesAsync()
    {
        var query = DataContext.CreateQuery<FleetModel>()
            .Where(m => m.IsActive);

        var result = await DataContext.LoadAsync(query, size: 500);

        foreach (var fm in result.ItemCollection)
        {
            foreach (var pkg in fm.HourlyPackages)
            {
                m_packages.Add(new PackageOption
                {
                    FleetModelId = fm.FleetModelId,
                    PackageName = pkg.Name,
                    Display = $"{pkg.Name} ({fm.DisplayNameWithEngine})"
                });
            }
        }
    }

    private void OnApplyToPackageChanged()
    {
        if (!Entity.ApplyToPackage)
        {
            // Clear package selection when disabled
            Entity.TargetPackages.Clear();
        }
    }

    private bool IsPackageSelected(PackageOption pkg)
    {
        return Entity.TargetPackages.Any(t =>
            t.FleetModelId == pkg.FleetModelId && t.PackageName == pkg.PackageName);
    }

    private void TogglePackage(PackageOption pkg, bool selected)
    {
        if (selected)
        {
            if (!IsPackageSelected(pkg))
            {
                Entity.TargetPackages.Add(new PackageTarget
                {
                    FleetModelId = pkg.FleetModelId,
                    PackageName = pkg.PackageName
                });
            }
        }
        else
        {
            Entity.TargetPackages.RemoveAll(t =>
                t.FleetModelId == pkg.FleetModelId && t.PackageName == pkg.PackageName);
        }
    }

    private class PackageOption
    {
        public int FleetModelId { get; set; }
        public string PackageName { get; set; } = "";
        public string Display { get; set; } = "";
    }

    private void OnRuleTypeChanged()
    {
        if (Entity.RuleType == PricingRuleType.DayOfWeek)
        {
            // Initialize with Saturday if no days selected
            if (Entity.ApplicableDaysOfWeek.Count == 0)
            {
                Entity.ApplicableDaysOfWeek.Add(DayOfWeek.Saturday);
            }
        }
    }

    private void ToggleDay(DayOfWeek day, bool selected)
    {
        if (selected)
        {
            if (!Entity.ApplicableDaysOfWeek.Contains(day))
            {
                Entity.ApplicableDaysOfWeek.Add(day);
            }
        }
        else
        {
            Entity.ApplicableDaysOfWeek.Remove(day);
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(this.Entity.Name))
        {
            this.ShowError(Localizer["RuleNameRequired"]);
            return;
        }

        if (Entity.Multiplier <= 0 || Entity.Multiplier > 10)
        {
            this.ShowError(Localizer["MultiplierInvalid"]);
            return;
        }

        if (Entity.RuleType == PricingRuleType.DayOfWeek && Entity.ApplicableDaysOfWeek.Count == 0)
        {
            this.ShowError(Localizer["SelectAtLeastOneDay"]);
            return;
        }

        // Sync dates from DateTime back to DateOnly
        Entity.StartDate = DateOnly.FromDateTime(m_startDate);
        Entity.EndDate = DateOnly.FromDateTime(m_endDate);

        if (Entity.RuleType != PricingRuleType.DayOfWeek && Entity.EndDate < Entity.StartDate)
        {
            this.ShowError(Localizer["EndDateBeforeStartDate"]);
            return;
        }

        if (Entity.IsRecurring && Entity.RuleType != PricingRuleType.DayOfWeek)
        {
            Entity.RecurringMonth = Entity.StartDate.Month;
            Entity.RecurringDay = Entity.StartDate.Day;
        }

        // Validate package selection
        if (Entity.ApplyToPackage && Entity.TargetPackages.Count == 0)
        {
            this.ShowError(Localizer["SelectAtLeastOnePackage"]);
            return;
        }

        // Clear packages if not applying to packages
        if (!Entity.ApplyToPackage)
        {
            Entity.TargetPackages.Clear();
        }

        this.Saving = true;

        try
        {
            using var session = this.DataContext.OpenSession(this.UserName);
            session.Attach(this.Entity);
            var result = await session.SubmitChanges(
                this.IsNew ? "Create pricing rule" : "Update pricing rule");

            if (result.Success)
            {
                this.Close();
            }
            else
            {
                this.ShowError($"Save failed: {result.Message}");
            }
        }
        finally
        {
            this.Saving = false;
        }
    }

    private string GetPreviewAlertClass()
    {
        var effectiveChange = (Entity.Multiplier - 1.0m) * 500 + Entity.AmountAdjustment;
        if (effectiveChange < 0) return "alert-success";
        if (effectiveChange > 0) return "alert-warning";
        return "alert-info";
    }

    private string GetPreviewIcon()
    {
        var effectiveChange = (Entity.Multiplier - 1.0m) * 500 + Entity.AmountAdjustment;
        if (effectiveChange < 0) return "ti-discount-2";
        if (effectiveChange > 0) return "ti-trending-up";
        return "ti-minus";
    }

    private string FormatAdjustment()
    {
        var parts = new List<string>();

        if (Entity.Multiplier != 1.0m)
        {
            var pct = (Entity.Multiplier - 1.0m) * 100;
            parts.Add(pct >= 0 ? $"+{pct:N0}%" : $"{pct:N0}%");
        }

        if (Entity.AmountAdjustment != 0)
        {
            parts.Add(Entity.AmountAdjustment >= 0 ? $"+{BaseCurrencySymbol}{Entity.AmountAdjustment:N0}" : $"{BaseCurrencySymbol}{Entity.AmountAdjustment:N0}");
        }

        return parts.Count > 0 ? string.Join(" ", parts) : "ไม่มีการปรับราคา";
    }
}
