@page "/settings/billing"
@using Microsoft.AspNetCore.Authorization
@using MotoRent.Domain.Core
@attribute [Authorize(Roles = "OrgAdmin")]
@inherits LocalizedComponentBase<BillingDashboard>
@inject OrganizationService OrganizationService

<MotoRentPageTitle>@Localizer["BillingDashboard"]</MotoRentPageTitle>

<TablerHeader Title="@Localizer["BillingDashboard"]" PreTitle="@Localizer["ManageSubscription"]">
    <button class="btn btn-primary" @onclick="UpgradePlan">
        <i class="ti ti-arrow-up-circle me-2"></i>
        @Localizer["UpgradePlan"]
    </button>
</TablerHeader>

<LoadingSkeleton Loading="@m_loading">
    @if (m_organization != null)
    {
        <div class="row row-cards">
            @* Current Plan *@
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-status-top bg-primary"></div>
                    <div class="card-body text-center">
                        <div class="text-secondary text-uppercase fw-bold mb-3">@Localizer["CurrentPlan"]</div>
                        <div class="display-5 fw-bold mb-3">@m_organization.SubscriptionPlan</div>
                        
                        @if (m_organization.SubscriptionPlan == SubscriptionPlan.Free)
                        {
                            <span class="badge bg-green-lt">@Localizer["FreeForever"]</span>
                        }
                        else
                        {
                            <div class="mb-2">
                                @if (m_organization.TrialEndDate.HasValue && m_organization.TrialEndDate > DateTimeOffset.UtcNow)
                                {
                                    <span class="badge bg-yellow-lt">
                                        @Localizer["TrialEndsIn"] @((int)(m_organization.TrialEndDate.Value - DateTimeOffset.UtcNow).TotalDays) @Localizer["Days"]
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-green-lt">@Localizer["Active"]</span>
                                }
                            </div>
                            <div class="text-secondary">
                                @Localizer["NextBillingDate"]: @FormatDate(m_organization.TrialEndDate?.AddDays(1) ?? DateTimeOffset.UtcNow.AddMonths(1))
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Payment Method *@
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <div class="text-secondary text-uppercase fw-bold mb-3">@Localizer["PaymentMethod"]</div>
                        <div class="mb-3">
                            <i class="ti ti-credit-card icon-lg text-secondary"></i>
                        </div>
                        <div class="mb-3">
                            <h4>Visa •••• 4242</h4>
                            <div class="text-secondary">@Localizer["Expires"] 12/28</div>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm">
                            @Localizer["UpdatePaymentMethod"]
                        </button>
                    </div>
                </div>
            </div>

            @* Billing History *@
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">@Localizer["BillingHistory"]</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table card-table table-vcenter">
                            <thead>
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Description"]</th>
                                    <th>@Localizer["Amount"]</th>
                                    <th>@Localizer["Status"]</th>
                                    <th>@Localizer["Invoice"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @* Mock Data *@
                                <tr>
                                    <td>@FormatDate(DateTimeOffset.UtcNow.AddDays(-15))</td>
                                    <td>
                                        Subscription: @m_organization.SubscriptionPlan (Monthly)
                                    </td>
                                    <td>@FormatCurrency(m_organization.SubscriptionPlan == SubscriptionPlan.Pro ? 799 : 1199)</td>
                                    <td>
                                        <span class="badge bg-success-lt">@Localizer["Paid"]</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-icon btn-ghost-secondary btn-sm">
                                            <i class="ti ti-download"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</LoadingSkeleton>

@code {
    private Organization? m_organization;
    private bool m_loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        m_loading = true;
        try
        {
            if (AccountNo != null)
            {
                m_organization = await OrganizationService.GetOrganizationByAccountNoAsync(AccountNo);
            }
        }
        finally
        {
            m_loading = false;
        }
    }

    private void UpgradePlan()
    {
        // TODO: Navigate to upgrade page or show modal
        ShowInfo("Upgrade plan feature coming soon!");
    }
}
