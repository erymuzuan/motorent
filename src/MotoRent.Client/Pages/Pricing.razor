@page "/pricing"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout Layout.PublicLayout
@inherits LocalizedComponentBase<Pricing>

<PageTitle>@Localizer["PageTitle"] - MotoRent</PageTitle>

<div class="pricing-page">
    @* Hero Section with Animated Background *@
    <section class="pricing-hero">
        <div class="hero-bg-pattern"></div>
        <div class="container-xl position-relative">
            <div class="text-center">
                <span class="pricing-badge mr-animate-in">
                    <i class="ti ti-discount-2 me-1"></i>
                    @Localizer["FreeTrial"]
                </span>
                <h1 class="pricing-headline mr-animate-in mr-animate-delay-1">
                    @Localizer["Headline"]
                </h1>
                <p class="pricing-subheadline mr-animate-in mr-animate-delay-2">
                    @Localizer["Subheadline"]
                </p>
            </div>
        </div>
    </section>

    @* Pricing Toggle (Monthly/Annual) *@
    <section class="pricing-toggle-section">
        <div class="container-xl">
            <div class="pricing-toggle mr-animate-in mr-animate-delay-2">
                <button class="toggle-btn @(m_isAnnual ? "" : "active")" @onclick="() => m_isAnnual = false">
                    @Localizer["Monthly"]
                </button>
                <button class="toggle-btn @(m_isAnnual ? "active" : "")" @onclick="() => m_isAnnual = true">
                    @Localizer["Annual"]
                    <span class="save-badge">@Localizer["Save20"]</span>
                </button>
            </div>
        </div>
    </section>

    @* Pricing Cards *@
    <section class="pricing-cards-section">
        <div class="container-xl">
            <div class="row g-4 justify-content-center">
                @* Free Plan *@
                <div class="col-lg-4 col-md-6">
                    <div class="pricing-card free mr-animate-in mr-animate-delay-1">
                        <div class="card-top-accent"></div>
                        <div class="pricing-card-header">
                            <div class="plan-icon free">
                                <i class="ti ti-leaf"></i>
                            </div>
                            <h3 class="plan-name">@Localizer["FreePlan"]</h3>
                            <p class="plan-tagline">@Localizer["FreeTagline"]</p>
                        </div>
                        <div class="pricing-card-price">
                            <span class="currency">RM</span>
                            <span class="amount">0</span>
                            <span class="period">/@Localizer["Month"]</span>
                        </div>
                        <div class="pricing-card-features">
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["Feature1Shop"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["Feature5Vehicles"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureBasicReports"]</span>
                            </div>
                            <div class="feature excluded">
                                <i class="ti ti-x"></i>
                                <span>@Localizer["FeatureOcr"]</span>
                            </div>
                            <div class="feature excluded">
                                <i class="ti ti-x"></i>
                                <span>@Localizer["FeatureMaintenance"]</span>
                            </div>
                            <div class="feature excluded">
                                <i class="ti ti-x"></i>
                                <span>@Localizer["FeatureMultiCurrency"]</span>
                            </div>
                            <div class="feature excluded">
                                <i class="ti ti-x"></i>
                                <span>@Localizer["FeatureApi"]</span>
                            </div>
                        </div>
                        <div class="pricing-card-cta">
                            <a href="/signup?plan=Free" class="cta-btn free">
                                @Localizer["GetStartedFree"]
                                <i class="ti ti-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

                @* Pro Plan - Featured *@
                <div class="col-lg-4 col-md-6">
                    <div class="pricing-card pro featured mr-animate-in mr-animate-delay-2">
                        <div class="featured-ribbon">
                            <i class="ti ti-star-filled"></i>
                            @Localizer["MostPopular"]
                        </div>
                        <div class="card-top-accent"></div>
                        <div class="pricing-card-header">
                            <div class="plan-icon pro">
                                <i class="ti ti-bolt"></i>
                            </div>
                            <h3 class="plan-name">@Localizer["ProPlan"]</h3>
                            <p class="plan-tagline">@Localizer["ProTagline"]</p>
                        </div>
                        <div class="pricing-card-price">
                            <span class="currency">RM</span>
                            <span class="amount">@(m_isAnnual ? "55" : "69")</span>
                            <span class="period">/@Localizer["Month"]</span>
                            @if (m_isAnnual)
                            {
                                <div class="annual-note">@Localizer["BilledAnnually"]</div>
                            }
                        </div>
                        <div class="pricing-card-features">
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["Feature3Shops"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["Feature15Vehicles"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureMostReports"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureOcr"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureMaintenance"]</span>
                            </div>
                            <div class="feature excluded">
                                <i class="ti ti-x"></i>
                                <span>@Localizer["FeatureMultiCurrency"]</span>
                            </div>
                            <div class="feature excluded">
                                <i class="ti ti-x"></i>
                                <span>@Localizer["FeatureApi"]</span>
                            </div>
                        </div>
                        <div class="pricing-card-cta">
                            <a href="/signup?plan=Pro" class="cta-btn pro">
                                @Localizer["StartProTrial"]
                                <i class="ti ti-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

                @* Ultra Plan *@
                <div class="col-lg-4 col-md-6">
                    <div class="pricing-card ultra mr-animate-in mr-animate-delay-3">
                        <div class="card-top-accent"></div>
                        <div class="pricing-card-header">
                            <div class="plan-icon ultra">
                                <i class="ti ti-diamond"></i>
                            </div>
                            <h3 class="plan-name">@Localizer["UltraPlan"]</h3>
                            <p class="plan-tagline">@Localizer["UltraTagline"]</p>
                        </div>
                        <div class="pricing-card-price">
                            <span class="currency">RM</span>
                            <span class="amount">@(m_isAnnual ? "79" : "99")</span>
                            <span class="period">/@Localizer["Month"]</span>
                            @if (m_isAnnual)
                            {
                                <div class="annual-note">@Localizer["BilledAnnually"]</div>
                            }
                        </div>
                        <div class="pricing-card-features">
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureUnlimitedShops"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["Feature30Vehicles"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureFullFinancial"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureOcr"]</span>
                            </div>
                            <div class="feature included">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureMaintenance"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureAccidentsDamages"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureDepreciation"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureMultiCurrency"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureCustomBranding"]</span>
                            </div>
                            <div class="feature included highlight">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["FeatureApi"]</span>
                            </div>
                        </div>
                        <div class="pricing-card-cta">
                            <a href="/signup?plan=Ultra" class="cta-btn ultra">
                                @Localizer["StartUltraTrial"]
                                <i class="ti ti-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Enterprise Contact *@
    <section class="enterprise-section">
        <div class="container-xl">
            <div class="enterprise-banner mr-animate-in">
                <div class="enterprise-content">
                    <i class="ti ti-building-skyscraper"></i>
                    <div>
                        <h4>@Localizer["EnterpriseTitle"]</h4>
                        <p>@Localizer["EnterpriseDescription"]</p>
                    </div>
                </div>
                <a href="/contact" class="enterprise-cta">
                    @Localizer["ContactSales"]
                    <i class="ti ti-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    @* Add-ons Section *@
    <section class="addons-section">
        <div class="container-xl">
            <h2 class="section-title mr-animate-in">@Localizer["AddonsTitle"]</h2>
            <div class="row g-4 justify-content-center">
                <div class="col-md-5">
                    <div class="addon-card mr-animate-in mr-animate-delay-1">
                        <div class="addon-icon">
                            <i class="ti ti-headset"></i>
                        </div>
                        <div class="addon-content">
                            <h4>@Localizer["DedicatedSupport"]</h4>
                            <p>@Localizer["DedicatedSupportDesc"]</p>
                        </div>
                        <div class="addon-price">
                            <span class="currency">RM</span>299.00<span class="period">/@Localizer["Month"]</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="addon-card mr-animate-in mr-animate-delay-2">
                        <div class="addon-icon tourist">
                            <i class="ti ti-device-mobile"></i>
                        </div>
                        <div class="addon-content">
                            <h4>@Localizer["TouristApp"]</h4>
                            <p>@Localizer["TouristAppDesc"]</p>
                        </div>
                        <div class="addon-price coming-soon">
                            @Localizer["ComingSoon"]
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Feature Comparison Table *@
    <section class="comparison-section">
        <div class="container-xl">
            <h2 class="section-title mr-animate-in">@Localizer["CompareTitle"]</h2>
            <div class="comparison-table-wrapper mr-animate-in mr-animate-delay-1">
                <table class="comparison-table">
                    <thead>
                        <tr>
                            <th class="feature-col">@Localizer["Features"]</th>
                            <th class="plan-col free">@Localizer["FreePlan"]</th>
                            <th class="plan-col pro">@Localizer["ProPlan"]</th>
                            <th class="plan-col ultra">@Localizer["UltraPlan"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Localizer["ShopLocations"]</td>
                            <td>1</td>
                            <td>3</td>
                            <td>@Localizer["Unlimited"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["Vehicles"]</td>
                            <td>2</td>
                            <td>10</td>
                            <td>20</td>
                        </tr>
                        <tr>
                            <td>@Localizer["Reports"]</td>
                            <td>@Localizer["Basic"]</td>
                            <td>@Localizer["Most"]</td>
                            <td>@Localizer["FullFinancial"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["OcrScanning"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                        <tr>
                            <td>@Localizer["MaintenanceTracking"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                        <tr>
                            <td>@Localizer["AccidentsDamagesTracking"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                        <tr>
                            <td>@Localizer["AssetDepreciation"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                        <tr>
                            <td>@Localizer["MultiCurrencySupport"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                        <tr>
                            <td>@Localizer["CustomBrandingFeature"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                        <tr>
                            <td>@Localizer["ApiAccess"]</td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-x text-secondary"></i></td>
                            <td><i class="ti ti-check text-success"></i></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    @* FAQ Section *@
    <section class="faq-section">
        <div class="container-xl">
            <h2 class="section-title mr-animate-in">@Localizer["FaqTitle"]</h2>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="faq-list">
                        <div class="faq-item mr-animate-in mr-animate-delay-1">
                            <button class="faq-question @(m_expandedFaq == 1 ? "expanded" : "")" @onclick="() => ToggleFaq(1)">
                                <span>@Localizer["Faq1Question"]</span>
                                <i class="ti ti-chevron-down"></i>
                            </button>
                            @if (m_expandedFaq == 1)
                            {
                                <div class="faq-answer">
                                    <p>@Localizer["Faq1Answer"]</p>
                                </div>
                            }
                        </div>
                        <div class="faq-item mr-animate-in mr-animate-delay-2">
                            <button class="faq-question @(m_expandedFaq == 2 ? "expanded" : "")" @onclick="() => ToggleFaq(2)">
                                <span>@Localizer["Faq2Question"]</span>
                                <i class="ti ti-chevron-down"></i>
                            </button>
                            @if (m_expandedFaq == 2)
                            {
                                <div class="faq-answer">
                                    <p>@Localizer["Faq2Answer"]</p>
                                </div>
                            }
                        </div>
                        <div class="faq-item mr-animate-in mr-animate-delay-3">
                            <button class="faq-question @(m_expandedFaq == 3 ? "expanded" : "")" @onclick="() => ToggleFaq(3)">
                                <span>@Localizer["Faq3Question"]</span>
                                <i class="ti ti-chevron-down"></i>
                            </button>
                            @if (m_expandedFaq == 3)
                            {
                                <div class="faq-answer">
                                    <p>@Localizer["Faq3Answer"]</p>
                                </div>
                            }
                        </div>
                        <div class="faq-item mr-animate-in mr-animate-delay-4">
                            <button class="faq-question @(m_expandedFaq == 4 ? "expanded" : "")" @onclick="() => ToggleFaq(4)">
                                <span>@Localizer["Faq4Question"]</span>
                                <i class="ti ti-chevron-down"></i>
                            </button>
                            @if (m_expandedFaq == 4)
                            {
                                <div class="faq-answer">
                                    <p>@Localizer["Faq4Answer"]</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* CTA Section *@
    <section class="cta-section">
        <div class="cta-bg-gradient"></div>
        <div class="container-xl position-relative">
            <div class="cta-content mr-animate-in">
                <h2>@Localizer["CtaHeadline"]</h2>
                <p>@Localizer["CtaSubheadline"]</p>
                <div class="cta-buttons">
                    <a href="/signup" class="cta-primary">
                        <i class="ti ti-rocket me-2"></i>
                        @Localizer["StartFreeTrial"]
                    </a>
                    <a href="/" class="cta-secondary">
                        @Localizer["LearnMore"]
                        <i class="ti ti-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="cta-features">
                    <span><i class="ti ti-check me-1"></i>@Localizer["NoCreditCard"]</span>
                    <span><i class="ti ti-check me-1"></i>@Localizer["SetupMinutes"]</span>
                    <span><i class="ti ti-check me-1"></i>@Localizer["CancelAnytime"]</span>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* ============================================
       PRICING PAGE - Tropical Premium Aesthetic
       ============================================ */

    .pricing-page {
        --pricing-teal: #00897B;
        --pricing-teal-dark: #00695C;
        --pricing-teal-light: #4DB6AC;
        --pricing-orange: #FF7043;
        --pricing-gold: #FFB300;
        --pricing-bg: #f8fafb;
        --pricing-card-bg: #ffffff;
        --pricing-text: #1e293b;
        --pricing-text-muted: #64748b;
        font-family: "Kanit", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--pricing-bg);
        overflow-x: hidden;
    }

    /* Hero Section */
    .pricing-hero {
        position: relative;
        padding: 5rem 0 3rem;
        background: linear-gradient(135deg, #00695C 0%, #00897B 50%, #4DB6AC 100%);
        overflow: hidden;
    }

    .hero-bg-pattern {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 20% 80%, rgba(255,255,255,0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 40%),
            url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.6;
    }

    .pricing-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 179, 0, 0.2);
        color: #FFE082;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255, 179, 0, 0.3);
    }

    .pricing-headline {
        color: white;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 1rem;
        text-shadow: 0 2px 20px rgba(0,0,0,0.15);
    }

    .pricing-subheadline {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1.25rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Toggle Section */
    .pricing-toggle-section {
        padding: 2rem 0;
        margin-top: -2rem;
        position: relative;
        z-index: 10;
    }

    .pricing-toggle {
        display: inline-flex;
        background: var(--pricing-card-bg);
        border-radius: 50px;
        padding: 0.375rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        margin: 0 auto;
    }

    .toggle-btn {
        position: relative;
        padding: 0.75rem 1.5rem;
        border: none;
        background: transparent;
        border-radius: 50px;
        font-weight: 500;
        color: var(--pricing-text-muted);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .toggle-btn.active {
        background: var(--pricing-teal);
        color: white;
        box-shadow: 0 2px 10px rgba(0, 137, 123, 0.3);
    }

    .save-badge {
        position: absolute;
        top: -8px;
        right: -5px;
        background: var(--pricing-orange);
        color: white;
        font-size: 0.625rem;
        padding: 0.125rem 0.5rem;
        border-radius: 50px;
        font-weight: 600;
        text-transform: uppercase;
    }

    /* Pricing Cards */
    .pricing-cards-section {
        padding: 2rem 0 4rem;
    }

    .pricing-card {
        position: relative;
        background: var(--pricing-card-bg);
        border-radius: 24px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .pricing-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    }

    .pricing-card.featured {
        border: 2px solid var(--pricing-teal);
        transform: scale(1.02);
        z-index: 5;
    }

    .pricing-card.featured:hover {
        transform: scale(1.02) translateY(-8px);
    }

    .card-top-accent {
        height: 6px;
        background: linear-gradient(90deg, #e2e8f0 0%, #cbd5e1 100%);
    }

    .pricing-card.pro .card-top-accent {
        background: linear-gradient(90deg, var(--pricing-teal) 0%, var(--pricing-teal-light) 100%);
    }

    .pricing-card.ultra .card-top-accent {
        background: linear-gradient(90deg, var(--pricing-gold) 0%, #FFC107 100%);
    }

    .featured-ribbon {
        position: absolute;
        top: 1.25rem;
        right: -2rem;
        background: var(--pricing-teal);
        color: white;
        padding: 0.375rem 2.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        transform: rotate(45deg);
        box-shadow: 0 2px 10px rgba(0, 137, 123, 0.3);
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .featured-ribbon i {
        font-size: 0.625rem;
    }

    .pricing-card-header {
        padding: 2rem 2rem 1rem;
        text-align: center;
    }

    .plan-icon {
