@inherits LocalizedComponentBase<CheckIn>
@using MotoRent.Domain.Entities
@using MotoRent.Domain.Models
@using MotoRent.Client.Pages.Rentals
@using MotoRent.Services
@inject DynamicPricingService DynamicPricingService
@inject InsuranceService InsuranceService
@inject AccessoryService AccessoryService
@inject ServiceLocationService LocationService
@inject RentalPricingService PricingService
@inject ShopService ShopService
@inject OperatingHoursService HoursService

<div class="d-flex flex-column gap-4">
    <div>
        <h5 class="mb-1">@Localizer["ConfigureHourlyRental"]</h5>
        <p class="text-secondary mb-0">@Localizer["ConfigureHourlyRentalDesc"]</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-md-8">
            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title mb-3">
                        <i class="ti ti-@(IsPackageMode ? "package" : "clock") me-2"></i>@Localizer[IsPackageMode ? "SelectPackage" : "SelectHours"]
                    </h6>

                    <div class="row g-3">
                        @if (IsPackageMode)
                        {
                            @* Package Mode: Show packages from HourlyPackages with date-aware pricing *@
                            @foreach (var package in (SelectedVehicle?.HourlyPackages ?? []).OrderBy(p => p.Hours))
                            {
                                var pkg = package;
                                var adjustedPrice = m_adjustedPrices.GetValueOrDefault(pkg.Hours, pkg.Price);
                                var linearPrice = m_adjustedHourlyRate * pkg.Hours;
                                var savings = linearPrice - adjustedPrice;
                                <div class="col-6 col-md-4">
                                    <div class="card h-100 @(m_selectedHours == pkg.Hours ? "border-primary border-2" : "")"
                                         style="cursor: pointer;"
                                         @onclick="@(() => SelectHours(pkg.Hours))">
                                        <div class="card-body text-center py-3">
                                            <div class="mb-2">
                                                <span class="avatar avatar-lg @(m_selectedHours == pkg.Hours ? "bg-primary text-white" : "bg-primary-lt text-primary")">
                                                    <i class="ti ti-package" style="font-size: 1.5rem;"></i>
                                                </span>
                                            </div>
                                            <h3 class="mb-0">@(string.IsNullOrEmpty(pkg.Name) ? $"{pkg.Hours} {Localizer["Hours"]}" : pkg.Name)</h3>
                                            <div class="text-muted small">@pkg.Hours @Localizer[pkg.Hours == 1 ? "HourSingular" : "Hours"]</div>
                                            <div class="text-primary fw-bold" style="font-size: 1.25rem;">
                                                @FormatCurrency(adjustedPrice)
                                            </div>
                                            @if (savings > 0)
                                            {
                                                <div class="text-success small">
                                                    <i class="ti ti-discount-2 me-1"></i>@Localizer["SaveAmount", FormatCurrency(savings)]
                                                </div>
                                            }
                                            @if (m_selectedHours == pkg.Hours)
                                            {
                                                <i class="ti ti-circle-check text-success mt-2" style="font-size: 1.5rem;"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            @* Hourly Mode: Show standard hour options (no savings) *@
                            @foreach (var hours in new[] { 1, 2, 3, 4, 6, 8 })
                            {
                                var h = hours;
                                var price = m_adjustedHourlyRate * h;
                                <div class="col-6 col-md-4">
                                    <div class="card h-100 @(m_selectedHours == h ? "border-primary border-2" : "")"
                                         style="cursor: pointer;"
                                         @onclick="@(() => SelectHours(h))">
                                        <div class="card-body text-center py-3">
                                            <div class="mb-2">
                                                <span class="avatar avatar-lg @(m_selectedHours == h ? "bg-primary text-white" : "bg-primary-lt text-primary")">
                                                    <i class="ti ti-clock-hour-@(h > 9 ? 12 : h)" style="font-size: 1.5rem;"></i>
                                                </span>
                                            </div>
                                            <h3 class="mb-0">@h @Localizer[h == 1 ? "HourSingular" : "Hours"]</h3>
                                            <div class="text-primary fw-bold" style="font-size: 1.25rem;">
                                                @FormatCurrency(price)
                                            </div>
                                            @if (m_selectedHours == h)
                                            {
                                                <i class="ti ti-circle-check text-success mt-2" style="font-size: 1.5rem;"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @if (!IsPackageMode)
                    {
                        @* Custom hours input - only show in Hourly mode *@
                        <div class="mt-3">
                            <label class="form-label">@Localizer["CustomHours"]</label>
                            <div class="input-group" style="max-width: 200px;">
                                <input type="number" class="form-control"
                                       value="@m_selectedHours"
                                       @onchange="@((ChangeEventArgs e) => OnCustomHoursChanged(e.Value?.ToString()))"
                                       min="1" max="24" />
                                <span class="input-group-text">@Localizer["Hours"]</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title mb-3">
                        <i class="ti ti-clock-play me-2"></i>@Localizer["StartTime"]
                    </h6>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Date"]</label>
                            <input type="date" class="form-control" lang="en"
                                   @bind="m_startDate" @bind:after="OnDateChangedAsync"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Time"]</label>
                            <input type="time" class="form-control"
                                   value="@m_startTimeString"
                                   @onchange="@((ChangeEventArgs e) => OnTimeChanged(e.Value?.ToString()))" />
                        </div>
                    </div>

                    <div class="alert alert-info mt-3 mb-0">
                        <div class="d-flex align-items-center gap-2">
                            <i class="ti ti-info-circle"></i>
                            <span>
                                @Localizer["RentalEndsAt"] <strong>@GetEndTimeDisplay()</strong>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @* Insurance Section *@
            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="card-title mb-1">@Localizer["InsuranceQuestion"]</h6>
                    <p class="text-muted small mb-3">@Localizer["InsuranceSubtitle"]</p>

                    @if (m_loadingInsurance)
                    {
                        <div class="progress progress-sm">
                            <div class="progress-bar progress-bar-indeterminate"></div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            <label class="form-selectgroup-item">
                                <input type="radio" name="insurance-hourly" class="form-selectgroup-input"
                                       checked="@(m_selectedInsuranceId == null)"
                                       @onchange="@(() => SelectInsuranceAsync(null))" />
                                <span class="form-selectgroup-label d-flex justify-content-between align-items-center w-100">
                                    <span class="d-flex align-items-center gap-3">
                                        <span class="avatar avatar-sm bg-secondary-lt">
                                            <i class="ti ti-shield-off"></i>
                                        </span>
                                        <span class="d-flex flex-column">
                                            <span class="fw-medium">@Localizer["NoProtection"]</span>
                                        </span>
                                    </span>
                                    <span class="text-secondary">@Localizer["Free"]</span>
                                </span>
                            </label>

                            @foreach (var insurance in m_insurances)
                            {
                                <label class="form-selectgroup-item">
                                    <input type="radio" name="insurance-hourly" class="form-selectgroup-input"
                                           checked="@(m_selectedInsuranceId == insurance.InsuranceId)"
                                           @onchange="@(() => SelectInsuranceAsync(insurance.InsuranceId))" />
                                    <span class="form-selectgroup-label d-flex align-items-start w-100">
                                        <span class="avatar avatar-sm bg-primary-lt flex-shrink-0 me-3">
                                            <i class="ti ti-shield-check"></i>
                                        </span>
                                        <span class="d-flex flex-column flex-grow-1">
                                            <span class="fw-medium text-primary">@insurance.Name</span>
                                            <small class="text-secondary">@insurance.Description</small>
                                            <small class="text-muted">
                                                @Localizer["MaxCoverage"]: @FormatCurrency(insurance.MaxCoverage) |
                                                @Localizer["Deductible"]: @FormatCurrency(insurance.Deductible)
                                            </small>
                                        </span>
                                        <span class="text-primary fw-medium ms-3 flex-shrink-0 text-end" style="white-space: nowrap;">
                                            @FormatCurrency(insurance.DailyRate)
                                        </span>
                                    </span>
                                </label>
                            }
                        </div>

                        <div class="mt-3 text-muted small">
                            <a href="/insurance-terms" target="_blank" class="text-muted">
                                <i class="ti ti-info-circle me-1"></i>@Localizer["InsuranceTermsApply"]
                            </a>
                        </div>
                    }
                </div>
            </div>

            @* Accessories Section *@
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title mb-3">@Localizer["Accessories"]</h6>

                    @if (m_loadingAccessories)
                    {
                        <div class="progress progress-sm">
                            <div class="progress-bar progress-bar-indeterminate"></div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var accessory in m_accessories)
                            {
                                var selection = m_accessorySelections.FirstOrDefault(a => a.AccessoryId == accessory.AccessoryId);
                                var isSelected = selection != null;

                                <div class="card bg-light">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center gap-3">
                                                <label class="form-check mb-0">
                                                    <input class="form-check-input" type="checkbox"
                                                           checked="@isSelected"
                                                           @onchange="@((ChangeEventArgs e) => ToggleAccessoryAsync(accessory, (bool)(e.Value ?? false)))" />
                                                </label>
                                                <div class="d-flex flex-column">
                                                    <span>
                                                        @accessory.Name
                                                        @if (accessory.IsIncluded)
                                                        {
                                                            <span class="badge bg-success ms-2">@Localizer["Free"]</span>
                                                        }
                                                    </span>
                                                    <small class="text-secondary">
                                                        @(accessory.IsIncluded ? Localizer["IncludedWithRental"] : FormatCurrency(accessory.DailyRate))
                                                    </small>
                                                </div>
                                            </div>

                                            @if (isSelected && !accessory.IsIncluded)
                                            {
                                                <div style="width: 80px;">
                                                    <input type="number" class="form-control form-control-sm"
                                                           min="1" max="@accessory.QuantityAvailable"
                                                           @bind="selection!.Quantity" @bind:after="UpdateConfig" />
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Pick-up/Drop-off Location *@
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title mb-3">
                        <i class="ti ti-map-pin me-2"></i>@Localizer["PickupDropoff"]
                    </h6>

                    @if (m_loadingLocations)
                    {
                        <div class="progress progress-sm">
                            <div class="progress-bar progress-bar-indeterminate"></div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @* Pickup Location *@
                            <div class="col-12">
                                <label class="form-label">@Localizer["PickupLocation"]</label>
                                <select class="form-select" @bind="m_pickupLocationId" @bind:after="OnLocationChanged">
                                    <option value="0">@Localizer["AtShopFree"]</option>
                                    @foreach (var location in m_pickupLocations)
                                    {
                                        <option value="@location.ServiceLocationId">
                                            @location.Name
                                            @if (location.PickupFee > 0)
                                            {
                                                @($" (+{FormatCurrency(location.PickupFee)})")
                                            }
                                        </option>
                                    }
                                </select>
                                @if (m_pickupOutOfHoursBand != null)
                                {
                                    <small class="text-warning mt-1 d-block">
                                        <i class="ti ti-clock-exclamation me-1"></i>
                                        @m_pickupOutOfHoursBand.BandName: +@FormatCurrency(m_pickupOutOfHoursBand.Fee)
                                    </small>
                                }
                            </div>

                            @* Dropoff Location *@
                            <div class="col-12 mt-3">
                                <label class="form-label">@Localizer["DropoffLocationExpected"]</label>
                                <select class="form-select" @bind="m_dropoffLocationId" @bind:after="OnLocationChanged">
                                    <option value="0">@Localizer["AtShopFree"]</option>
                                    @foreach (var location in m_dropoffLocations)
                                    {
                                        <option value="@location.ServiceLocationId">
                                            @location.Name
                                            @if (location.DropoffFee > 0)
                                            {
                                                @($" (+{FormatCurrency(location.DropoffFee)})")
                                            }
                                        </option>
                                    }
                                </select>
                                @if (m_dropoffOutOfHoursBand != null)
                                {
                                    <small class="text-warning mt-1 d-block">
                                        <i class="ti ti-clock-exclamation me-1"></i>
                                        @m_dropoffOutOfHoursBand.BandName: +@FormatCurrency(m_dropoffOutOfHoursBand.Fee)
                                    </small>
                                }
                            </div>
                        </div>

                        @if (this.Config.LocationPricing?.HasAnyFees == true)
                        {
                            <div class="alert alert-info mt-3 mb-0 py-2">
                                <small>
                                    <i class="ti ti-info-circle me-1"></i>
                                    @Localizer["LocationTimingFees"]: <strong>@FormatCurrency(this.Config.LocationFeesTotal)</strong>
                                </small>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card" style="position: sticky; top: 20px;">
                <div class="card-body">
                    <h6 class="card-title mb-3">@Localizer["PriceSummary"]</h6>

                    @if (this.SelectedVehicle != null && m_selectedHours > 0)
                    {
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex justify-content-between">
                                <span>
                                    @Localizer["HourlyRental"] (@m_selectedHours @Localizer[m_selectedHours == 1 ? "HourSingular" : "Hours"])
                                </span>
                                <span>@FormatCurrency(this.Config.VehicleTotal)</span>
                            </div>

                            @if (m_selectedInsuranceId.HasValue)
                            {
                                var insurance = m_insurances.FirstOrDefault(i => i.InsuranceId == m_selectedInsuranceId);
                                if (insurance != null)
                                {
                                    <div class="d-flex justify-content-between">
                                        <span>@insurance.Name</span>
                                        <span>@FormatCurrency(this.Config.InsuranceTotal)</span>
                                    </div>
                                }
                            }

                            @foreach (var acc in m_accessorySelections.Where(a => !m_accessories.First(x => x.AccessoryId == a.AccessoryId).IsIncluded))
                            {
                                var accessory = m_accessories.First(a => a.AccessoryId == acc.AccessoryId);
                                <div class="d-flex justify-content-between">
                                    <span>@accessory.Name x@acc.Quantity</span>
                                    <span>@FormatCurrency(accessory.DailyRate * acc.Quantity)</span>
                                </div>
                            }

                            @if (this.Config.LocationPricing?.HasAnyFees == true)
                            {
                                @if (this.Config.LocationPricing.PickupLocationFee > 0)
                                {
                                    <div class="d-flex justify-content-between text-secondary">
                                        <span><i class="ti ti-map-pin me-1"></i>@this.Config.LocationPricing.PickupLocationName</span>
                                        <span>@FormatCurrency(this.Config.LocationPricing.PickupLocationFee)</span>
                                    </div>
                                }
                                @if (this.Config.LocationPricing.DropoffLocationFee > 0)
                                {
                                    <div class="d-flex justify-content-between text-secondary">
                                        <span><i class="ti ti-map-pin me-1"></i>@this.Config.LocationPricing.DropoffLocationName</span>
                                        <span>@FormatCurrency(this.Config.LocationPricing.DropoffLocationFee)</span>
                                    </div>
                                }
                                @if (this.Config.LocationPricing.IsOutOfHoursPickup)
                                {
                                    <div class="d-flex justify-content-between text-warning">
                                        <span><i class="ti ti-clock me-1"></i>@this.Config.LocationPricing.OutOfHoursPickupBand</span>
                                        <span>@FormatCurrency(this.Config.LocationPricing.OutOfHoursPickupFee)</span>
                                    </div>
                                }
                                @if (this.Config.LocationPricing.IsOutOfHoursDropoff)
                                {
                                    <div class="d-flex justify-content-between text-warning">
                                        <span><i class="ti ti-clock me-1"></i>@this.Config.LocationPricing.OutOfHoursDropoffBand</span>
                                        <span>@FormatCurrency(this.Config.LocationPricing.OutOfHoursDropoffFee)</span>
                                    </div>
                                }
                            }

                            <hr class="my-2">

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="font-size: 1.1rem;">@Localizer["Total"]</span>
                                <span class="text-primary fw-bold" style="font-size: 1.25rem;">
                                    @FormatCurrency(this.Config.TotalAmount)
                                </span>
                            </div>

                            <hr class="my-2">

                            <div class="d-flex justify-content-between">
                                <span class="text-secondary">@Localizer["RequiredDeposit"]</span>
                                <span class="fw-medium">@FormatCurrency(this.SelectedVehicle.DepositAmount)</span>
                            </div>

                            <div class="mt-2 text-secondary small">
                                <i class="ti ti-info-circle me-1"></i>
                                @FormatCurrency(this.m_adjustedHourlyRate) / @Localizer["HourSingular"]
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-secondary mb-0">@Localizer["SelectHoursHint"]</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Vehicle? SelectedVehicle { get; set; }
    [Parameter] public HourlyRentalConfig Config { get; set; } = new();
    [Parameter] public EventCallback<HourlyRentalConfig> ConfigChanged { get; set; }
    [Parameter] public bool IsPackageMode { get; set; }

    private int m_selectedHours = 1;
    private DateTime? m_startDate;
    private string m_startTimeString = "";
    private TimeSpan m_startTime = TimeSpan.Zero;
    private Dictionary<int, decimal> m_adjustedPrices = new();
    private decimal m_adjustedHourlyRate;
    private bool m_previousIsPackageMode;

    // Insurance & Accessories
    private List<Insurance> m_insurances = [];
    private List<Accessory> m_accessories = [];
    private List<AccessorySelectionModel> m_accessorySelections = [];
    private bool m_loadingInsurance;
    private bool m_loadingAccessories;
    private int? m_selectedInsuranceId;

    // Location
    private List<ServiceLocation> m_pickupLocations = [];
    private List<ServiceLocation> m_dropoffLocations = [];
    private int m_pickupLocationId;
    private int m_dropoffLocationId;
    private bool m_loadingLocations;
    private OutOfHoursResult? m_pickupOutOfHoursBand;
    private OutOfHoursResult? m_dropoffOutOfHoursBand;
    private Shop? m_shop;

    protected override async Task OnInitializedAsync()
    {
        this.m_startDate = DateTime.Today;
        this.m_startTime = new TimeSpan(DateTime.Now.Hour, 0, 0);
        this.m_startTimeString = this.m_startTime.ToString(@"hh\:mm");
        this.m_selectedHours = 1;
        this.m_previousIsPackageMode = this.IsPackageMode;

        await Task.WhenAll(
            this.LoadAdjustedPricesAsync(),
            this.LoadInsurancesAsync(),
            this.LoadAccessoriesAsync(),
            this.LoadLocationsAsync()
        );

        // Auto-select first package if starting in package mode
        if (this.IsPackageMode)
        {
            this.AutoSelectFirstPackage();
        }

        await this.UpdateConfigAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Detect when switching TO package mode
        if (this.IsPackageMode && !this.m_previousIsPackageMode)
        {
            this.AutoSelectFirstPackage();
            await this.UpdateConfigAsync();
        }
        // Detect when switching FROM package mode to hourly
        else if (!this.IsPackageMode && this.m_previousIsPackageMode)
        {
            this.m_selectedHours = 1;
            await this.UpdateConfigAsync();
        }

        this.m_previousIsPackageMode = this.IsPackageMode;
    }

    private void AutoSelectFirstPackage()
    {
        var firstPackage = (this.SelectedVehicle?.HourlyPackages ?? [])
            .OrderBy(p => p.Hours)
            .FirstOrDefault();

        if (firstPackage != null)
        {
            this.m_selectedHours = firstPackage.Hours;
        }
    }

    private async Task LoadAdjustedPricesAsync()
    {
        this.m_adjustedPrices.Clear();

        if (this.SelectedVehicle == null)
            return;

        var rentalDate = DateOnly.FromDateTime(this.m_startDate ?? DateTime.Today);
        var vehicleType = this.SelectedVehicle.VehicleType.ToString();

        // Calculate adjusted hourly rate
        var hourlyCalc = await this.DynamicPricingService.CalculateAdjustedRateAsync(
            this.SelectedVehicle.HourlyRate ?? 0, rentalDate, vehicleType);
        this.m_adjustedHourlyRate = hourlyCalc.AdjustedRate;

        // Calculate adjusted package prices (pass FleetModelId and PackageName for package-specific rules)
        foreach (var package in this.SelectedVehicle.HourlyPackages ?? [])
        {
            var calc = await this.DynamicPricingService.CalculateAdjustedRateAsync(
                package.Price,
                rentalDate,
                vehicleType,
                this.SelectedVehicle.VehicleId,
                this.SelectedVehicle.FleetModelId,
                package.Name);
            this.m_adjustedPrices[package.Hours] = calc.AdjustedRate;
        }
    }

    private async Task SelectHours(int hours)
    {
        this.m_selectedHours = hours;
        await this.UpdateConfigAsync();
    }

    private async Task OnDateChangedAsync()
    {
        await this.LoadAdjustedPricesAsync();
        await this.UpdateConfigAsync();
    }

    private async Task OnCustomHoursChanged(string? value)
    {
        if (int.TryParse(value, out var hours) && hours >= 1 && hours <= 24)
        {
            this.m_selectedHours = hours;
            await this.UpdateConfigAsync();
        }
    }

    private async Task OnTimeChanged(string? timeValue)
    {
        if (!string.IsNullOrEmpty(timeValue) && TimeSpan.TryParse(timeValue, out var time))
        {
            this.m_startTimeString = timeValue;
            this.m_startTime = time;
            await this.UpdateConfigAsync();
        }
    }

    private async Task UpdateConfigAsync()
    {
        if (this.m_startDate.HasValue && this.SelectedVehicle != null)
        {
            var startDateTime = this.m_startDate.Value.Date + this.m_startTime;
            var offset = TimeZoneInfo.Local.GetUtcOffset(startDateTime);
            this.Config.StartDateTime = new DateTimeOffset(startDateTime, offset);
            this.Config.Hours = this.m_selectedHours;
            this.Config.HourlyRate = this.m_adjustedHourlyRate;

            // Package price only applies in Package mode
            if (this.IsPackageMode)
            {
                var adjustedPrice = this.m_adjustedPrices.GetValueOrDefault(this.m_selectedHours);
                this.Config.PackagePrice = adjustedPrice > 0 ? adjustedPrice : null;
            }
            else
            {
                // Hourly mode: no package discount
                this.Config.PackagePrice = null;
            }
        }

        // Insurance (flat rate per rental)
        this.Config.SelectedInsuranceId = this.m_selectedInsuranceId;
        this.Config.SelectedInsurance = this.m_selectedInsuranceId.HasValue
            ? this.m_insurances.FirstOrDefault(i => i.InsuranceId == this.m_selectedInsuranceId)
            : null;
        this.Config.InsuranceTotal = this.Config.SelectedInsurance?.DailyRate ?? 0;

        // Accessories (flat rate per rental)
        this.Config.SelectedAccessories = this.m_accessorySelections
            .Select(s => new RentalConfig.AccessorySelection
            {
                Accessory = this.m_accessories.First(a => a.AccessoryId == s.AccessoryId),
                Quantity = s.Quantity
            }).ToList();
        this.Config.AccessoriesTotal = this.Config.SelectedAccessories
            .Where(a => !a.Accessory.IsIncluded)
            .Sum(a => a.Accessory.DailyRate * a.Quantity);

        // Calculate location and out-of-hours pricing
        await this.CalculateLocationPricingAsync();

        await this.ConfigChanged.InvokeAsync(this.Config);
    }

    private string GetEndTimeDisplay()
    {
        if (!this.m_startDate.HasValue || this.m_selectedHours <= 0)
            return "--:--";

        var startDateTime = this.m_startDate.Value.Date + this.m_startTime;
        var endDateTime = startDateTime.AddHours(this.m_selectedHours);

        // If crosses midnight, show date too
        if (endDateTime.Date != startDateTime.Date)
            return endDateTime.ToString("d MMM h:mm tt");

        return endDateTime.ToString("h:mm tt");
    }

    private async Task LoadInsurancesAsync()
    {
        this.m_loadingInsurance = true;
        try
        {
            this.m_insurances = await this.InsuranceService.GetActiveInsurancesAsync();
        }
        finally
        {
            this.m_loadingInsurance = false;
        }
    }

    private async Task LoadAccessoriesAsync()
    {
        this.m_loadingAccessories = true;
        try
        {
            var result = await this.AccessoryService.GetAccessoriesAsync(this.RequestContext.GetShopId());
            this.m_accessories = result.ItemCollection.Where(a => a.QuantityAvailable > 0).ToList();

            // Auto-select included accessories
            foreach (var accessory in this.m_accessories.Where(a => a.IsIncluded))
            {
                this.m_accessorySelections.Add(new AccessorySelectionModel
                {
                    AccessoryId = accessory.AccessoryId,
                    Quantity = 1
                });
            }
        }
        finally
        {
            this.m_loadingAccessories = false;
        }
    }

    private async Task SelectInsuranceAsync(int? insuranceId)
    {
        this.m_selectedInsuranceId = insuranceId;
        await this.UpdateConfigAsync();
    }

    private async Task ToggleAccessoryAsync(Accessory accessory, bool selected)
    {
        if (selected)
        {
            if (!this.m_accessorySelections.Any(a => a.AccessoryId == accessory.AccessoryId))
            {
                this.m_accessorySelections.Add(new AccessorySelectionModel
                {
                    AccessoryId = accessory.AccessoryId,
                    Quantity = 1
                });
            }
        }
        else
        {
            this.m_accessorySelections.RemoveAll(a => a.AccessoryId == accessory.AccessoryId);
        }
        await this.UpdateConfigAsync();
    }

    private void UpdateConfig() => _ = this.UpdateConfigAsync();

    private async Task LoadLocationsAsync()
    {
        this.m_loadingLocations = true;
        try
        {
            this.m_shop = await this.ShopService.GetShopByIdAsync(this.RequestContext.GetShopId());
            this.m_pickupLocations = await this.LocationService.GetActiveLocationsAsync(
                this.RequestContext.GetShopId(), pickupOnly: true, dropoffOnly: null);
            this.m_dropoffLocations = await this.LocationService.GetActiveLocationsAsync(
                this.RequestContext.GetShopId(), pickupOnly: null, dropoffOnly: true);
        }
        finally
        {
            this.m_loadingLocations = false;
        }
    }

    private async Task OnLocationChanged()
    {
        this.Config.PickupLocationId = this.m_pickupLocationId > 0 ? this.m_pickupLocationId : null;
        this.Config.PickupLocation = this.m_pickupLocations.FirstOrDefault(l => l.ServiceLocationId == this.m_pickupLocationId);
        this.Config.DropoffLocationId = this.m_dropoffLocationId > 0 ? this.m_dropoffLocationId : null;
        this.Config.DropoffLocation = this.m_dropoffLocations.FirstOrDefault(l => l.ServiceLocationId == this.m_dropoffLocationId);
        await this.UpdateConfigAsync();
    }

    private async Task CalculateLocationPricingAsync()
    {
        if (!this.m_startDate.HasValue) return;

        var startDateTime = this.m_startDate.Value.Date + this.m_startTime;
        var endDateTime = startDateTime.AddHours(this.m_selectedHours);

        var pickupDateTimeOffset = new DateTimeOffset(
            DateTime.SpecifyKind(startDateTime, DateTimeKind.Utc), TimeSpan.Zero);
        var dropoffDateTimeOffset = new DateTimeOffset(
            DateTime.SpecifyKind(endDateTime, DateTimeKind.Utc), TimeSpan.Zero);

        this.Config.LocationPricing = await this.PricingService.CalculateLocationPricingAsync(
            this.RequestContext.GetShopId(),
            pickupDateTimeOffset,
            dropoffDateTimeOffset,
            this.Config.PickupLocation,
            this.Config.DropoffLocation);

        await this.UpdateOutOfHoursBandsAsync();
    }

    private async Task UpdateOutOfHoursBandsAsync()
    {
        if (!this.m_startDate.HasValue) return;

        var startDateTime = this.m_startDate.Value.Date + this.m_startTime;
        var endDateTime = startDateTime.AddHours(this.m_selectedHours);

        var pickupDto = new DateTimeOffset(
            DateTime.SpecifyKind(startDateTime, DateTimeKind.Utc), TimeSpan.Zero);
        this.m_pickupOutOfHoursBand = await this.HoursService.GetOutOfHoursFeeAsync(
            this.RequestContext.GetShopId(), pickupDto);

        var dropoffDto = new DateTimeOffset(
            DateTime.SpecifyKind(endDateTime, DateTimeKind.Utc), TimeSpan.Zero);
        this.m_dropoffOutOfHoursBand = await this.HoursService.GetOutOfHoursFeeAsync(
            this.RequestContext.GetShopId(), dropoffDto);
    }

    private class AccessorySelectionModel
    {
        public int AccessoryId { get; set; }
        public int Quantity { get; set; } = 1;
    }
}
