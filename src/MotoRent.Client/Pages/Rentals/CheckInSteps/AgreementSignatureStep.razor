@inherits LocalizedComponentBase<CheckIn>
@using MotoRent.Domain.Entities
@using MotoRent.Client.Pages.Rentals
@using MotoRent.Domain.Models
@using MotoRent.Domain.Core
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IJSRuntime JS
@inject DocumentTemplateService TemplateService

<div class="d-flex flex-column gap-4">
    <div>
        <h5 class="mb-1 mr-text-primary" style="font-weight: 600;">
            <i class="ti ti-file-check me-2" style="color: var(--mr-accent-primary);"></i>
            @Localizer["AgreementSignature"]
        </h5>
        <p class="mr-text-muted mb-0">@Localizer["AgreementSignatureDesc"]</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-md-6">
            <div class="mr-form-panel">
                <div class="mr-form-panel-header">
                    <div class="mr-form-panel-header-icon">
                        <i class="ti ti-file-description"></i>
                    </div>
                    <h3 class="mr-form-panel-title">@Localizer["RentalSummary"]</h3>
                </div>
                <div class="mr-form-panel-body">

                    @if (this.Renter != null && this.Vehicle != null)
                    {
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">@Localizer["Renter"]</small>
                                <span class="fw-medium">@this.Renter.FullName</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">@Localizer["Phone"]</small>
                                <span>@this.Renter.Phone</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">@Localizer["PassportID"]</small>
                                <span>@(this.Renter.PassportNo ?? this.Renter.NationalIdNo ?? "-")</span>
                            </div>

                            <hr class="my-2">

                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">@GetVehicleTypeLabel(this.Vehicle.VehicleType)</small>
                                <span class="fw-medium">@this.Vehicle.Brand @this.Vehicle.Model</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">@Localizer["LicensePlate"]</small>
                                <span>@this.Vehicle.LicensePlate</span>
                            </div>
                            @if (this.Vehicle.Mileage.HasValue && this.Vehicle.Mileage > 0)
                            {
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["CurrentMileage"]</small>
                                    <span>@this.Vehicle.Mileage.Value.ToString("N0") km</span>
                                </div>
                            }

                            <hr class="my-2">

                            @if (this.IsIntervalRental && this.IntervalConfig != null)
                            {
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["Duration"]</small>
                                    <span>@GetIntervalLabel(this.IntervalConfig.IntervalMinutes)</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["StartTime"]</small>
                                    <span>@this.IntervalConfig.StartDateTime.DateTime.ToString("HH:mm")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["Rate"]</small>
                                    <span>@FormatCurrency(this.IntervalConfig.RentalRate)</span>
                                </div>
                            }
                            else if (this.Config != null)
                            {
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["RentalPeriod"]</small>
                                    <span>
                                        @FormatDate(this.Config.StartDate) - @FormatDate(this.Config.EndDate) (@this.Config.Days @Localizer["Days"])
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["DailyRate"]</small>
                                    <span>@FormatCurrency(this.Vehicle.DailyRate)</span>
                                </div>

                                @if (this.Config.IncludeDriver)
                                {
                                    <div class="d-flex justify-content-between">
                                        <small class="text-secondary">@Localizer["Driver"]</small>
                                        <span>@FormatCurrency(this.Config.DriverTotal)</span>
                                    </div>
                                }

                                @if (this.Config.IncludeGuide)
                                {
                                    <div class="d-flex justify-content-between">
                                        <small class="text-secondary">@Localizer["TourGuideDesc"]</small>
                                        <span>@FormatCurrency(this.Config.GuideTotal)</span>
                                    </div>
                                }

                                @if (this.Config.SelectedInsurance != null)
                                {
                                    <div class="d-flex justify-content-between">
                                        <small class="text-secondary">@Localizer["Insurance"]</small>
                                        <span>@this.Config.SelectedInsurance.Name</span>
                                    </div>
                                }

                                @if (this.Config.SelectedAccessories.Count > 0)
                                {
                                    <div class="d-flex justify-content-between">
                                        <small class="text-secondary">@Localizer["Accessories"]</small>
                                        <span>
                                            @string.Join(", ", this.Config.SelectedAccessories.Select(a => a.Accessory.Name))
                                        </span>
                                    </div>
                                }
                            }

                            <hr class="my-2">

                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">@Localizer["Deposit"]</small>
                                <span>
                                    @Localizer[this.DepositInfo?.DepositType ?? ""] - @FormatCurrency(this.DepositInfo?.Amount ?? 0)
                                </span>
                            </div>

                            <hr class="my-2">

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold" style="font-size: 1.1rem;">@Localizer["TotalAmount"]</span>
                                <span class="text-primary fw-bold" style="font-size: 1.5rem;">
                                    @FormatCurrency(GetTotalAmount())
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title mb-3">@Localizer["PrintAgreement"]</h6>

                    <p class="text-secondary mb-3">
                        @Localizer["PrintAgreementDesc"]
                    </p>

                    @if (m_templates.Count > 1)
                    {
                        <div class="dropdown w-100">
                            <div class="btn-group w-100">
                                <button type="button" class="btn btn-outline-primary btn-lg w-100" @onclick="() => PrintAgreement()">
                                    <i class="ti ti-printer me-2"></i>
                                    @Localizer["PrintAgreement"]
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-lg dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="visually-hidden">Toggle Dropdown</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li class="dropdown-header">Select Template</li>
                                    @foreach (var template in m_templates)
                                    {
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2" href="#" @onclick="@(() => PrintAgreement(template.DocumentTemplateId))" @onclick:preventDefault>
                                                <i class="ti ti-file-description text-secondary"></i>
                                                <span>@template.Name</span>
                                                @if (template.IsDefault)
                                                {
                                                    <span class="badge bg-blue-lt ms-auto">Default</span>
                                                }
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-primary btn-lg w-100" @onclick="() => PrintAgreement()">
                            <i class="ti ti-printer me-2"></i>
                            @Localizer["PrintAgreement"]
                        </button>
                    }

                    @if (AgreementPrinted)
                    {
                        <div class="alert alert-success d-flex align-items-center gap-2 mt-3 py-2">
                            <i class="ti ti-check"></i>
                            <span>@Localizer["AgreementPrinted"]</span>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info d-flex align-items-center gap-2 mt-3 py-2">
                            <i class="ti ti-info-circle"></i>
                            <span>@Localizer["PrintAgreementHint"]</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-body">
                    <h6 class="card-title mb-3">@Localizer["TermsConditions"]</h6>

                    @* Upload Signed Agreement Section *@
                    @if (string.IsNullOrEmpty(ScannedAgreementPath))
                    {
                        <label class="btn btn-outline-secondary w-100 @(m_isUploading ? "disabled" : "")" style="padding: 1rem;">
                            @if (m_isUploading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>@Localizer["Uploading"]</span>
                            }
                            else
                            {
                                <i class="ti ti-camera me-2"></i>
                                <span>@Localizer["UploadSignedAgreement"]</span>
                            }
                            <InputFile OnChange="OnAgreementFileSelected" accept="image/*,.pdf" capture="environment" class="d-none" disabled="@m_isUploading" />
                        </label>
                        <p class="text-secondary small mt-2 mb-0 text-center">@Localizer["UploadSignedAgreementHint"]</p>
                    }
                    else
                    {
                        <div class="alert alert-success d-flex align-items-center justify-content-between py-2 mb-0">
                            <div class="d-flex align-items-center gap-2">
                                <i class="ti ti-check"></i>
                                <span>@Localizer["ScannedAgreementUploaded"]</span>
                            </div>
                            <div class="dropdown">
                                <button type="button" class="btn btn-ghost-secondary btn-icon btn-sm" data-bs-toggle="dropdown">
                                    <i class="ti ti-dots-vertical"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end">
                                    <button type="button" class="dropdown-item" @onclick="ViewScannedAgreement">
                                        <i class="ti ti-external-link me-2"></i>@Localizer["ViewScannedAgreement"]
                                    </button>
                                    <button type="button" class="dropdown-item text-danger" @onclick="RemoveScannedAgreement">
                                        <i class="ti ti-trash me-2"></i>@CommonLocalizer["Delete"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <label class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" checked="@TermsAccepted" @onchange="OnTermsChanged" />
                        <span class="form-check-label">@Localizer["ExplainTermsConfirm"]</span>
                    </label>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Renter? Renter { get; set; }
    [Parameter] public Vehicle? Vehicle { get; set; }
    [Parameter] public bool IsIntervalRental { get; set; }
    [Parameter] public bool IsHourlyRental { get; set; }
    [Parameter] public IntervalRentalConfig? IntervalConfig { get; set; }
    [Parameter] public HourlyRentalConfig? HourlyConfig { get; set; }
    [Parameter] public RentalConfig? Config { get; set; }
    [Parameter] public DepositInfo? DepositInfo { get; set; }
    [Parameter] public EventCallback OnComplete { get; set; }
    [Parameter] public string? ScannedAgreementPath { get; set; }
    [Parameter] public EventCallback<string?> ScannedAgreementPathChanged { get; set; }
    [Parameter] public bool TermsAccepted { get; set; }
    [Parameter] public EventCallback<bool> TermsAcceptedChanged { get; set; }
    [Parameter] public bool AgreementPrinted { get; set; }
    [Parameter] public EventCallback<bool> AgreementPrintedChanged { get; set; }

    private string m_agreementText = string.Empty;
    private List<DocumentTemplate> m_templates = new();
    private bool m_isUploading;

    protected override async Task OnInitializedAsync()
    {
        m_agreementText = GetAgreementText();
        
        // Load approved agreement templates
        var result = await TemplateService.GetTemplatesAsync(DocumentType.RentalAgreement);
        m_templates = result.ItemCollection.Where(t => t.Status == DocumentTemplateStatus.Approved).ToList();
    }

    private string GetAgreementText()
    {
        return Localizer["AgreementTextTemplate"].Value;
    }

    private decimal GetTotalAmount()
    {
        if (IsIntervalRental && IntervalConfig != null)
            return IntervalConfig.RentalRate + (DepositInfo?.Amount ?? 0);

        if (IsHourlyRental && HourlyConfig != null)
            return HourlyConfig.TotalAmount + (DepositInfo?.Amount ?? 0);

        if (Config != null)
        {
            return Config.VehicleTotal + Config.InsuranceTotal + Config.AccessoriesTotal
                   + Config.DriverTotal + Config.GuideTotal + (DepositInfo?.Amount ?? 0);
        }

        return DepositInfo?.Amount ?? 0;
    }

    private async Task PrintAgreement(int? templateId = null)
    {
        var url = BuildPrintAgreementUrl(templateId);
        await JS.InvokeVoidAsync("window.open", url, "_blank");
        await AgreementPrintedChanged.InvokeAsync(true);
    }

    private async Task OnTermsChanged(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        await TermsAcceptedChanged.InvokeAsync(isChecked);
    }

    private string BuildPrintAgreementUrl(int? templateId = null)
    {
        var queryParams = new List<string>();

        if (Renter != null)
        {
            queryParams.Add($"RenterId={Renter.RenterId}");
            // Pass renter data directly for unsaved renters
            if (Renter.RenterId == 0)
            {
                queryParams.Add($"RenterName={Uri.EscapeDataString(Renter.FullName ?? "")}");
                queryParams.Add($"RenterPhone={Uri.EscapeDataString(Renter.Phone ?? "")}");
                queryParams.Add($"RenterPassport={Uri.EscapeDataString(Renter.PassportNo ?? Renter.NationalIdNo ?? "")}");
                queryParams.Add($"RenterNationality={Uri.EscapeDataString(Renter.Nationality ?? "")}");
            }
        }

        if (Vehicle != null)
        {
            queryParams.Add($"VehicleId={Vehicle.VehicleId}");
            // Pass vehicle data directly for fallback
            if (Vehicle.VehicleId == 0)
            {
                queryParams.Add($"VehicleBrand={Uri.EscapeDataString(Vehicle.Brand ?? "")}");
                queryParams.Add($"VehicleModel={Uri.EscapeDataString(Vehicle.Model ?? "")}");
                queryParams.Add($"VehiclePlate={Uri.EscapeDataString(Vehicle.LicensePlate ?? "")}");
                queryParams.Add($"VehicleColor={Uri.EscapeDataString(Vehicle.Color ?? "")}");
            }
        }

        if (templateId.HasValue)
            queryParams.Add($"TemplateId={templateId.Value}");

        if (IsIntervalRental && IntervalConfig != null)
        {
            queryParams.Add($"Interval={IntervalConfig.IntervalMinutes}");
            queryParams.Add($"StartTime={Uri.EscapeDataString(IntervalConfig.StartDateTime.ToString("o"))}");
            queryParams.Add($"Rate={IntervalConfig.RentalRate}");
            queryParams.Add($"Total={GetTotalAmount()}");
        }
        else if (IsHourlyRental && HourlyConfig != null)
        {
            queryParams.Add($"RentalType=Hourly");
            queryParams.Add($"Hours={HourlyConfig.Hours}");
            queryParams.Add($"HourlyRate={HourlyConfig.VehicleTotal}");
            queryParams.Add($"StartTime={Uri.EscapeDataString(HourlyConfig.StartDateTime.ToString("o"))}");
            queryParams.Add($"Total={GetTotalAmount()}");
            if (HourlyConfig.IsPackagePrice)
            {
                queryParams.Add("IsPackage=true");
            }
        }
        else if (Config != null)
        {
            queryParams.Add($"StartDate={Uri.EscapeDataString(Config.StartDate.ToString("yyyy-MM-dd"))}");
            queryParams.Add($"EndDate={Uri.EscapeDataString(Config.EndDate.ToString("yyyy-MM-dd"))}");
            queryParams.Add($"Days={Config.Days}");
            queryParams.Add($"Total={GetTotalAmount()}");
        }

        if (DepositInfo != null)
        {
            queryParams.Add($"DepositType={Uri.EscapeDataString(DepositInfo.DepositType)}");
            queryParams.Add($"DepositAmount={DepositInfo.Amount}");
        }

        return $"/rentals/print-agreement?{string.Join("&", queryParams)}";
    }

    private string GetVehicleTypeLabel(VehicleType type) => type switch
    {
        VehicleType.Motorbike => Localizer["Motorbike"],
        VehicleType.Car => Localizer["Car"],
        VehicleType.JetSki => Localizer["JetSki"],
        VehicleType.Boat => Localizer["Boat"],
        VehicleType.Van => Localizer["Van"],
        _ => Localizer["Vehicle"]
    };

    private string GetIntervalLabel(int minutes) => minutes switch
    {
        15 => Localizer["15Min"],
        30 => Localizer["30Min"],
        60 => Localizer["1Hour"],
        _ => $"{minutes} {Localizer["Minutes"]}"
    };

    private async Task OnAgreementFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Validate file size (max 10MB)
        const long maxSize = 10 * 1024 * 1024;
        if (file.Size > maxSize)
        {
            this.ShowWarning(Localizer["FileTooLarge"]);
            return;
        }

        // Validate file type
        var allowedTypes = new[] { "image/jpeg", "image/png", "image/gif", "image/webp", "application/pdf" };
        if (!allowedTypes.Contains(file.ContentType.ToLower()))
        {
            this.ShowWarning(Localizer["InvalidFileType"]);
            return;
        }

        m_isUploading = true;
        StateHasChanged();

        try
        {
            // Read file into memory
            using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            // Get file extension
            var extension = Path.GetExtension(file.Name).ToLowerInvariant();
            if (string.IsNullOrEmpty(extension))
            {
                extension = file.ContentType switch
                {
                    "image/jpeg" => ".webp",
                    "image/png" => ".webp",
                    "image/gif" => ".gif",
                    "image/webp" => ".webp",
                    "application/pdf" => ".pdf",
                    _ => ".webp"
                };
            }

            // Save file to disk
            var basePath = MotoConfig.FileStorageBasePath;
            var accountNo = this.RequestContext.GetAccountNo() ?? "default";
            var uploadDir = Path.Combine(Directory.GetCurrentDirectory(), basePath, accountNo, "agreements");
            Directory.CreateDirectory(uploadDir);

            var timestamp = DateTimeOffset.UtcNow.ToString("yyyyMMdd-HHmmss");
            var fileName = $"{timestamp}_{Guid.NewGuid()}{extension}";
            var filePath = Path.Combine(uploadDir, fileName);
            await File.WriteAllBytesAsync(filePath, fileBytes);

            // Calculate relative path for storage
            var uploadsDir = Path.Combine(Directory.GetCurrentDirectory(), basePath);
            var relativePath = filePath.StartsWith(uploadsDir)
                ? filePath[uploadsDir.Length..].TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)
                : filePath;

            ScannedAgreementPath = relativePath;
            await ScannedAgreementPathChanged.InvokeAsync(ScannedAgreementPath);
            await AgreementPrintedChanged.InvokeAsync(true); // Uploading signed copy counts as having agreement
            this.ShowSuccess(Localizer["UploadSuccess"]);
        }
        catch (Exception ex)
        {
            this.ShowError($"{Localizer["UploadFailed"]}: {ex.Message}");
        }
        finally
        {
            m_isUploading = false;
            StateHasChanged();
        }
    }

    private async Task ViewScannedAgreement()
    {
        if (!string.IsNullOrEmpty(ScannedAgreementPath))
        {
            var url = $"/api/agreements/file/{ScannedAgreementPath}";
            await JS.InvokeVoidAsync("window.open", url, "_blank");
        }
    }

    private async Task RemoveScannedAgreement()
    {
        ScannedAgreementPath = null;
        await ScannedAgreementPathChanged.InvokeAsync(null);
        // Only reset m_agreementPrinted if user didn't print before
        // Keep it true if they printed
    }
}