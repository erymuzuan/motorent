@inherits LocalizedComponentBase<CheckIn>
@using MotoRent.Domain.Entities
@using MotoRent.Domain.Models
@using MotoRent.Domain.Storage
@using MotoRent.Services
@inject VehicleService VehicleService
@inject VehicleImageService VehicleImageService
@inject IBinaryStore BinaryStore

<div class="d-flex flex-column gap-4">
    <div>
        <h5 class="mb-1 mr-text-primary" style="font-weight: 600;">
            <i class="ti ti-car me-2" style="color: var(--mr-accent-primary);"></i>
            @Localizer["SelectVehicle"]
        </h5>
        <p class="mr-text-muted mb-0">@Localizer["SelectVehicleDesc"]</p>
    </div>

    @if (m_loading)
    {
        <div class="progress progress-sm" style="background: var(--mr-border-light);">
            <div class="progress-bar progress-bar-indeterminate" style="background: var(--mr-accent-gradient);"></div>
        </div>
    }

    @if (m_selectedFleetModel == null)
    {
        @* Phase 1: FleetModel Selection *@
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <div class="mr-search-box" style="min-width: 250px;">
                <i class="ti ti-search"></i>
                <input type="text" placeholder="@Localizer["SearchRenterPlaceholder"]"
                       @bind="m_searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
            </div>

            <div class="form-check form-switch ms-2">
                <input class="form-check-input" type="checkbox" id="includePooled"
                       @bind="m_includePooled" @bind:after="LoadVehicles"
                       style="background-color: var(--mr-accent-primary);">
                <label class="form-check-label mr-text-secondary" for="includePooled">@Localizer["IncludePooled"]</label>
            </div>

            <div class="ms-auto">
                <span class="mr-status-badge success">
                    <i class="ti ti-check"></i>
                    @m_filteredGroups.Count @Localizer["ModelsAvailable"]
                </span>
            </div>
        </div>

        <div class="row g-3">
            @foreach (var group in m_filteredGroups)
            {
                <div class="col-12 col-sm-6 col-md-4">
                    <div class="mr-card h-100" style="cursor: pointer;" @onclick="@(() => SelectFleetModel(group))">
                        @if (!string.IsNullOrEmpty(group.ImagePath))
                        {
                            <div style="aspect-ratio: 16/10; overflow: hidden; border-radius: 8px 8px 0 0;">
                                <img src="@group.ImagePath" alt="@group.DisplayName"
                                     style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                        }
                        else
                        {
                            <div style="aspect-ratio: 16/10; overflow: hidden; border-radius: 8px 8px 0 0; background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%); display: flex; align-items: center; justify-content: center;">
                                <i class="ti @GetVehicleTypeIcon(group.VehicleType)" style="font-size: 3rem; color: var(--mr-accent-primary); opacity: 0.6;"></i>
                            </div>
                        }
                        <div class="p-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="mr-text-primary" style="font-weight: 600;">@group.DisplayName</div>
                                    @if (!string.IsNullOrEmpty(group.EngineDisplay))
                                    {
                                        <span class="text-muted small">@group.EngineDisplay</span>
                                    }
                                </div>
                                <span class="mr-status-badge success" style="font-size: 0.75rem;">
                                    @group.AvailableUnits @Localizer["Available"]
                                </span>
                            </div>
                            @if (group.AvailableColors.Count > 0)
                            {
                                <div class="mt-2">
                                    @foreach (var color in group.AvailableColors)
                                    {
                                        <span class="badge bg-secondary me-1" style="font-size: 0.7rem;">@color</span>
                                    }
                                </div>
                            }
                            <div class="mt-2">
                                @if (group.HasPriceRange)
                                {
                                    <span class="text-primary fw-bold">@FormatCurrency(group.MinDailyRate)-@FormatCurrency(group.MaxDailyRate)</span>
                                }
                                else
                                {
                                    <span class="text-primary fw-bold">@FormatCurrency(group.MinDailyRate)</span>
                                }
                                <span class="text-muted">/@(group.IsHourlyOnly ? "hr" : "day")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (m_filteredGroups.Count == 0 && !m_loading)
        {
            <div class="mr-info-panel">
                <div class="mr-info-panel-icon">
                    <i class="ti ti-info-circle"></i>
                </div>
                <div>
                    <div class="mr-info-panel-title">@Localizer["NoVehiclesFound"]</div>
                    @if (!m_includePooled)
                    {
                        <div class="mr-info-panel-desc">@Localizer["IncludePooledHint"]</div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        @* Phase 2: Individual Vehicle Selection within FleetModel *@
        <div class="d-flex align-items-center gap-3">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="BackToModelList">
                <i class="ti ti-arrow-left me-1"></i>
                @Localizer["Back"]
            </button>
            <h6 class="mb-0 mr-text-primary">@m_selectedFleetModel.DisplayName</h6>
            <span class="mr-status-badge success" style="font-size: 0.75rem;">
                @m_selectedFleetModel.AvailableUnits @Localizer["Available"]
            </span>
        </div>

        <div class="row g-3">
            @foreach (var availability in m_filteredVehicles)
            {
                var vehicle = availability.Vehicle;
                var isSelected = this.SelectedVehicle?.VehicleId == vehicle.VehicleId;
                <div class="col-12 col-sm-6 col-md-4">
                    <div class="mr-card h-100"
                         style="cursor: pointer; @(isSelected ? "border: 2px solid var(--mr-accent-primary); background: var(--mr-accent-bg);" : "")"
                         @onclick="@(() => SelectVehicleItem(vehicle))">
                        @{
                            var vehicleImageUrl = GetVehicleImage(vehicle);
                        }
                        <div style="aspect-ratio: 1; overflow: hidden; border-radius: 8px 8px 0 0; background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%); display: flex; align-items: center; justify-content: center;">
                            @if (!string.IsNullOrEmpty(vehicleImageUrl))
                            {
                                <img src="@vehicleImageUrl" alt="@vehicle.Brand @vehicle.Model"
                                     style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="ti @GetVehicleTypeIcon(vehicle.VehicleType)" style="font-size: 3rem; color: var(--mr-accent-primary); opacity: 0.6;"></i>
                            }
                        </div>
                        <div class="p-3" style="border-bottom: 1px solid var(--mr-border-light);">
                            <div class="d-flex align-items-center gap-2">
                                <div class="flex-grow-1">
                                    <div class="mr-text-primary" style="font-weight: 600;">@vehicle.Brand @vehicle.Model</div>
                                    <div class="d-flex align-items-center gap-1">
                                        <span class="mr-mono" style="color: var(--mr-accent-primary); font-size: 0.85rem;">@vehicle.LicensePlate</span>
                                        @if (availability.IsPooled)
                                        {
                                            <span class="mr-status-badge info" style="font-size: 0.65rem; padding: 2px 6px;">
                                                <i class="ti ti-share"></i> Pooled
                                            </span>
                                        }
                                    </div>
                                </div>
                                @if (isSelected)
                                {
                                    <i class="ti ti-circle-check" style="font-size: 1.5rem; color: var(--mr-accent-primary);"></i>
                                }
                            </div>
                        </div>
                        <div class="p-3">
                            <div class="d-flex flex-column gap-1">
                                @if (!string.IsNullOrEmpty(vehicle.Color))
                                {
                                    <div class="d-flex justify-content-between">
                                        <small class="text-secondary">@Localizer["Color"]</small>
                                        <span>@vehicle.Color</span>
                                    </div>
                                }
                                @if (vehicle.Year > 0)
                                {
                                    <div class="d-flex justify-content-between">
                                        <small class="text-secondary">@Localizer["Year"]</small>
                                        <span>@vehicle.Year</span>
                                    </div>
                                }

                                <hr class="my-2">

                                @if (vehicle.UsesIntervalPricing)
                                {
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-medium">@Localizer["HourlyRate"]</span>
                                        <span class="text-primary fw-semibold" style="font-size: 1.1rem;">
                                            @FormatCurrency(vehicle.Rate1Hour ?? 0)/hr
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-medium">@(vehicle.IsHourlyOnly ? Localizer["HourlyRate"] : Localizer["DailyRate"])</span>
                                        <span class="text-primary fw-semibold" style="font-size: 1.1rem;">
                                            @FormatCurrency(vehicle.DisplayRate)
                                        </span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between">
                                    <small class="text-secondary">@Localizer["Deposit"]</small>
                                    <span>@FormatCurrency(vehicle.DepositAmount)</span>
                                </div>

                                @if (availability.IsPooled && !availability.IsAtCurrentShop)
                                {
                                    <div class="mr-info-panel py-2 px-3 mt-2" style="background: var(--mr-warning-bg); border-color: var(--mr-warning-border); font-size: 0.75rem;">
                                        <i class="ti ti-map-pin me-1" style="color: var(--mr-warning-text);"></i>
                                        <span style="color: var(--mr-warning-text);">@Localizer["AtAnotherShop"]</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (m_filteredVehicles.Count == 0 && !m_loading)
        {
            <div class="mr-info-panel">
                <div class="mr-info-panel-icon">
                    <i class="ti ti-info-circle"></i>
                </div>
                <div>
                    <div class="mr-info-panel-title">@Localizer["NoVehiclesFound"]</div>
                </div>
            </div>
        }
    }

    @if (this.SelectedVehicle != null)
    {
        <div class="mr-info-panel mt-4" style="background: var(--mr-success-bg); border-color: var(--mr-success-border);">
            <div class="mr-info-panel-icon success">
                <i class="ti @GetVehicleTypeIcon(this.SelectedVehicle.VehicleType)"></i>
            </div>
            <div>
                <div class="mr-info-panel-title" style="color: var(--mr-success-text);">
                    @Localizer["Selected"]: <strong>@this.SelectedVehicle.Brand @this.SelectedVehicle.Model</strong>
                </div>
                <div class="mr-info-panel-desc">
                    @this.SelectedVehicle.LicensePlate -
                    @if (this.SelectedVehicle.UsesIntervalPricing)
                    {
                        @FormatCurrency(this.SelectedVehicle.Rate1Hour ?? 0)<text>/hr</text>
                    }
                    else if (this.SelectedVehicle.IsHourlyOnly)
                    {
                        @FormatCurrency(this.SelectedVehicle.HourlyRate!.Value)<text>/hr</text>
                    }
                    else
                    {
                        @FormatCurrency(this.SelectedVehicle.DailyRate)<text>/day</text>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Vehicle? SelectedVehicle { get; set; }
    [Parameter] public EventCallback<Vehicle?> SelectedVehicleChanged { get; set; }

    private List<VehicleAvailability> m_allVehicles = [];
    private List<VehicleAvailability> m_filteredVehicles = [];
    private List<VehicleGroup> m_allGroups = [];
    private List<VehicleGroup> m_filteredGroups = [];
    private VehicleGroup? m_selectedFleetModel;
    private Dictionary<int, string> m_vehiclePrimaryImages = new();
    private bool m_loading;
    private string? m_searchTerm;
    private bool m_includePooled = true;

    protected override async Task OnInitializedAsync()
    {
        await this.LoadVehicles();
    }

    private async Task LoadVehicles()
    {
        this.m_loading = true;
        try
        {
            this.m_allVehicles = await this.VehicleService.GetAvailableVehiclesForShopAsync(
                this.RequestContext.GetShopId(),
                vehicleType: null,
                includePooledVehicles: m_includePooled);

            // Build fleet model groups from loaded vehicles
            this.m_allGroups = this.m_allVehicles
                .Where(v => v.Vehicle.FleetModelId > 0)
                .GroupBy(v => v.Vehicle.FleetModelId)
                .Select(g => VehicleGroup.FromVehicles(g.Select(a => a.Vehicle)))
                .OrderBy(g => g.VehicleType)
                .ThenBy(g => g.Brand)
                .ThenBy(g => g.Model)
                .ToList();

            // Load primary images for all vehicles
            this.m_vehiclePrimaryImages.Clear();
            foreach (var availability in this.m_allVehicles)
            {
                var primaryImage = await this.VehicleImageService.GetPrimaryImageAsync(availability.Vehicle.VehicleId);
                if (primaryImage != null && !string.IsNullOrEmpty(primaryImage.StoreId))
                {
                    this.m_vehiclePrimaryImages[availability.Vehicle.VehicleId] = this.BinaryStore.GetImageUrl(primaryImage.StoreId);
                }
            }

            this.ApplyFilters();
        }
        finally
        {
            this.m_loading = false;
        }
    }

    private void OnSearchChanged()
    {
        this.ApplyFilters();
    }

    private void ApplyFilters()
    {
        if (this.m_selectedFleetModel == null)
        {
            // Phase 1: Filter groups
            var filtered = this.m_allGroups.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(this.m_searchTerm))
            {
                var term = this.m_searchTerm.ToLowerInvariant();
                filtered = filtered.Where(g =>
                    g.Brand.ToLowerInvariant().Contains(term) ||
                    g.Model.ToLowerInvariant().Contains(term) ||
                    g.DisplayName.ToLowerInvariant().Contains(term));
            }

            this.m_filteredGroups = filtered.ToList();
        }
        else
        {
            // Phase 2: Filter vehicles within selected model
            this.m_filteredVehicles = this.m_allVehicles
                .Where(v => v.Vehicle.FleetModelId == this.m_selectedFleetModel.FleetModelId)
                .OrderBy(v => !v.IsAtCurrentShop)
                .ThenBy(v => v.Vehicle.LicensePlate)
                .ToList();
        }
    }

    private void SelectFleetModel(VehicleGroup group)
    {
        this.m_selectedFleetModel = group;
        this.ApplyFilters();
    }

    private void BackToModelList()
    {
        this.m_selectedFleetModel = null;
        this.ApplyFilters();
    }

    private async Task SelectVehicleItem(Vehicle vehicle)
    {
        this.SelectedVehicle = vehicle;
        await this.SelectedVehicleChanged.InvokeAsync(vehicle);
    }

    private string GetVehicleImage(Vehicle vehicle)
    {
        if (this.m_vehiclePrimaryImages.TryGetValue(vehicle.VehicleId, out var imageUrl))
            return imageUrl;

        if (!string.IsNullOrEmpty(vehicle.ImagePath))
            return vehicle.ImagePath;

        return string.Empty;
    }

    private static string GetVehicleTypeIcon(VehicleType type) => type switch
    {
        VehicleType.Motorbike => "ti-motorbike",
        VehicleType.Car => "ti-car",
        VehicleType.JetSki => "ti-sailboat",
        VehicleType.Boat => "ti-ship",
        VehicleType.Van => "ti-bus",
        _ => "ti-car"
    };
}
