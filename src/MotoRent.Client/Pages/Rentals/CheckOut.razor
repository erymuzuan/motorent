                    @Localizer["3DInspection"]
                </button>
            </div>
        </div>

        @if (m_use3DInspection)
        {
            @* 3D Vehicle Inspection Mode *@
            <div class="inspection-3d-container">
                <div class="row">
                    <div class="col-lg-8">
                        <VehicleInspector @ref="m_vehicleInspector"
                                          ModelPath="@GetVehicleModelPath()"
                                          Height="350"
                                          Markers="@m_inspectionMarkers"
                                          MarkersChanged="OnInspectionMarkersChanged"
                                          OnMarkerAdded="OnMarkerAdded"
                                          OnMarkerSelected="OnMarkerSelected"
                                          ShowMarkersList="false" />
                    </div>
                    <div class="col-lg-4">
                        <MarkerDetailPanel Marker="@m_selectedMarker"
                                           MarkerChanged="OnMarkerUpdated"
                                           ShowPhotos="true"
                                           OnAddPhoto="OnAddMarkerPhoto" />

                        @if (m_inspectionMarkers.Count > 0)
                        {
                            <div class="card mt-3">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        @Localizer["DamageMarkers"] (@m_inspectionMarkers.Count)
                                    </h5>
                                </div>
                                <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                                    @for (int i = 0; i < m_inspectionMarkers.Count; i++)
                                    {
                                        var idx = i;
                                        var marker = m_inspectionMarkers[i];
                                        <button type="button"
                                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(m_selectedMarker?.MarkerId == marker.MarkerId ? "active" : "")"
                                                @onclick="@(() => SelectMarkerByIndex(idx))">
                                            <span>
                                                <span class="badge bg-secondary rounded-pill me-1">@(idx + 1)</span>
                                                @marker.DamageType
                                            </span>
                                            <span class="badge @GetSeverityBadgeClass(marker.Severity)">
                                                @marker.Severity
                                            </span>
                                        </button>
                                    }
                                </div>
                                <div class="card-footer">
                                    <div class="d-flex justify-content-between small">
                                        <span>@Localizer["EstimatedTotal"]:</span>
                                        <strong class="text-danger">
                                            @FormatCurrency(m_inspectionMarkers.Sum(m => m.EstimatedCost ?? 0))
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (m_preRentalInspection != null)
                {
                    <div class="alert alert-info mt-3">
                        <i class="ti ti-info-circle me-1"></i>
                        @Localizer["PreRentalInspectionFound", m_preRentalInspection.Markers.Count]
                        @if (m_preRentalInspection.Markers.Count > 0)
                        {
                            <span class="ms-2">
                                @Localizer["PreExistingDamageMarked"]
                            </span>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            @* Standard Inspection Mode *@
            <div class="damage-options">
                <div class="damage-option @(m_damageLevel == "None" ? "selected" : "") damage-none"
                     @onclick="@(() => m_damageLevel = "None")">
                    <div class="damage-icon">
                        <i class="ti ti-circle-check"></i>
                    </div>
                    <div class="damage-text">
                        <span class="damage-title">@Localizer["NoDamage"]</span>
                        <span class="damage-desc">@Localizer["GoodCondition"]</span>
                    </div>
                    <div class="damage-check">
                        @if (m_damageLevel == "None")
                        {
                            <i class="ti ti-check"></i>
                        }
                    </div>
                </div>

                <div class="damage-option @(m_damageLevel == "Minor" ? "selected" : "") damage-minor"
                     @onclick="@(() => m_damageLevel = "Minor")">
                    <div class="damage-icon">
                        <i class="ti ti-info-circle"></i>
                    </div>
                    <div class="damage-text">
                        <span class="damage-title">@Localizer["Minor"]</span>
                        <span class="damage-desc">@Localizer["ScratchesScuffs"]</span>
                    </div>
                    <div class="damage-check">
                        @if (m_damageLevel == "Minor")
                        {
                            <i class="ti ti-check"></i>
                        }
                    </div>
                </div>

                <div class="damage-option @(m_damageLevel == "Moderate" ? "selected" : "") damage-moderate"
                     @onclick="@(() => m_damageLevel = "Moderate")">
                    <div class="damage-icon">
                        <i class="ti ti-alert-triangle"></i>
                    </div>
                    <div class="damage-text">
                        <span class="damage-title">@Localizer["Moderate"]</span>
                        <span class="damage-desc">@Localizer["RepairsNeeded"]</span>
                    </div>
                    <div class="damage-check">
                        @if (m_damageLevel == "Moderate")
                        {
                            <i class="ti ti-check"></i>
                        }
                    </div>
                </div>

                <div class="damage-option @(m_damageLevel == "Major" ? "selected" : "") damage-major"
                     @onclick="@(() => m_damageLevel = "Major")">
                    <div class="damage-icon">
                        <i class="ti ti-alert-octagon"></i>
                    </div>
                    <div class="damage-text">
                        <span class="damage-title">@Localizer["Major"]</span>
                        <span class="damage-desc">@Localizer["SignificantDamage"]</span>
                    </div>
                    <div class="damage-check">
                        @if (m_damageLevel == "Major")
                        {
                            <i class="ti ti-check"></i>
                        }
                    </div>
                </div>
            </div>

            @if (m_damageLevel != "None")
            {
                <div class="damage-details-section">
                    <h5 class="section-title">
                        <i class="ti ti-file-description"></i>
                        @Localizer["DamageDetails"]
                    </h5>

                    <div class="form-group">
                        <label class="form-label">@Localizer["DescribeDamage"]</label>
                        <textarea class="form-control" @bind="m_damageDescription" rows="3"
                                  placeholder="@Localizer["DescribeDamagePlaceholder"]"></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label">@Localizer["EstimatedRepairCost"]</label>
                        <div class="cost-input">
                            <span class="cost-currency">@BaseCurrencySymbol</span>
                            <input type="number" class="form-control form-control-lg" @bind="m_damageEstimate"
                                   min="0" max="100000" step="100" placeholder="0" />
                        </div>
                    </div>

                    <h5 class="section-title mt-4">
                        <i class="ti ti-camera"></i>
                        @Localizer["DamagePhotos"]
                    </h5>
                    <p class="text-secondary small mb-3">
                        @Localizer["DamagePhotosDesc"]
                    </p>

                    <DamagePhotoUpload @ref="m_damagePhotoUpload"
                                       RentalId="@m_rental!.RentalId"
                                       PhotoType="After"
                                       MaxPhotos="5"
                                       OnPhotosChanged="OnDamagePhotosChanged" />

                    <div class="info-banner info-blue mt-3">
                        <i class="ti ti-info-circle"></i>
                        <span>@Localizer["DeductedFromDeposit"]</span>
                    </div>
                </div>
            }
        }
    };

    private RenderFragment RenderSettleStep() => __builder =>
    {
        @* Charges Summary *@
        <div class="settlement-card">
            <h5 class="settlement-title">@Localizer["ChargesSummary"]</h5>

            <div class="settlement-row">
                <span>@Localizer["OriginalRental"]</span>
                <span class="text-secondary">@FormatCurrency(m_rental!.TotalAmount) (@Localizer["Paid"])</span>
            </div>

            @* Dynamic Pricing Badge *@
            @if (m_rental.DynamicPricingApplied)
            {
                <div class="dynamic-pricing-summary">
                    <button type="button" class="dynamic-pricing-toggle @(m_showPricingBreakdown ? "expanded" : "")"
                            @onclick="@(() => m_showPricingBreakdown = !m_showPricingBreakdown)">
                        <i class="ti ti-chart-arrows-vertical text-warning me-2"></i>
                        <span class="flex-grow-1 text-start">@Localizer["DynamicPricingApplied"]</span>
                        <span class="badge bg-warning text-dark me-2">×@m_rental.AverageMultiplier.ToString("N2")</span>
                        <i class="ti @(m_showPricingBreakdown ? "ti-chevron-up" : "ti-chevron-down")"></i>
                    </button>

                    @if (m_showPricingBreakdown && m_rental.DayPricingBreakdown.Count > 0)
                    {
                        <div class="pricing-breakdown">
                            <div class="breakdown-header">
                                <span>@Localizer["Date"]</span>
                                <span class="text-end">@Localizer["BaseRate"]</span>
                                <span class="text-center">@Localizer["Multiplier"]</span>
                                <span class="text-end">@Localizer["AdjustedRate"]</span>
                            </div>
                            @foreach (var day in m_rental.DayPricingBreakdown)
                            {
                                <div class="breakdown-row @(day.HasAdjustment ? "adjusted" : "")">
                                    <span>@day.Date.ToString("dd MMM")</span>
                                    <span class="text-end">@FormatCurrency(day.BaseRate)</span>
                                    <span class="text-center">
                                        @if (day.HasAdjustment)
                                        {
                                            <span class="text-warning fw-medium">×@day.Multiplier.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">×1.00</span>
                                        }
                                    </span>
                                    <span class="text-end fw-medium">@FormatCurrency(day.AdjustedRate)</span>
                                </div>
                            }
                            <div class="breakdown-footer">
                                <span class="text-muted">@m_rental.AppliedPricingRules</span>
                                <span class="text-decoration-line-through text-muted">
                                    @FormatCurrency(m_rental.BaseRentalRate * m_rental.DayPricingBreakdown.Count)
                                </span>
                                <span></span>
                                <span class="fw-bold text-warning">
                                    @FormatCurrency(m_rental.DayPricingBreakdown.Sum(d => d.AdjustedRate))
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (m_isHourlyRental && m_extraHours > 0)
            {
                <div class="settlement-row text-warning">
                    <span>@Localizer["ExtraHours", m_extraHours]</span>
                    <span>+@FormatCurrency(m_extraDaysCharge)</span>
                </div>
            }
            else if (!m_isHourlyRental && m_dailyLateFeeMode == "Hourly" && m_vehicle?.HourlyRate > 0 && m_extraHours > 0)
            {
                <div class="settlement-row text-warning">
                    <span>@Localizer["ExtraHours", m_extraHours]</span>
                    <span>+@FormatCurrency(m_extraDaysCharge)</span>
                </div>
            }
            else if (m_extraDays > 0)
            {
                <div class="settlement-row text-warning">
                    <span>@Localizer["ExtraDays", m_extraDays]</span>
                    <span>+@FormatCurrency(m_extraDaysCharge)</span>
                </div>
            }

            @if (m_damageLevel != "None" && m_damageEstimate > 0)
            {
                <div class="settlement-row text-danger">
                    <span>@Localizer["Damage"] (@Localizer[m_damageLevel])</span>
                    <span>+@FormatCurrency(m_damageEstimate)</span>
                </div>
            }

            @if (m_fuelSurcharge > 0)
            {
                <div class="settlement-row text-warning">
                    <span><i class="ti ti-gas-station me-1"></i>@Localizer["FuelSurcharge"]</span>
                    <span>+@FormatCurrency(m_fuelSurcharge)</span>
                </div>
                <div class="settlement-row text-secondary" style="font-size: 0.8rem; padding-left: 1.75rem;">
                    <span>@Localizer["FuelDeficitDetail", m_fuelDeficitQuarters, FormatCurrency(m_fuelRatePerQuarter)]</span>
                </div>
            }

            @if (m_cleaningFee > 0)
            {
                <div class="settlement-row text-warning">
                    <span><i class="ti ti-wash me-1"></i>@Localizer["CleaningFee"]</span>
                    <span>+@FormatCurrency(m_cleaningFee)</span>
                </div>
            }

            @if (m_accessoryMissingCharge > 0)
            {
                <div class="settlement-row text-danger">
                    <span><i class="ti ti-backpack me-1"></i>@Localizer["MissingAccessoryCharge"]</span>
                    <span>+@FormatCurrency(m_accessoryMissingCharge)</span>
                </div>
            }

            @if (m_dropoffLocationFee > 0)
            {
                <div class="settlement-row text-secondary">
                    <span><i class="ti ti-map-pin me-1"></i>@m_selectedDropoffLocation?.Name</span>
                    <span>+@FormatCurrency(m_dropoffLocationFee)</span>
                </div>
            }

            @if (m_dropoffOutOfHoursFee > 0)
            {
                <div class="settlement-row text-warning">
                    <span><i class="ti ti-clock me-1"></i>@m_dropoffOutOfHoursBand?.BandName</span>
                    <span>+@FormatCurrency(m_dropoffOutOfHoursFee)</span>
                </div>
            }

            <div class="settlement-total">
                <span>@Localizer["AdditionalDue"]</span>
                <span class="total-value">@FormatCurrency(m_totalAdditional)</span>
            </div>
        </div>

        @* Deposit Settlement *@
        <div class="settlement-card">
            <h5 class="settlement-title">@Localizer["DepositSettlement"]</h5>

            <div class="settlement-row">
                <span>@Localizer["DepositHeld"]</span>
                <span>@FormatCurrency(m_depositAmount)</span>
            </div>

            @if (m_totalAdditional > 0)
            {
                <div class="settlement-row text-danger">
                    <span>@Localizer["Deductions"]</span>
                    <span>-@FormatCurrency(Math.Min(m_totalAdditional, m_depositAmount))</span>
                </div>
            }

            <div class="refund-amount">
                <span class="refund-label">@Localizer["RefundAmount"]</span>
                <span class="refund-value @(m_refundAmount > 0 ? "text-success" : "")">
                    @FormatCurrency(m_refundAmount)
                </span>
            </div>

            @if (m_totalAdditional > m_depositAmount)
            {
                <div class="status-alert status-warning mt-3">
                    <div class="status-icon">
                        <i class="ti ti-alert-triangle"></i>
                    </div>
                    <div class="status-content">
                        <span class="status-title">@Localizer["PaymentRequired"]</span>
                        <span class="status-detail">@Localizer["CollectFromRenter", FormatCurrency(m_totalAdditional - m_depositAmount)]</span>
                    </div>
                </div>
            }
        </div>

        @* Refund Method *@
        <div class="form-section">
            <h5 class="section-title">
                <i class="ti ti-wallet"></i>
                @Localizer["RefundMethod"]
            </h5>

            <div class="refund-methods">
                <div class="refund-method @(m_refundMethod == "Cash" ? "selected" : "")"
                     @onclick="@(() => m_refundMethod = "Cash")">
                    <i class="ti ti-cash"></i>
                    <span>@Localizer["Cash"]</span>
                </div>
                <div class="refund-method @(m_refundMethod == "Card" ? "selected" : "")"
                     @onclick="@(() => m_refundMethod = "Card")">
                    <i class="ti ti-credit-card"></i>
                    <span>@Localizer["Card"]</span>
                </div>
                <div class="refund-method @(m_refundMethod == "BankTransfer" ? "selected" : "")"
                     @onclick="@(() => m_refundMethod = "BankTransfer")">
                    <i class="ti ti-building-bank"></i>
                    <span>@Localizer["Bank"]</span>
                </div>
            </div>

            <label class="confirm-check">
                <input type="checkbox" class="form-check-input" @bind="m_refundProcessed" />
                <span>@GetRefundConfirmationText()</span>
            </label>
        </div>

        @if (m_hasMaintenanceWarning)
        {
            <div class="status-alert status-warning">
                <div class="status-icon">
                    <i class="ti ti-tool"></i>
                </div>
                <div class="status-content">
                    <span class="status-title">@Localizer["MaintenanceNotice"]</span>
                    <span class="status-detail">
                        @if (m_maintenanceOverdueCount > 0)
                        {
                            <span class="badge bg-danger me-1">@m_maintenanceOverdueCount @Localizer["Overdue"]</span>
                        }
                        @if (m_maintenanceDueSoonCount > 0)
                        {
                            <span class="badge bg-warning text-dark">@m_maintenanceDueSoonCount @Localizer["DueSoon"]</span>
                        }
                    </span>
                    <label class="confirm-check mt-2">
                        <input type="checkbox" class="form-check-input" @bind="m_acknowledgeMaintenanceWarning" />
                        <span>@Localizer["Acknowledge"]</span>
                    </label>
                </div>
            </div>
        }
    };

    #endregion
}
