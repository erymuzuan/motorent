    private void OnMarkerAdded(DamageMarker marker)
    {
        this.m_selectedMarker = marker;
    }

    private void OnMarkerSelected(DamageMarker marker)
    {
        this.m_selectedMarker = marker;
    }

    private void OnMarkerUpdated(DamageMarker marker)
