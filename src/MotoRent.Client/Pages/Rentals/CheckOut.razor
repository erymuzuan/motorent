@page "/rentals/checkout"
@page "/rentals/checkout/{RentalRef}"
@using Microsoft.AspNetCore.Authorization
@using MotoRent.Domain.Entities
@using MotoRent.Domain.Models
@using MotoRent.Domain.Models.VehicleInspection
@using MotoRent.Domain.Settings
@using MotoRent.Client.Components.Shared
@using MotoRent.Client.Controls
@using MotoRent.Client.Controls.VehicleInspection
@attribute [Authorize(Policy = "RequireTenantStaff")]
@inherits LocalizedComponentBase<CheckOut>
@inject RentalService RentalService
@inject RenterService RenterService
@inject VehicleService VehicleService
@inject VehiclePoolService VehiclePoolService
@inject ShopService ShopService
@inject MaintenanceService MaintenanceService
@inject ServiceLocationService LocationService
@inject OperatingHoursService HoursService
@inject RentalPricingService PricingService
@inject VehicleInspectionService VehicleInspectionService
@inject AccessoryService AccessoryService
@inject FleetModelService FleetModelService

<MotoRentPageTitle>@Localizer["PageTitle"]</MotoRentPageTitle>

<div class="mr-page-header mr-animate-in">
    <div class="container-xl">
        <nav class="mr-breadcrumb">
            <span class="mr-breadcrumb-item"><a href="/"><i class="ti ti-home"></i></a></span>
            <span class="mr-breadcrumb-separator"><i class="ti ti-chevron-right"></i></span>
            <span class="mr-breadcrumb-item"><a href="/rentals">@Localizer["Rentals"]</a></span>
            <span class="mr-breadcrumb-separator"><i class="ti ti-chevron-right"></i></span>
            <span class="mr-breadcrumb-item active">@Localizer["CheckOut"]</span>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="mr-page-title">
                    <i class="ti ti-logout"></i>
                    @Localizer["Header"]
                </h1>
                <p class="mr-page-subtitle">@Localizer["SubHeader"]</p>
            </div>
            @if (m_rental != null)
            {
                <a href="/rentals/checkout" class="mr-btn-header-action">
                    <i class="ti ti-arrow-left"></i>
                    @CommonLocalizer["BackToList"]
                </a>
            }
            else
            {
                <a href="/rentals" class="mr-btn-header-action">
                    <i class="ti ti-arrow-left"></i>
                    @CommonLocalizer["BackToList"]
                </a>
            }
        </div>
    </div>
</div>

@if (m_rental != null)
{
    @* ===== Full-page checkout wizard ===== *@
    <div class="container-xl">
        <div class="mr-card mr-animate-in mr-animate-delay-1">
            <div class="mr-card-body p-4">
                @if (m_wizardLoading)
                {
                    <div class="d-flex justify-content-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else
                {
                    @* Step indicators *@
                    <div class="mr-filter-tabs mb-4" style="justify-content: center;">
                        @for (int i = 0; i < m_stepKeys.Length; i++)
                        {
                            var stepIndex = i;
                            var isActive = m_activeStep == stepIndex;
                            var isCompleted = m_activeStep > stepIndex;
                            <button type="button"
                                    class="mr-filter-tab @(isActive ? "active" : "") @(isCompleted ? "text-success" : "")"
                                    disabled="@(stepIndex > m_activeStep)"
                                    @onclick="@(() => GoToStep(stepIndex))">
                                @if (isCompleted)
                                {
                                    <i class="ti ti-check me-1"></i>
                                }
                                else
                                {
                                    <span class="me-1">@(stepIndex + 1).</span>
                                }
                                @Localizer[m_stepKeys[stepIndex]]
                            </button>
                        }
                    </div>

                    <hr class="my-4" style="border-color: var(--mr-border-light);" />

                    @* Step content *@
                    @switch (m_activeStep)
                    {
                        case 0:
                            @RenderReturnStep()
                            break;
                        case 1:
                            @RenderDamageStep()
                            break;
                        case 2:
                            @RenderSettleStep()
                            break;
                    }

                    @* Navigation buttons *@
                    <div class="d-flex justify-content-between mt-4 pt-3" style="border-top: 1px solid var(--mr-border-light);">
                        <button type="button" class="mr-btn-cancel"
                                disabled="@(m_activeStep == 0)"
                                @onclick="PreviousStep">
                            <i class="ti ti-arrow-left"></i>
                            @Localizer["Back"]
                        </button>

                        @if (m_activeStep < 2)
                        {
                            <button type="button" class="mr-btn-primary-action"
                                    disabled="@(m_activeStep == 0 && !CanProceedToStep2)"
                                    @onclick="NextStep">
                                @if (m_activeStep == 0)
                                {
                                    @Localizer["NextDamageCheck"]
                                }
                                else
                                {
                                    @Localizer["NextSettlement"]
                                }
                                <i class="ti ti-arrow-right"></i>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-success btn-lg" disabled="@(!CanComplete)" @onclick="CompleteCheckOut">
                                @if (m_saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                <i class="ti ti-check me-1"></i>
                                @Localizer["Complete"]
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    @* ===== List view (no RentalRef) ===== *@
    <div class="container-xl">
        <div class="mr-card mr-animate-in mr-animate-delay-1">
            <div class="mr-card-header">
                <div class="mr-card-title">
                    <i class="ti ti-car me-2"></i>
                    @Localizer["SelectRental"]
                </div>
                <div class="ms-auto">
                    <div class="input-icon">
                        <span class="input-icon-addon">
                            <i class="ti ti-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="@Localizer["SearchPlaceholder"]"
                               @bind="m_searchTerm" @bind:event="oninput" @onkeyup="OnSearchChanged" />
                    </div>
                </div>
            </div>
            <div class="mr-card-body p-0">
                @if (m_loading)
                {
                    <div class="d-flex justify-content-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (m_activeRentals.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="ti ti-car-off text-secondary" style="font-size: 3rem;"></i>
                        <h4 class="mt-3 text-secondary">@Localizer["NoActiveRentals"]</h4>
                        <p class="text-secondary">@Localizer["NoActiveRentalsHint"]</p>
                        <a href="/rentals/checkin" class="btn btn-primary mt-2">
                            <i class="ti ti-login me-1"></i>
                            @Localizer["NewCheckIn"]
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["Renter"]</th>
                                    <th>@Localizer["Vehicle"]</th>
                                    <th>@Localizer["StartDate"]</th>
                                    <th>@Localizer["ExpectedReturn"]</th>
                                    <th class="text-center">@Localizer["Status"]</th>
                                    <th class="text-end" style="width: 120px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rental in m_filteredRentals)
                                {
                                    var isOverdue = rental.ExpectedEndDate < DateTimeOffset.Now;
                                    <tr class="@(isOverdue ? "table-warning" : "")">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="avatar avatar-sm bg-primary-lt me-2">
                                                    <i class="ti ti-user"></i>
                                                </span>
                                                <div>
                                                    <div class="fw-medium">@rental.RenterName</div>
                                                    <small class="text-secondary">@rental.RenterPhone</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-medium">@rental.VehicleName</div>
                                            <small class="text-secondary">@rental.LicensePlate</small>
                                        </td>
                                        <td>@rental.StartDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @rental.ExpectedEndDate.ToString("dd MMM yyyy")
                                            @if (isOverdue)
                                            {
                                                <span class="badge bg-danger ms-1">@Localizer["Overdue"]</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="mr-badge mr-badge-success">@Localizer["Active"]</span>
                                        </td>
                                        <td class="text-end">
                                            <a href="/rentals/checkout/@EncodeId(rental.Rental.RentalId)" class="btn btn-outline-primary btn-sm">
                                                <i class="ti ti-logout me-1"></i>
                                                @Localizer["ReturnVehicle"]
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? RentalRef { get; set; }

    private readonly string[] m_stepKeys = ["Return", "Damage", "Settle"];
    private int m_activeStep;

    // List view state
    private bool m_loading = true;
    private string m_searchTerm = "";
    private List<ActiveRentalItem> m_activeRentals = [];
    private List<ActiveRentalItem> m_filteredRentals = [];

    // Wizard state
    private Rental? m_rental;
    private bool m_wizardLoading = true;
    private bool m_saving;
    private bool m_showPricingBreakdown;

    // Rental details
    private string m_renterName = "";
    private string m_vehicleName = "";
    private Vehicle? m_vehicle;
    private FleetModel? m_fleetModel;
    private decimal m_depositAmount;
    private bool m_isIntervalRental;
    private bool m_isHourlyRental;
    private string m_dailyLateFeeMode = "Daily";
    private bool m_showMileage;

    // Cross-shop return for pooled vehicles
    private bool m_isPooledVehicle;
    private List<Shop> m_poolShops = [];
    private int m_returnToShopId;

    // Return details
    private DateTime? m_actualReturnDate;
    private int m_mileageEnd;
    private string? m_notes;

    // Post-rental inspection
    private InspectionInfo? m_postInspection;

    // Damage assessment
    private string m_damageLevel = "None";
    private string? m_damageDescription;
    private decimal m_damageEstimate;
    private DamagePhotoUpload? m_damagePhotoUpload;
    private List<string> m_damagePhotoPaths = [];

    // 3D Inspection
    private bool m_use3DInspection;
    private VehicleInspector? m_vehicleInspector;
    private List<DamageMarker> m_inspectionMarkers = [];
    private DamageMarker? m_selectedMarker;
    private VehicleInspection? m_preRentalInspection;

    // Settlement
    private string m_refundMethod = "Cash";
    private bool m_refundProcessed;

    // Maintenance warning
    private bool m_hasMaintenanceWarning;
    private int m_maintenanceOverdueCount;
    private int m_maintenanceDueSoonCount;
    private bool m_acknowledgeMaintenanceWarning;

    // Drop-off service location
    private List<ServiceLocation> m_dropoffLocations = [];
    private int m_dropoffLocationId;
    private ServiceLocation? m_selectedDropoffLocation;
    private TimeSpan m_dropoffTime = new(10, 0, 0);
    private decimal m_dropoffLocationFee;
    private decimal m_dropoffOutOfHoursFee;
    private OutOfHoursResult? m_dropoffOutOfHoursBand;

    // Fuel level
    private int m_fuelLevelAtReturn = 100;
    private int? m_fuelLevelAtCheckIn;
    private decimal m_fuelSurcharge;
    private int m_fuelDeficitQuarters;
    private decimal m_fuelRatePerQuarter;

    // Cleanliness
    private string m_cleanlinessLevel = "Clean";
    private decimal m_cleaningFee;

    // Accessories
    private List<AccessoryReturnItem> m_rentalAccessories = [];
    private decimal m_accessoryMissingCharge;

    // Calculated values
    private int m_extraDays => this.m_actualReturnDate.HasValue && !this.m_isIntervalRental && !this.m_isHourlyRental
        ? Math.Max(0, (int)(this.m_actualReturnDate.Value - this.m_rental!.ExpectedEndDate.Date).TotalDays)
        : 0;

    private int m_extraHours
    {
        get
        {
            if (this.m_rental == null) return 0;

            if (this.m_isHourlyRental)
            {
                var actualEnd = DateTimeOffset.Now;
                if (actualEnd <= this.m_rental.ExpectedEndDate) return 0;
                return (int)Math.Ceiling((actualEnd - this.m_rental.ExpectedEndDate).TotalHours);
            }

            if (this.m_dailyLateFeeMode == "Hourly" && this.m_vehicle?.HourlyRate > 0
                && this.m_actualReturnDate.HasValue && !this.m_isIntervalRental)
            {
                var expectedEnd = this.m_rental.ExpectedEndDate;
                var actualEnd = new DateTimeOffset(
                    DateTime.SpecifyKind(this.m_actualReturnDate.Value, DateTimeKind.Utc), TimeSpan.Zero);
                if (actualEnd <= expectedEnd) return 0;
                return (int)Math.Ceiling((actualEnd - expectedEnd).TotalHours);
            }

            return 0;
        }
    }

    private decimal m_extraDaysCharge
    {
        get
        {
            if (this.m_rental == null) return 0;

            if (this.m_isHourlyRental)
                return this.m_extraHours * this.m_rental.RentalRate;

            if (this.m_dailyLateFeeMode == "Hourly" && this.m_vehicle?.HourlyRate > 0
                && !this.m_isIntervalRental)
                return this.m_extraHours * this.m_vehicle.HourlyRate.Value;

            return this.m_extraDays * this.m_rental.RentalRate;
        }
    }

    private decimal m_dropoffTotalFees => this.m_dropoffLocationFee + this.m_dropoffOutOfHoursFee;
    private decimal m_3dInspectionDamageEstimate => this.m_inspectionMarkers.Sum(m => m.EstimatedCost ?? 0);
    private decimal m_totalAdditional => this.m_extraDaysCharge +
        (this.m_use3DInspection ? this.m_3dInspectionDamageEstimate : (this.m_damageLevel != "None" ? this.m_damageEstimate : 0)) +
        this.m_dropoffTotalFees +
        this.m_fuelSurcharge +
        this.m_cleaningFee +
        this.m_accessoryMissingCharge;
    private decimal m_refundAmount => Math.Max(0, this.m_depositAmount - this.m_totalAdditional);

    private bool CanProceedToStep2 => this.m_rental != null &&
                                      (this.m_actualReturnDate.HasValue || this.m_isIntervalRental || this.m_isHourlyRental) &&
                                      (!this.m_showMileage || this.m_mileageEnd >= this.m_rental.MileageStart) &&
                                      this.m_postInspection != null;

    private bool CanComplete => this.CanProceedToStep2 &&
                                (this.m_refundAmount == 0 || this.m_refundProcessed) &&
                                (!this.m_hasMaintenanceWarning || this.m_acknowledgeMaintenanceWarning);

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(this.RentalRef))
        {
            await LoadActiveRentalsAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var rentalId = this.DecodeId(this.RentalRef);
        if (rentalId > 0)
        {
            if (this.m_rental == null || this.m_rental.RentalId != rentalId)
            {
                this.m_rental = await this.RentalService.GetRentalByIdAsync(rentalId);
                if (this.m_rental == null || this.m_rental.Status != "Active")
                {
                    this.ShowError(this.Localizer["ErrorLoading", "Rental not found or not active"]);
                    this.NavigationManager.NavigateTo("/rentals/checkout");
                    return;
                }
                await LoadWizardDataAsync();
            }
        }
        else if (string.IsNullOrEmpty(this.RentalRef))
        {
            this.m_rental = null;
        }
    }

    #region List View

    private async Task LoadActiveRentalsAsync()
    {
        this.m_loading = true;
        try
        {
            var result = await this.RentalService.GetRentalsAsync(0, status: "Active", pageSize: 100);

            this.m_activeRentals.Clear();
            foreach (var rental in result.ItemCollection)
            {
                var renter = await this.DataContext.LoadOneAsync<Renter>(r => r.RenterId == rental.RenterId);
                var vehicle = await this.DataContext.LoadOneAsync<Vehicle>(v => v.VehicleId == rental.VehicleId);

                this.m_activeRentals.Add(new ActiveRentalItem
                {
                    Rental = rental,
                    RenterName = renter?.FullName ?? "Unknown",
                    RenterPhone = renter?.Phone ?? "",
                    VehicleName = vehicle != null ? $"{vehicle.Brand} {vehicle.Model}" : "Unknown",
                    LicensePlate = vehicle?.LicensePlate ?? "",
                    StartDate = rental.StartDate,
                    ExpectedEndDate = rental.ExpectedEndDate
                });
            }

            this.m_activeRentals = this.m_activeRentals
                .OrderBy(r => r.ExpectedEndDate)
                .ToList();

            ApplyFilter();
        }
        finally
        {
            this.m_loading = false;
        }
    }

    private void OnSearchChanged()
    {
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(this.m_searchTerm))
        {
            this.m_filteredRentals = this.m_activeRentals;
        }
        else
        {
            var term = this.m_searchTerm.ToLower();
            this.m_filteredRentals = this.m_activeRentals
                .Where(r => r.RenterName.ToLower().Contains(term) ||
                            r.VehicleName.ToLower().Contains(term) ||
                            r.LicensePlate.ToLower().Contains(term))
                .ToList();
        }
    }

    private class ActiveRentalItem
    {
        public Rental Rental { get; set; } = null!;
        public string RenterName { get; set; } = "";
        public string RenterPhone { get; set; } = "";
        public string VehicleName { get; set; } = "";
        public string LicensePlate { get; set; } = "";
        public DateTimeOffset StartDate { get; set; }
        public DateTimeOffset ExpectedEndDate { get; set; }
    }

    #endregion

    #region Wizard

    private async Task LoadWizardDataAsync()
    {
        this.m_wizardLoading = true;
        try
        {
            this.m_activeStep = 0;
            this.m_actualReturnDate = DateTime.Today;
            this.m_mileageEnd = this.m_rental!.MileageStart;
            this.m_returnToShopId = this.RequestContext.GetShopId();

            // Load renter name
            var renter = await this.DataContext.LoadOneAsync<Renter>(r => r.RenterId == this.m_rental.RenterId);
            this.m_renterName = renter?.FullName ?? "Unknown";

            // Load vehicle
            var vehicleId = this.m_rental.VehicleId;
            this.m_vehicle = vehicleId > 0
                ? await this.DataContext.LoadOneAsync<Vehicle>(v => v.VehicleId == vehicleId)
                : null;
            if (this.m_vehicle != null)
            {
                this.m_vehicleName = $"{this.m_vehicle.Brand} {this.m_vehicle.Model} ({this.m_vehicle.LicensePlate})";
                this.m_mileageEnd = this.m_vehicle.Mileage ?? 0;
                this.m_isIntervalRental = this.m_rental.DurationType == RentalDurationType.FixedInterval;
                this.m_isHourlyRental = this.m_rental.DurationType == RentalDurationType.Hourly;
                this.m_showMileage = this.m_vehicle.VehicleType == VehicleType.Motorbike ||
                                     this.m_vehicle.VehicleType == VehicleType.Car ||
                                     this.m_vehicle.VehicleType == VehicleType.Van;

                if (this.m_vehicle.VehiclePoolId.HasValue)
                {
                    this.m_isPooledVehicle = true;
                    this.m_poolShops = await this.VehiclePoolService.GetShopsInPoolAsync(this.m_vehicle.VehiclePoolId.Value);
                }
            }

            // Load FleetModel for fee fallback (via Rental.FleetModelId or Vehicle.FleetModelId)
            var fleetModelId = this.m_rental!.FleetModelId
                ?? (this.m_vehicle?.FleetModelId > 0 ? this.m_vehicle.FleetModelId : (int?)null);
            if (fleetModelId.HasValue && fleetModelId.Value > 0)
            {
                this.m_fleetModel = await this.FleetModelService.GetFleetModelByIdAsync(fleetModelId.Value);
            }
            // Fallback: find FleetModel by matching brand/model/year
            if (this.m_fleetModel == null && this.m_vehicle != null)
            {
                this.m_fleetModel = await this.FleetModelService.GetFleetModelForVehicleAsync(this.m_vehicle);
            }

            // Load daily late fee mode setting
            if (this.m_rental.DurationType == RentalDurationType.Daily)
            {
                this.m_dailyLateFeeMode = await this.SettingConfig.GetStringAsync(
                    SettingKeys.Rental_DailyLateFeeMode, defaultValue: "Daily") ?? "Daily";
            }

            // Load deposit
            var deposit = await this.DataContext.LoadOneAsync<Deposit>(d => d.RentalId == this.m_rental.RentalId);
            this.m_depositAmount = deposit?.Amount ?? 0;

            // Check maintenance status
            if (this.m_showMileage && this.m_vehicle != null)
            {
                var maintenanceSummary = await this.MaintenanceService.GetMotorbikeMaintenanceSummaryAsync(
                    this.m_vehicle.VehicleId, DateTimeOffset.Now);
                this.m_maintenanceOverdueCount = maintenanceSummary.OverdueCount;
                this.m_maintenanceDueSoonCount = maintenanceSummary.DueSoonCount;
                this.m_hasMaintenanceWarning = maintenanceSummary.OverallStatus != MaintenanceStatus.Ok;
            }

            // Load dropoff service locations (use rental's shop if user has no specific shop)
            var shopId = this.RequestContext.GetShopId();
            if (shopId == 0)
                shopId = this.m_rental.RentedFromShopId;
            this.m_dropoffLocations = await this.LocationService.GetActiveLocationsAsync(
                shopId, pickupOnly: null, dropoffOnly: true);

            // Check if rental already has a dropoff location configured
            if (this.m_rental.DropoffLocationId.HasValue)
            {
                this.m_dropoffLocationId = this.m_rental.DropoffLocationId.Value;
                this.m_selectedDropoffLocation = this.m_dropoffLocations.FirstOrDefault(l => l.ServiceLocationId == this.m_dropoffLocationId);
                this.m_dropoffLocationFee = this.m_rental.DropoffLocationFee;
                if (this.m_rental.ScheduledDropoffTime.HasValue)
                {
                    this.m_dropoffTime = this.m_rental.ScheduledDropoffTime.Value;
                }
            }

            // Load fuel level from check-in (stored on rental)
            this.m_fuelLevelAtCheckIn = this.m_rental.FuelLevelAtCheckIn;
            this.m_fuelLevelAtReturn = this.m_fuelLevelAtCheckIn ?? 100;

            // Load rental accessories for return checklist
            this.m_rentalAccessories.Clear();
            var rentalAccessories = await this.DataContext.LoadAsync(
                this.DataContext.CreateQuery<RentalAccessory>()
                    .Where(ra => ra.RentalId == this.m_rental.RentalId));
            foreach (var ra in rentalAccessories.ItemCollection)
            {
                var accessory = await this.DataContext.LoadOneAsync<Accessory>(a => a.AccessoryId == ra.AccessoryId);
                this.m_rentalAccessories.Add(new AccessoryReturnItem
                {
                    AccessoryId = ra.AccessoryId,
                    Name = accessory?.Name ?? $"Accessory #{ra.AccessoryId}",
                    QuantityRented = ra.Quantity,
                    QuantityReturned = ra.Quantity
                });
            }

            // Load pre-rental inspection for 3D comparison
            this.m_preRentalInspection = await this.VehicleInspectionService.GetPreRentalInspectionAsync(this.m_rental.RentalId);
            if (this.m_preRentalInspection != null)
            {
                foreach (var marker in this.m_preRentalInspection.Markers)
                {
                    marker.IsPreExisting = true;
                }
                this.m_inspectionMarkers = [.. this.m_preRentalInspection.Markers];
            }
        }
        finally
        {
            this.m_wizardLoading = false;
        }
    }

    private string GetVehicleTypeLabel() => this.m_vehicle?.VehicleType switch
    {
        VehicleType.Motorbike => Localizer["Motorbike"],
        VehicleType.Car => Localizer["Car"],
        VehicleType.JetSki => Localizer["JetSki"],
        VehicleType.Boat => Localizer["Boat"],
        VehicleType.Van => Localizer["Van"],
        _ => Localizer["Vehicle"]
    };

    private void GoToStep(int step)
    {
        if (step < this.m_activeStep)
            this.m_activeStep = step;
    }

    private void NextStep()
    {
        if (this.m_activeStep < 2)
            this.m_activeStep++;
    }

    private void PreviousStep()
    {
        if (this.m_activeStep > 0)
            this.m_activeStep--;
    }

    private string GetRefundConfirmationText()
    {
        if (this.m_refundAmount > 0)
            return Localizer["ConfirmRefundProcessed", FormatCurrency(this.m_refundAmount), Localizer[this.m_refundMethod]];
        else if (this.m_totalAdditional > this.m_depositAmount)
            return Localizer["ConfirmAdditionalCollected", FormatCurrency(this.m_totalAdditional - this.m_depositAmount)];
        else
            return Localizer["NoRefundNeeded"];
    }

    private void OnDamagePhotosChanged(List<string> photoPaths)
    {
        this.m_damagePhotoPaths = photoPaths;
    }

    private async Task OnDropoffLocationChanged()
    {
        this.m_selectedDropoffLocation = this.m_dropoffLocations.FirstOrDefault(l => l.ServiceLocationId == this.m_dropoffLocationId);

        if (this.m_selectedDropoffLocation != null)
        {
            this.m_dropoffLocationFee = this.m_selectedDropoffLocation.DropoffFee;
            await this.CalculateDropoffOutOfHoursFeeAsync();
        }
        else
        {
            this.m_dropoffLocationFee = 0;
            this.m_dropoffOutOfHoursFee = 0;
            this.m_dropoffOutOfHoursBand = null;
        }
    }

    private async Task OnDropoffTimeChanged(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var time))
        {
            this.m_dropoffTime = time;
            await this.CalculateDropoffOutOfHoursFeeAsync();
        }
    }

    private async Task CalculateDropoffOutOfHoursFeeAsync()
    {
        if (!this.m_actualReturnDate.HasValue && !this.m_isIntervalRental && !this.m_isHourlyRental) return;

        var dropoffDate = (this.m_isIntervalRental || this.m_isHourlyRental) ? DateTime.Today : this.m_actualReturnDate!.Value;
        var dropoffDateTime = new DateTimeOffset(
            DateTime.SpecifyKind(dropoffDate, DateTimeKind.Utc), TimeSpan.Zero)
            .Add(this.m_dropoffTime);

        this.m_dropoffOutOfHoursBand = await this.HoursService.GetOutOfHoursFeeAsync(this.RequestContext.GetShopId(), dropoffDateTime);
        this.m_dropoffOutOfHoursFee = this.m_dropoffOutOfHoursBand?.Fee ?? 0;
    }

    private async Task CompleteCheckOut()
    {
        if (this.m_rental == null) return;
        if (!this.m_actualReturnDate.HasValue && !this.m_isIntervalRental && !this.m_isHourlyRental) return;

        this.m_saving = true;
        try
        {
            var request = new CheckOutRequest
            {
                RentalId = this.m_rental.RentalId,
                ActualEndDate = (this.m_isIntervalRental || this.m_isHourlyRental)
                    ? DateTimeOffset.Now
                    : new DateTimeOffset(DateTime.SpecifyKind(this.m_actualReturnDate!.Value, DateTimeKind.Utc), TimeSpan.Zero),
                MileageEnd = this.m_showMileage ? this.m_mileageEnd : 0,
                Notes = this.m_notes,
                PaymentMethod = this.m_refundMethod,
                RefundDeposit = this.m_refundAmount > 0,
                ReturnShopId = this.m_isPooledVehicle ? this.m_returnToShopId : null,
                DropoffLocationId = this.m_dropoffLocationId > 0 ? this.m_dropoffLocationId : null,
                DropoffLocationName = this.m_selectedDropoffLocation?.Name,
                ScheduledDropoffTime = this.m_dropoffLocationId > 0 ? this.m_dropoffTime : null,
                DropoffLocationFee = this.m_dropoffLocationFee,
                OutOfHoursDropoffFee = this.m_dropoffOutOfHoursFee,
                IsOutOfHoursDropoff = this.m_dropoffOutOfHoursBand != null,
                OutOfHoursDropoffBand = this.m_dropoffOutOfHoursBand?.BandName,
                PostRentalInspection = this.m_postInspection,
                FuelLevelAtReturn = this.m_fuelLevelAtReturn,
                FuelSurcharge = this.m_fuelSurcharge,
                CleanlinessLevel = this.m_cleanlinessLevel,
                CleaningFee = this.m_cleaningFee,
                ReturnedAccessories = this.m_rentalAccessories.Count > 0 ? this.m_rentalAccessories : null,
                AccessoryMissingCharge = this.m_accessoryMissingCharge
            };

            if (this.m_damageLevel != "None" && !string.IsNullOrEmpty(this.m_damageDescription))
            {
                request.DamageReports = [
                    new DamageReportInfo
                    {
                        Description = this.m_damageDescription,
                        Severity = this.m_damageLevel,
                        EstimatedCost = this.m_damageEstimate,
                        PhotoPaths = this.m_damagePhotoPaths.Count > 0 ? this.m_damagePhotoPaths : null
                    }
                ];
            }

            var result = await this.RentalService.CheckOutAsync(request, this.UserName);

            if (result.Success)
            {
                var message = Localizer["CheckOutCompleted"].Value;
                if (this.m_refundAmount > 0)
                    message += $" {Localizer["RefundLabel", FormatCurrency(result.RefundAmount)]}";
                if (this.m_returnToShopId != this.RequestContext.GetShopId())
                    message += $" {Localizer["VehicleTransferred", this.m_poolShops.FirstOrDefault(s => s.ShopId == this.m_returnToShopId)?.Name ?? ""]}";
                this.ShowSuccess(message);
                this.NavigationManager.NavigateTo("/rentals");
            }
            else
            {
                this.ShowError(Localizer["CheckOutFailed", result.Message ?? ""]);
            }
        }
        finally
        {
            this.m_saving = false;
        }
    }

    #endregion

    #region Fuel, Accessories, Cleanliness

    private void OnFuelLevelChanged(int level)
    {
        this.m_fuelLevelAtReturn = level;
        this.CalculateFuelSurcharge();
    }

    private void CalculateFuelSurcharge()
    {
        int checkInLevel = this.m_fuelLevelAtCheckIn ?? 100;
        if (this.m_fuelLevelAtReturn < checkInLevel)
        {
            int deficit = checkInLevel - this.m_fuelLevelAtReturn;
            this.m_fuelDeficitQuarters = deficit / 25;
            this.m_fuelRatePerQuarter = this.m_vehicle?.FuelSurchargePerQuarter
                ?? this.m_fleetModel?.FuelSurchargePerQuarter ?? 50m;
            this.m_fuelSurcharge = this.m_fuelDeficitQuarters * this.m_fuelRatePerQuarter;
        }
        else
        {
            this.m_fuelDeficitQuarters = 0;
            this.m_fuelRatePerQuarter = 0;
            this.m_fuelSurcharge = 0;
        }
    }

    private void OnAccessoryReturnChanged(int index, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var qty))
        {
            var item = this.m_rentalAccessories[index];
            item.QuantityReturned = Math.Max(0, Math.Min(qty, item.QuantityRented));
            this.RecalculateAccessoryCharges();
        }
    }

    private void RecalculateAccessoryCharges()
    {
        decimal total = 0;
        foreach (var item in this.m_rentalAccessories)
        {
            if (item.IsMissing)
            {
                int missing = item.QuantityRented - item.QuantityReturned;
                item.MissingCharge = missing * 500m; // ฿500 per missing accessory
                total += item.MissingCharge;
            }
            else
            {
                item.MissingCharge = 0;
            }
        }
        this.m_accessoryMissingCharge = total;
    }

    private void OnCleanlinessChanged(string level)
    {
        this.m_cleanlinessLevel = level;
        this.m_cleaningFee = level switch
        {
            "Dirty" => this.m_vehicle?.CleaningFeeDirty ?? this.m_fleetModel?.CleaningFeeDirty ?? 100m,
            "VeryDirty" => this.m_vehicle?.CleaningFeeVeryDirty ?? this.m_fleetModel?.CleaningFeeVeryDirty ?? 200m,
            _ => 0
        };
    }

