    private async Task RecordPayment()
    {
        if (m_booking == null) return;

        // Case 1: Till disabled - direct payment recording
        if (!m_isTillEnabled)
        {
            await RecordDirectPaymentAsync();
            return;
        }

        // Case 2: Till enabled but no active session
        if (m_activeSession == null)
        {
            var openTill = await DialogService.ConfirmYesNoAsync(
                Localizer["TillRequiredDescription"],
                Localizer["TillRequired"]);

            if (openTill)
            {
                NavigationManager.NavigateTo($"/staff/till?returnUrl=/bookings/{BookingRef}");
            }
            return;
        }

        // Case 3: Till enabled with active session
        await RecordTillPaymentAsync();
    }

    private async Task RecordDirectPaymentAsync()
    {
        if (m_booking == null) return;

        var result = await DialogService.Create<RecordBookingPaymentDialog>(Localizer["RecordPayment"])
            .WithParameter(x => x.BookingId, m_booking.BookingId)
            .WithParameter(x => x.BookingRef, BookingRef)
            .WithParameter(x => x.BalanceDue, m_booking.BalanceDue)
            .WithParameter(x => x.TotalAmount, m_booking.TotalAmount)
            .WithSize(ModalSize.Medium)
            .ShowDialogAsync();

        if (!result.Cancelled && result.Data is BookingPayment payment)
        {
            var saveResult = await BookingService.RecordPaymentAsync(m_booking.BookingId, payment, UserName);
            if (saveResult.Success)
            {
                ShowSuccess(Localizer["PaymentRecorded"]);
                await LoadBookingAsync();
            }
            else
            {
                ShowError(saveResult.Message ?? Localizer["ErrorRecordingPayment"]);
            }
        }
    }

    private async Task RecordTillPaymentAsync()
    {
        if (m_booking == null || m_activeSession == null) return;

        var result = await DialogService.Create<RecordBookingPaymentDialog>(Localizer["RecordPayment"])
            .WithParameter(x => x.BookingId, m_booking.BookingId)
            .WithParameter(x => x.BookingRef, BookingRef)
            .WithParameter(x => x.BalanceDue, m_booking.BalanceDue)
            .WithParameter(x => x.TotalAmount, m_booking.TotalAmount)
            .WithSize(ModalSize.Medium)
            .ShowDialogAsync();

        if (!result.Cancelled && result.Data is BookingPayment payment)
        {
            // 1. Record to Till (for cash payments) - use appropriate transaction type
            var tillTransactionType = payment.PaymentMethod switch
            {
                "Cash" => TillTransactionType.BookingDeposit,
                "Card" => TillTransactionType.CardPayment,
                "PromptPay" => TillTransactionType.PromptPay,
                "BankTransfer" => TillTransactionType.BankTransfer,
                _ => TillTransactionType.BookingDeposit
            };

            var tillResult = await TillService.RecordCashInAsync(
                m_activeSession.TillSessionId,
                tillTransactionType,
                payment.Amount,
                $"Booking payment {BookingRef} - {payment.PaymentType}",
                UserName,
                notes: payment.Notes);

            if (!tillResult.Success)
            {
                ShowError(tillResult.Message ?? Localizer["ErrorRecordingPayment"]);
                return;
            }

            // 2. Record to Booking
            var bookingResult = await BookingService.RecordPaymentAsync(m_booking.BookingId, payment, UserName);

            if (bookingResult.Success)
            {
                ShowSuccess(Localizer["PaymentRecorded"]);
                await LoadBookingAsync();
            }
            else
            {
                ShowError(bookingResult.Message ?? Localizer["ErrorRecordingPayment"]);
            }
        }
    }

