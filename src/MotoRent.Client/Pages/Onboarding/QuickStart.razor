@page "/quick-start"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inherits LocalizedComponentBase<QuickStart>
@inject IOptions<CompanySettings> CompanyInfo

<MotoRentPageTitle>@Localizer["PageTitle"]</MotoRentPageTitle>

<div class="page-wrapper">
    <div class="container-xl py-4">
        @* Welcome Header *@
        <div class="text-center mb-5 mr-animate-in">
            <div class="mb-3">
                <div class="mr-icon-circle mx-auto" style="width: 80px; height: 80px; font-size: 2rem; background: var(--mr-gradient-primary);">
                    <i class="ti ti-confetti text-white"></i>
                </div>
            </div>
            <h1 class="mr-page-title mb-2">@Localizer["WelcomeTitle"]</h1>
            <p class="mr-page-subtitle lead">@Localizer["WelcomeSubtitle"]</p>
        </div>

        @* Quick Action Cards *@
        <div class="row g-4 justify-content-center mb-5">
            @* Add First Vehicle *@
            <div class="col-md-6 col-lg-3">
                <a href="/vehicles/create" class="mr-card h-100 text-decoration-none mr-animate-in mr-animate-delay-1" style="transition: transform 0.2s;">
                    <div class="mr-card-body p-4 text-center">
                        <div class="mb-3">
                            <div class="mr-icon-circle mx-auto" style="width: 56px; height: 56px; font-size: 1.25rem;">
                                <i class="ti ti-motorbike"></i>
                            </div>
                        </div>
                        <h4 class="mb-2">@Localizer["AddFirstVehicle"]</h4>
                        <p class="text-secondary small mb-0">@Localizer["AddFirstVehicleHint"]</p>
                    </div>
                </a>
            </div>

            @* Configure Shop *@
            <div class="col-md-6 col-lg-3">
                <a href="/shops" class="mr-card h-100 text-decoration-none mr-animate-in mr-animate-delay-2" style="transition: transform 0.2s;">
                    <div class="mr-card-body p-4 text-center">
                        <div class="mb-3">
                            <div class="mr-icon-circle mx-auto" style="width: 56px; height: 56px; font-size: 1.25rem;">
                                <i class="ti ti-building-store"></i>
                            </div>
                        </div>
                        <h4 class="mb-2">@Localizer["ConfigureShop"]</h4>
                        <p class="text-secondary small mb-0">@Localizer["ConfigureShopHint"]</p>
                    </div>
                </a>
            </div>

            @* Start a Rental *@
            <div class="col-md-6 col-lg-3">
                <a href="/rentals/checkin" class="mr-card h-100 text-decoration-none mr-animate-in mr-animate-delay-3" style="transition: transform 0.2s;">
                    <div class="mr-card-body p-4 text-center">
                        <div class="mb-3">
                            <div class="mr-icon-circle mx-auto" style="width: 56px; height: 56px; font-size: 1.25rem;">
                                <i class="ti ti-login"></i>
                            </div>
                        </div>
                        <h4 class="mb-2">@Localizer["StartRental"]</h4>
                        <p class="text-secondary small mb-0">@Localizer["StartRentalHint"]</p>
                    </div>
                </a>
            </div>

            @* View Dashboard *@
            <div class="col-md-6 col-lg-3">
                <a href="/" class="mr-card h-100 text-decoration-none mr-animate-in mr-animate-delay-4" style="transition: transform 0.2s;">
                    <div class="mr-card-body p-4 text-center">
                        <div class="mb-3">
                            <div class="mr-icon-circle mx-auto" style="width: 56px; height: 56px; font-size: 1.25rem;">
                                <i class="ti ti-dashboard"></i>
                            </div>
                        </div>
                        <h4 class="mb-2">@Localizer["ViewDashboard"]</h4>
                        <p class="text-secondary small mb-0">@Localizer["ViewDashboardHint"]</p>
                    </div>
                </a>
            </div>
        </div>

        @* Getting Started Checklist *@
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="mr-card mr-animate-in mr-animate-delay-5">
                    <div class="mr-card-header">
                        <h3 class="mr-card-title">
                            <i class="ti ti-list-check me-2"></i>
                            @Localizer["GettingStarted"]
                        </h3>
                    </div>
                    <div class="mr-card-body p-0">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex align-items-center">
                                <span class="badge bg-success me-3">
                                    <i class="ti ti-check"></i>
                                </span>
                                <span>@Localizer["StepCreateAccount"]</span>
                            </div>
                            <div class="list-group-item d-flex align-items-center">
                                <span class="badge bg-secondary me-3">1</span>
                                <span>@Localizer["StepAddVehicles"]</span>
                            </div>
                            <div class="list-group-item d-flex align-items-center">
                                <span class="badge bg-secondary me-3">2</span>
                                <span>@Localizer["StepSetupHours"]</span>
                            </div>
                            <div class="list-group-item d-flex align-items-center">
                                <span class="badge bg-secondary me-3">3</span>
                                <span>@Localizer["StepFirstRental"]</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Skip Tutorial Link *@
        <div class="text-center mt-4 mr-animate-in mr-animate-delay-6">
            <a href="/" class="text-secondary">
                <i class="ti ti-arrow-right me-1"></i>
                @Localizer["SkipTutorial"]
            </a>
        </div>

        @* Help Section *@
        <div class="row justify-content-center mt-5">
            <div class="col-lg-8">
                <div class="text-center p-4" style="background: var(--mr-bg-surface); border-radius: var(--mr-radius-lg);">
                    <h5 class="mb-2">@Localizer["NeedHelp"]</h5>
                    <p class="text-secondary mb-3">@Localizer["NeedHelpHint"]</p>
                    <div class="btn-list justify-content-center">
                        <a href="@(CompanyInfo.Value.DocsUrl ?? "#")" target="_blank" class="btn btn-outline-primary">
                            <i class="ti ti-book me-1"></i>
                            @Localizer["Documentation"]
                        </a>
                        <a href="mailto:@CompanyInfo.Value.GetSupportEmail()" class="btn btn-outline-secondary">
                            <i class="ti ti-mail me-1"></i>
                            @Localizer["ContactSupport"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
