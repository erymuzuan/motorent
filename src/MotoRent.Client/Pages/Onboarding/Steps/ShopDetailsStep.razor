@using MotoRent.Domain.Core
@inherits LocalizedComponentBase<ShopDetailsStep>

<div class="mr-animate-in">
    <div class="text-center mb-4">
        <div class="mb-3">
            <div class="mr-icon-circle mx-auto" style="width: 64px; height: 64px; font-size: 1.5rem;">
                <i class="ti ti-building-store"></i>
            </div>
        </div>
        <h3 class="mb-2">@Localizer["StepTitle"]</h3>
        <p class="text-secondary">@Localizer["StepDescription"]</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="row g-3">
                @* Shop Name *@
                <div class="col-12">
                    <label class="mr-form-label">@Localizer["ShopName"] <span class="required">*</span></label>
                    <input type="text" class="mr-form-control" @bind="Request.ShopName" required
                           placeholder="@Localizer["ShopNamePlaceholder"]" />
                    <div class="mr-form-hint">
                        <i class="ti ti-info-circle"></i>
                        @Localizer["ShopNameHint"]
                    </div>
                </div>

                @* Location Area *@
                <div class="col-md-6">
                    <label class="mr-form-label">@Localizer["Location"] <span class="required">*</span></label>
                    <select class="mr-form-control" @bind="Request.Location" required>
                        <option value="">@Localizer["SelectLocation"]</option>
                        <optgroup label="Sabah">
                            <option value="Kota Kinabalu">Kota Kinabalu</option>
                            <option value="Sandakan">Sandakan</option>
                            <option value="Tawau">Tawau</option>
                        </optgroup>
                        <optgroup label="Sarawak">
                            <option value="Kuching">Kuching</option>
                            <option value="Miri">Miri</option>
                            <option value="Sibu">Sibu</option>
                        </optgroup>
                        <optgroup label="Kedah">
                            <option value="Langkawi">Langkawi</option>
                            <option value="Alor Setar">Alor Setar</option>
                        </optgroup>
                        <optgroup label="Selangor">
                            <option value="Kuala Lumpur">Kuala Lumpur</option>
                            <option value="Petaling Jaya">Petaling Jaya</option>
                            <option value="Shah Alam">Shah Alam</option>
                        </optgroup>
                        <optgroup label="Johor">
                            <option value="Johor Bahru">Johor Bahru</option>
                            <option value="Iskandar Puteri">Iskandar Puteri</option>
                        </optgroup>
                        <optgroup label="Penang">
                            <option value="George Town">George Town</option>
                            <option value="Bayan Lepas">Bayan Lepas</option>
                        </optgroup>
                        <optgroup label="Pahang">
                            <option value="Cameron Highlands">Cameron Highlands</option>
                            <option value="Kuantan">Kuantan</option>
                        </optgroup>
                        <optgroup label="Terengganu">
                            <option value="Kuala Terengganu">Kuala Terengganu</option>
                            <option value="Pulau Redang">Pulau Redang</option>
                        </optgroup>
                        <option value="Other">@Localizer["Other"]</option>
                    </select>
                </div>

                @* Phone Number *@
                <div class="col-md-6">
                    <label class="mr-form-label">@Localizer["Phone"]</label>
                    <input type="tel" class="mr-form-control" @bind="Request.Phone"
                           placeholder="+60 XX XXXX XXXX" />
                </div>

                @* Preferred Language *@
                <div class="col-12">
                    <label class="mr-form-label">@Localizer["PreferredLanguage"]</label>
                    <div class="mr-quick-select">
                        <button type="button"
                                class="mr-quick-select-btn @(Request.PreferredLanguage == "en-US" ? "active" : "")"
                                @onclick="@(() => Request.PreferredLanguage = "en-US")">
                            <span class="me-1">🇬🇧</span>
                            English
                        </button>
                        <button type="button"
                                class="mr-quick-select-btn @(Request.PreferredLanguage == "ms-MY" ? "active" : "")"
                                @onclick="@(() => Request.PreferredLanguage = "ms-MY")">
                            <span class="me-1">🇲🇾</span>
                            Bahasa
                        </button>
                    </div>
                    <div class="mr-form-hint">
                        <i class="ti ti-info-circle"></i>
                        @Localizer["LanguageHint"]
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public OnboardingRequest Request { get; set; } = new();
    [Parameter] public EventCallback<OnboardingRequest> RequestChanged { get; set; }
}
