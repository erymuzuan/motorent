@using MotoRent.Domain.Core
@using Microsoft.AspNetCore.Components.Authorization
@inherits LocalizedComponentBase<AuthStep>

<div class="mr-animate-in">
    <div class="text-center mb-4">
        <div class="mb-3">
            <div class="mr-icon-circle mx-auto" style="width: 64px; height: 64px; font-size: 1.5rem;">
                <i class="ti ti-user-plus"></i>
            </div>
        </div>
        <h3 class="mb-2">@Localizer["StepTitle"]</h3>
        <p class="text-secondary">@Localizer["StepDescription"]</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Request.Provider) && !string.IsNullOrWhiteSpace(Request.ProviderId))
    {
        @* Show authenticated user info *@
        <div class="mr-info-panel mb-4">
            <div class="mr-info-panel-icon text-success">
                <i class="ti ti-circle-check"></i>
            </div>
            <div>
                <div class="mr-info-panel-title">@Localizer["AuthenticatedAs"]</div>
                <p class="mr-info-panel-text mb-0">
                    <strong>@Request.FullName</strong><br />
                    @if (!string.IsNullOrWhiteSpace(Request.Email))
                    {
                        <span class="text-secondary">@Request.Email</span>
                    }
                </p>
            </div>
        </div>

        <div class="text-center">
            <p class="text-secondary small mb-3">@Localizer["ContinueToNextStep"]</p>
        </div>
    }
    else
    {
        @* OAuth Sign-in Buttons *@
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="d-grid gap-3">
                    @* Google Sign-in *@
                    <a href="/account/google?returnUrl=/onboarding" class="btn btn-outline-secondary btn-lg d-flex align-items-center justify-content-center">
                        <svg class="me-2" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                        </svg>
                        @Localizer["ContinueWithGoogle"]
                    </a>

                    @* LINE Sign-in *@
                    <a href="/account/line?returnUrl=/onboarding" class="btn btn-lg d-flex align-items-center justify-content-center"
                       style="background-color: #06C755; color: white; border: none;">
                        <svg class="me-2" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                            <path d="M12 2C6.477 2 2 5.878 2 10.5c0 3.897 3.203 7.175 7.589 7.909.296.063.699.194.801.447.093.226.061.581.03.81l-.129.78c-.04.239-.183.931.815.507 1-.423 5.382-3.167 7.341-5.424C20.09 13.006 22 11.89 22 10.5 22 5.878 17.523 2 12 2z"/>
                        </svg>
                        @Localizer["ContinueWithLine"]
                    </a>
                </div>

                @if (this.IsLocalHost)
                {
                    <div class="mt-5 p-3 border border-warning rounded bg-warning-lt">
                        <h4 class="text-warning mb-2"><i class="ti ti-test-pipe me-1"></i> Dev Auth Mock (Localhost only)</h4>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <input type="text" class="form-control form-control-sm" placeholder="Full Name" @bind="this.m_mockName" />
                            </div>
                            <div class="col-md-4">
                                <input type="email" class="form-control form-control-sm" placeholder="Email" @bind="this.m_mockEmail" />
                            </div>
                            <div class="col-md-4">
                                <select class="form-select form-control-sm" @bind="this.m_mockProvider">
                                    <option value="Google">Google</option>
                                    <option value="Line">LINE</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="button" class="btn btn-warning btn-sm w-100" @onclick="this.SimulateLogin">
                                    Simulate Social Login
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <div class="text-center mt-4">
                    <p class="text-secondary small mb-0">
                        <i class="ti ti-shield-check me-1"></i>
                        @Localizer["SecureSignIn"]
                    </p>
                </div>
            </div>
        </div>
    }
</div>
