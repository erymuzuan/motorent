@page "/contact"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout Layout.PublicLayout
@inherits LocalizedComponentBase<Contact>
@inject MotoRent.Services.Core.SalesLeadService SalesLeadService

<PageTitle>@Localizer["PageTitle"] - @MotoConfig.ApplicationName</PageTitle>

<div class="contact-page">
    @* Hero Section *@
    <section class="contact-hero">
        <div class="hero-bg-pattern"></div>
        <div class="container-xl position-relative">
            <div class="text-center">
                <span class="contact-badge mr-animate-in">
                    <i class="ti ti-message-circle me-1"></i>
                    @Localizer["GetInTouch"]
                </span>
                <h1 class="contact-headline mr-animate-in mr-animate-delay-1">
                    @Localizer["Headline"]
                </h1>
                <p class="contact-subheadline mr-animate-in mr-animate-delay-2">
                    @Localizer["Subheadline"]
                </p>
            </div>
        </div>
    </section>

    @* Main Content *@
    <section class="contact-content">
        <div class="container-xl">
            <div class="row g-4 justify-content-center">
                @* Contact Form *@
                <div class="col-lg-7">
                    <div class="contact-form-card mr-animate-in mr-animate-delay-1">
                        @if (m_submitted)
                        {
                            <div class="success-message">
                                <div class="success-icon">
                                    <i class="ti ti-check"></i>
                                </div>
                                <h3>@Localizer["ThankYou"]</h3>
                                <p>@Localizer["SubmitSuccess"]</p>
                                <button type="button" class="btn btn-outline-primary mt-3" @onclick="ResetForm">
                                    <i class="ti ti-arrow-left me-1"></i>
                                    @Localizer["SendAnother"]
                                </button>
                            </div>
                        }
                        else
                        {
                            <form @onsubmit="SubmitFormAsync" @onsubmit:preventDefault>
                                <h3 class="form-title">@Localizer["FormTitle"]</h3>

                                <div class="row g-3">
                                    @* Name *@
                                    <div class="col-md-6">
                                        <label class="form-label required">@Localizer["Name"]</label>
                                        <div class="input-icon">
                                            <span class="input-icon-addon">
                                                <i class="ti ti-user"></i>
                                            </span>
                                            <input type="text" class="form-control"
                                                   placeholder="@Localizer["NamePlaceholder"]"
                                                   @bind="m_lead.Name" required />
                                        </div>
                                    </div>

                                    @* Email *@
                                    <div class="col-md-6">
                                        <label class="form-label required">@Localizer["Email"]</label>
                                        <div class="input-icon">
                                            <span class="input-icon-addon">
                                                <i class="ti ti-mail"></i>
                                            </span>
                                            <input type="email" class="form-control"
                                                   placeholder="@Localizer["EmailPlaceholder"]"
                                                   @bind="m_lead.Email" required />
                                        </div>
                                    </div>

                                    @* Phone *@
                                    <div class="col-md-6">
                                        <label class="form-label">@Localizer["Phone"]</label>
                                        <div class="input-icon">
                                            <span class="input-icon-addon">
                                                <i class="ti ti-phone"></i>
                                            </span>
                                            <input type="tel" class="form-control"
                                                   placeholder="@Localizer["PhonePlaceholder"]"
                                                   @bind="m_lead.Phone" />
                                        </div>
                                    </div>

                                    @* Company *@
                                    <div class="col-md-6">
                                        <label class="form-label">@Localizer["Company"]</label>
                                        <div class="input-icon">
                                            <span class="input-icon-addon">
                                                <i class="ti ti-building"></i>
                                            </span>
                                            <input type="text" class="form-control"
                                                   placeholder="@Localizer["CompanyPlaceholder"]"
                                                   @bind="m_lead.Company" />
                                        </div>
                                    </div>

                                    @* Plan Interested *@
                                    <div class="col-md-6">
                                        <label class="form-label">@Localizer["PlanInterested"]</label>
                                        <select class="form-select" @bind="m_planInterested">
                                            <option value="">@Localizer["SelectPlan"]</option>
                                            <option value="Free">@Localizer["PlanFree"]</option>
                                            <option value="Pro">@Localizer["PlanPro"]</option>
                                            <option value="Ultra">@Localizer["PlanUltra"]</option>
                                            <option value="Customized">@Localizer["PlanCustomized"]</option>
                                        </select>
                                    </div>

                                    @* Fleet Size *@
                                    <div class="col-md-6">
                                        <label class="form-label">@Localizer["FleetSize"]</label>
                                        <select class="form-select" @bind="m_fleetSize">
                                            <option value="">@Localizer["SelectFleetSize"]</option>
                                            <option value="1-5">1-5 @Localizer["Vehicles"]</option>
                                            <option value="6-15">6-15 @Localizer["Vehicles"]</option>
                                            <option value="16-30">16-30 @Localizer["Vehicles"]</option>
                                            <option value="31-50">31-50 @Localizer["Vehicles"]</option>
                                            <option value="50+">50+ @Localizer["Vehicles"]</option>
                                        </select>
                                    </div>

                                    @* Enterprise Requirements (shown when Customized is selected) *@
                                    @if (m_planInterested == "Customized")
                                    {
                                        <div class="col-12">
                                            <div class="enterprise-requirements-card">
                                                <label class="form-label">@Localizer["EnterpriseRequirements"]</label>
                                                <div class="row g-2">
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqSelfHosted" />
                                                            <span class="form-check-label">@Localizer["ReqSelfHosted"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqCustomBranding" />
                                                            <span class="form-check-label">@Localizer["ReqCustomBranding"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqSso" />
                                                            <span class="form-check-label">@Localizer["ReqSso"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqApiIntegration" />
                                                            <span class="form-check-label">@Localizer["ReqApiIntegration"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqLegacyMigration" />
                                                            <span class="form-check-label">@Localizer["ReqLegacyMigration"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqMultiLocation" />
                                                            <span class="form-check-label">@Localizer["ReqMultiLocation"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqDedicatedSupport" />
                                                            <span class="form-check-label">@Localizer["ReqDedicatedSupport"]</span>
                                                        </label>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-check">
                                                            <input class="form-check-input" type="checkbox"
                                                                   @bind="m_reqDataResidency" />
                                                            <span class="form-check-label">@Localizer["ReqDataResidency"]</span>
                                                        </label>
                                                    </div>
                                                </div>
                                                <div class="mt-3">
                                                    <label class="form-label">@Localizer["OtherRequirements"]</label>
                                                    <textarea class="form-control" rows="3"
                                                              placeholder="@Localizer["OtherRequirementsPlaceholder"]"
                                                              @bind="m_lead.CustomRequirements"></textarea>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @* Message *@
                                    <div class="col-12">
                                        <label class="form-label required">@Localizer["Message"]</label>
                                        <textarea class="form-control" rows="5"
                                                  placeholder="@Localizer["MessagePlaceholder"]"
                                                  @bind="m_lead.Message" required></textarea>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(m_errorMessage))
                                {
                                    <div class="alert alert-danger mt-3">
                                        <i class="ti ti-alert-circle me-2"></i>
                                        @m_errorMessage
                                    </div>
                                }

                                <div class="form-submit">
                                    <button type="submit" class="btn btn-primary btn-lg" disabled="@m_submitting">
                                        @if (m_submitting)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        }
                                        else
                                        {
                                            <i class="ti ti-send me-2"></i>
                                        }
                                        @Localizer["SendMessage"]
                                    </button>
                                </div>
                            </form>
                        }
                    </div>
                </div>

                @* Contact Info Sidebar *@
                <div class="col-lg-4">
                    <div class="contact-info-card mr-animate-in mr-animate-delay-2">
                        <h4>@Localizer["ContactInfo"]</h4>

                        <div class="contact-item">
                            <div class="contact-icon">
                                <i class="ti ti-mail"></i>
                            </div>
                            <div>
                                <span class="contact-label">@Localizer["EmailUs"]</span>
                                <a href="mailto:contact@motorent.io">contact@motorent.io</a>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon">
                                <i class="ti ti-clock"></i>
                            </div>
                            <div>
                                <span class="contact-label">@Localizer["ResponseTime"]</span>
                                <span>@Localizer["ResponseTimeValue"]</span>
                            </div>
                        </div>

                        <div class="contact-item">
                            <div class="contact-icon">
                                <i class="ti ti-map-pin"></i>
                            </div>
                            <div>
                                <span class="contact-label">@Localizer["Location"]</span>
                                <span>@Localizer["LocationValue"]</span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="quick-links">
                            <h5>@Localizer["QuickLinks"]</h5>
                            <a href="/pricing" class="quick-link">
                                <i class="ti ti-currency-baht"></i>
                                @Localizer["ViewPricing"]
                            </a>
                            <a href="/" class="quick-link">
                                <i class="ti ti-home"></i>
                                @Localizer["LearnMore"]
                            </a>
                            <a href="/account/login" class="quick-link">
                                <i class="ti ti-rocket"></i>
                                @Localizer["StartFreeTrial"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* ============================================
       CONTACT PAGE - Tropical Premium Aesthetic
       ============================================ */

    .contact-page {
        --contact-teal: #00897B;
        --contact-teal-dark: #00695C;
        --contact-teal-light: #4DB6AC;
        --contact-orange: #FF7043;
        --contact-gold: #FFB300;
        --contact-bg: #f8fafb;
        --contact-card-bg: #ffffff;
        --contact-text: #1e293b;
        --contact-text-muted: #64748b;
        font-family: "Kanit", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--contact-bg);
        overflow-x: hidden;
    }

    /* Hero Section */
    .contact-hero {
        position: relative;
        padding: 5rem 0 3rem;
        background: linear-gradient(135deg, #00695C 0%, #00897B 50%, #4DB6AC 100%);
        overflow: hidden;
    }

    .hero-bg-pattern {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 20% 80%, rgba(255,255,255,0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 40%),
            url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        opacity: 0.6;
    }

    .contact-badge {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 179, 0, 0.2);
        color: #FFE082;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255, 179, 0, 0.3);
    }

    .contact-headline {
        color: white;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 1rem;
        text-shadow: 0 2px 20px rgba(0,0,0,0.15);
    }

    .contact-subheadline {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1.125rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Content Section */
    .contact-content {
        padding: 3rem 0 5rem;
        margin-top: -2rem;
        position: relative;
    }

    /* Form Card */
    .contact-form-card {
        background: var(--contact-card-bg);
        border-radius: 24px;
        padding: 2.5rem;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
    }

    .form-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--contact-text);
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 500;
        color: var(--contact-text);
        margin-bottom: 0.5rem;
    }

    .form-label.required::after {
        content: " *";
        color: #dc3545;
    }

    .input-icon {
        position: relative;
    }

    .input-icon-addon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--contact-text-muted);
        pointer-events: none;
    }

    .input-icon .form-control {
        padding-left: 2.5rem;
    }

    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        padding: 0.75rem 1rem;
        font-size: 0.9375rem;
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--contact-teal);
        box-shadow: 0 0 0 3px rgba(0, 137, 123, 0.15);
    }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .form-submit {
        margin-top: 2rem;
        text-align: center;
    }

    .form-submit .btn {
        padding: 1rem 3rem;
        font-weight: 600;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--contact-teal) 0%, var(--contact-teal-light) 100%);
        border: none;
        box-shadow: 0 4px 15px rgba(0, 137, 123, 0.3);
        transition: all 0.3s ease;
    }

    .form-submit .btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 137, 123, 0.4);
    }

    .form-submit .btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    /* Success Message */
    .success-message {
        text-align: center;
        padding: 3rem 1rem;
    }

    .success-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--contact-teal) 0%, var(--contact-teal-light) 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.5rem;
    }

    .success-message h3 {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--contact-text);
        margin-bottom: 0.5rem;
    }

    .success-message p {
        color: var(--contact-text-muted);
        font-size: 1rem;
        margin: 0;
    }

    /* Info Card */
    .contact-info-card {
        background: var(--contact-card-bg);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
        height: fit-content;
    }

    .contact-info-card h4 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--contact-text);
        margin-bottom: 1.5rem;
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .contact-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(0, 137, 123, 0.1) 0%, rgba(77, 182, 172, 0.1) 100%);
        color: var(--contact-teal);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .contact-label {
        display: block;
        font-size: 0.75rem;
        color: var(--contact-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem;
    }

    .contact-item a {
        color: var(--contact-teal);
        text-decoration: none;
        font-weight: 500;
    }

    .contact-item a:hover {
        text-decoration: underline;
    }

    /* Quick Links */
    .quick-links h5 {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--contact-text);
        margin-bottom: 1rem;
    }

    .quick-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f8fafc;
        border-radius: 10px;
        color: var(--contact-text);
        text-decoration: none;
        margin-bottom: 0.5rem;
        transition: all 0.2s ease;
    }

    .quick-link:hover {
        background: linear-gradient(135deg, rgba(0, 137, 123, 0.1) 0%, rgba(77, 182, 172, 0.1) 100%);
        color: var(--contact-teal);
        transform: translateX(4px);
        text-decoration: none;
    }

    .quick-link i {
        color: var(--contact-teal);
    }

    /* Enterprise Requirements Card */
    .enterprise-requirements-card {
        background: linear-gradient(135deg, rgba(0, 137, 123, 0.05) 0%, rgba(77, 182, 172, 0.05) 100%);
        border: 1px solid rgba(0, 137, 123, 0.15);
        border-radius: 12px;
        padding: 1.25rem;
    }

    .enterprise-requirements-card .form-label {
        font-weight: 600;
        color: var(--contact-teal-dark);
        margin-bottom: 1rem;
    }

    .enterprise-requirements-card .form-check {
        margin-bottom: 0.5rem;
        padding: 0.5rem 0.75rem 0.5rem 1.75rem;
        border-radius: 8px;
        transition: background-color 0.2s ease;
    }

    .enterprise-requirements-card .form-check:hover {
        background-color: rgba(0, 137, 123, 0.08);
    }

    .enterprise-requirements-card .form-check-input:checked {
        background-color: var(--contact-teal);
        border-color: var(--contact-teal);
    }

    .enterprise-requirements-card .form-check-label {
        font-size: 0.9375rem;
        color: var(--contact-text);
        cursor: pointer;
    }

    .enterprise-requirements-card textarea {
        background: white;
    }

    /* Responsive */
    @@media (max-width: 991px) {
        .contact-form-card,
        .contact-info-card {
            padding: 1.5rem;
        }
    }

    @@media (max-width: 767px) {
        .contact-hero {
            padding: 3rem 0 2rem;
        }

        .contact-content {
            padding: 2rem 0 3rem;
        }

        .form-submit .btn {
            width: 100%;
        }
    }
</style>

@code {
    private MotoRent.Domain.Core.SalesLead m_lead = new();
    private string m_planInterested = "";
    private string m_fleetSize = "";
    private bool m_submitting;
    private bool m_submitted;
    private string? m_errorMessage;

    // Enterprise requirements checkboxes
    private bool m_reqSelfHosted;
    private bool m_reqCustomBranding;
    private bool m_reqSso;
    private bool m_reqApiIntegration;
    private bool m_reqLegacyMigration;
    private bool m_reqMultiLocation;
    private bool m_reqDedicatedSupport;
    private bool m_reqDataResidency;

    private async Task SubmitFormAsync()
    {
        m_submitting = true;
        m_errorMessage = null;

        try
        {
            // Set plan interested
            if (!string.IsNullOrEmpty(m_planInterested))
            {
                m_lead.PlanInterested = m_planInterested switch
                {
                    "Free" => MotoRent.Domain.Core.SubscriptionPlan.Free,
                    "Pro" => MotoRent.Domain.Core.SubscriptionPlan.Pro,
                    "Ultra" => MotoRent.Domain.Core.SubscriptionPlan.Ultra,
                    "Customized" => MotoRent.Domain.Core.SubscriptionPlan.Customized,
                    _ => null
                };
            }

            // Build enterprise requirements list if Customized plan
            if (m_planInterested == "Customized")
            {
                m_lead.EnterpriseRequirements.Clear();
                if (m_reqSelfHosted) m_lead.EnterpriseRequirements.Add("SelfHosted");
                if (m_reqCustomBranding) m_lead.EnterpriseRequirements.Add("CustomBranding");
                if (m_reqSso) m_lead.EnterpriseRequirements.Add("SSO");
                if (m_reqApiIntegration) m_lead.EnterpriseRequirements.Add("ApiIntegration");
                if (m_reqLegacyMigration) m_lead.EnterpriseRequirements.Add("LegacyMigration");
                if (m_reqMultiLocation) m_lead.EnterpriseRequirements.Add("MultiLocation");
                if (m_reqDedicatedSupport) m_lead.EnterpriseRequirements.Add("DedicatedSupport");
                if (m_reqDataResidency) m_lead.EnterpriseRequirements.Add("DataResidency");
            }

            // Parse fleet size
            if (!string.IsNullOrEmpty(m_fleetSize))
            {
                m_lead.FleetSize = m_fleetSize switch
                {
                    "1-5" => 5,
                    "6-15" => 15,
                    "16-30" => 30,
                    "31-50" => 50,
                    "50+" => 100,
                    _ => null
                };
            }

            m_lead.Source = MotoRent.Domain.Core.LeadSource.ContactForm;

            var result = await SalesLeadService.CreateLeadAsync(m_lead);
            if (result.Success)
            {
                m_submitted = true;
            }
            else
            {
                m_errorMessage = result.Message ?? Localizer["SubmitError"];
            }
        }
        catch (Exception ex)
        {
            m_errorMessage = Localizer["SubmitError", ex.Message];
        }
        finally
        {
            m_submitting = false;
        }
    }

    private void ResetForm()
    {
        m_lead = new MotoRent.Domain.Core.SalesLead();
        m_planInterested = "";
        m_fleetSize = "";
        m_submitted = false;
        m_errorMessage = null;

        // Reset enterprise requirements checkboxes
        m_reqSelfHosted = false;
        m_reqCustomBranding = false;
        m_reqSso = false;
        m_reqApiIntegration = false;
        m_reqLegacyMigration = false;
