@page "/fleet-models/{FleetModelId}/edit"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireTenantStaff")]
@inherits LocalizedComponentBase<EditFleetModel>
@inject FleetModelService FleetModelService

<MotoRentPageTitle>@Localizer["EditFleetModel"] - @this.m_fleetModel.DisplayName</MotoRentPageTitle>

<div class="container-xl">
    @* Page Header *@
    <div class="page-header d-print-none mb-4">
        <div class="row align-items-center">
            <div class="col-auto">
                <a href="/fleet-models" class="btn btn-ghost-secondary btn-icon">
                    <i class="ti ti-arrow-left"></i>
                </a>
            </div>
            <div class="col">
                <h2 class="page-title">@Localizer["EditFleetModel"]</h2>
                <p class="text-secondary mb-0">
                    <i class="ti @GetVehicleTypeIcon(this.m_fleetModel.VehicleType) me-1"></i>
                    @this.m_fleetModel.DisplayNameWithEngine
                </p>
            </div>
            <div class="col-auto">
                <span class="badge @(this.m_fleetModel.IsActive ? "bg-success-lt text-success" : "bg-secondary-lt text-secondary") fs-6">
                    @(this.m_fleetModel.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                </span>
            </div>
        </div>
    </div>

    <LoadingSkeleton Loading="@this.Loading" Mode="LoadingSkeleton.PlaceholderMode.Card">
        @if (this.m_fleetModel.FleetModelId == 0)
        {
            <div class="card">
                <div class="card-body">
                    <div class="empty py-5">
                        <div class="empty-icon">
                            <i class="ti ti-alert-circle" style="font-size: 3rem;"></i>
                        </div>
                        <p class="empty-title">@Localizer["FleetModelNotFound"]</p>
                        <div class="empty-action">
                            <a href="/fleet-models" class="btn btn-primary">
                                <i class="ti ti-arrow-left me-1"></i>@Localizer["BackToFleetModels"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <form id="edit-fleet-model-form" @onsubmit="this.SaveAsync" @onsubmit:preventDefault>
                <FleetModelForm Entity="@this.m_fleetModel" IsNew="false" FleetModelId="@this.m_fleetModelId" />

                @* Action Buttons *@
                <div class="card">
                    <div class="card-footer d-flex justify-content-between">
                        <a href="/fleet-models" class="btn btn-ghost-secondary">
                            <i class="ti ti-arrow-left me-1"></i>@Localizer["Cancel"]
                        </a>
                        <button type="submit" class="btn btn-primary" disabled="@this.m_saving">
                            @if (this.m_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>@Localizer["Saving"]...</span>
                            }
                            else
                            {
                                <i class="ti ti-device-floppy me-1"></i>
                                <span>@Localizer["SaveChanges"]</span>
                            }
                        </button>
                    </div>
                </div>
            </form>
        }
    </LoadingSkeleton>
</div>

@code {
    [Parameter]
    public string FleetModelId { get; set; } = "";

    private int m_fleetModelId;
    private FleetModel m_fleetModel = new();
    private bool Loading { get; set; } = true;
    private bool m_saving;

    protected override async Task OnParametersSetAsync()
    {
        this.m_fleetModelId = this.DecodeId(this.FleetModelId);
        await this.LoadFleetModelAsync();
    }

    private async Task LoadFleetModelAsync()
    {
        this.Loading = true;
        try
        {
            var fm = await this.FleetModelService.GetFleetModelByIdAsync(this.m_fleetModelId);
            if (fm is not null)
            {
                this.m_fleetModel = fm.Clone();
            }
            else
            {
                this.m_fleetModel = new FleetModel();
            }
        }
        finally
        {
            this.Loading = false;
        }
    }

    private async Task SaveAsync()
    {
        this.m_saving = true;
        try
        {
            var result = await this.FleetModelService.UpdateFleetModelAsync(this.m_fleetModel, this.UserName);

            if (result.Success)
            {
                this.ShowSuccess(Localizer["FleetModelUpdatedSuccess"]);
            }
            else
            {
                this.ShowError(result.Message ?? Localizer["SaveFailed"]);
            }
        }
        finally
        {
            this.m_saving = false;
        }
    }

    private static string GetVehicleTypeIcon(VehicleType type) => type switch
    {
        VehicleType.Motorbike => "ti-motorbike",
        VehicleType.Car => "ti-car",
        VehicleType.JetSki => "ti-sailboat",
        VehicleType.Boat => "ti-ship",
        VehicleType.Van => "ti-bus",
        _ => "ti-car"
    };
}
