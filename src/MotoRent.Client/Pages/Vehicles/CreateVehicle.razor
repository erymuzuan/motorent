@page "/vehicles/motorbike/new"
@page "/vehicles/car/new"
@page "/vehicles/jetski/new"
@page "/vehicles/boat/new"
@page "/vehicles/van/new"
@inherits LocalizedComponentBase<CreateVehicle>
@using MotoRent.Domain.Storage
@inject VehicleService VehicleService
@inject VehicleImageService VehicleImageService
@inject FleetModelService FleetModelService
@inject FleetModelImageService FleetModelImageService
@inject IBinaryStore BinaryStore
@inject IJSRuntime JsRuntime

<MotoRentPageTitle>@Localizer["AddVehicle"] - @GetVehicleTypeLabel(m_vehicleType)</MotoRentPageTitle>

@* Page Header with Gradient *@
<div class="mr-page-header">
    <div class="container-xl">
        @* Breadcrumb *@
        <nav class="mr-breadcrumb">
            <span class="mr-breadcrumb-item"><a href="/"><i class="ti ti-home"></i></a></span>
            <span class="mr-breadcrumb-separator"><i class="ti ti-chevron-right"></i></span>
            <span class="mr-breadcrumb-item"><a href="/vehicles">@Localizer["Fleet"]</a></span>
            <span class="mr-breadcrumb-separator"><i class="ti ti-chevron-right"></i></span>
            <span class="mr-breadcrumb-item active">@Localizer["AddNewVehicle"]</span>
        </nav>

        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="mr-page-title">
                    <i class="ti @GetVehicleTypeIcon(m_vehicleType)"></i>
                    @Localizer["AddNewVehicle"]
                </h1>
                <p class="mr-page-subtitle">@GetVehicleTypeLabel(m_vehicleType)</p>
            </div>
            <a href="/vehicles" class="mr-btn-header-action">
                <i class="ti ti-arrow-left"></i>
                @Localizer["BackToFleet"]
            </a>
        </div>
    </div>
</div>

<div class="container-xl">
    @* Step 1: Select Fleet Model *@
    @if (m_selectedFleetModel == null)
    {
        <div class="mr-form-panel mb-3">
            <div class="mr-form-panel-header">
                <div class="mr-form-panel-header-icon">
                    <i class="ti ti-template"></i>
                </div>
                <h3 class="mr-form-panel-title">@Localizer["SelectFleetModel"]</h3>
            </div>
            <div class="mr-form-panel-body">
                @if (m_loadingModels)
                {
                    <div class="d-flex justify-content-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    </div>
                }
                else if (m_availableFleetModels.Count > 0)
                {
                    <div class="list-group list-group-flush">
                        @foreach (var fm in m_availableFleetModels)
                        {
                            <button type="button" class="list-group-item list-group-item-action d-flex align-items-center"
                                    @onclick="@(() => SelectFleetModel(fm))">
                                @if (GetPrimaryImageUrl(fm.FleetModelId) is { } imageUrl)
                                {
                                    <span class="avatar avatar-sm me-3" style="background-image: url(@imageUrl)"></span>
                                }
                                else
                                {
                                    <span class="avatar avatar-sm bg-primary-lt me-3">
                                        <i class="ti @GetVehicleTypeIcon(fm.VehicleType)"></i>
                                    </span>
                                }
                                <div class="flex-fill">
                                    <div class="fw-bold">@fm.DisplayNameWithEngine</div>
                                    <div class="text-secondary small">
                                        @if (fm.VehicleType == VehicleType.JetSki)
                                        {
                                            <span>@BaseCurrencySymbol@(fm.Rate1Hour?.ToString("N0") ?? "0")/@Localizer["Hour"]</span>
                                        }
                                        else
                                        {
                                            <span>@BaseCurrencySymbol@fm.DailyRate.ToString("N0")/@Localizer["Day"]</span>
                                            @if (fm.HourlyRate > 0) { <span class="ms-2">@BaseCurrencySymbol@fm.HourlyRate.Value.ToString("N0")/@Localizer["Hour"]</span> }
                                        }
                                    </div>
                                </div>
                                <i class="ti ti-chevron-right text-secondary"></i>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-3 text-secondary">
                        <i class="ti ti-info-circle me-1"></i>
                        @Localizer["NoFleetModelsForType"]
                    </div>
                }

                <div class="mt-3 pt-3 border-top">
                    <span class="text-secondary small">
                        <i class="ti ti-info-circle me-1"></i>@Localizer["FleetModelRequired"]
                    </span>
                </div>
            </div>
        </div>
    }
    else
    {
        @* Show selected FleetModel info *@
        <div class="card mb-3 border-primary">
            <div class="card-body d-flex align-items-center">
                @if (GetPrimaryImageUrl(m_selectedFleetModel.FleetModelId) is { } selectedImageUrl)
                {
                    <span class="avatar avatar-md me-3" style="background-image: url(@selectedImageUrl)"></span>
                }
                else
                {
                    <span class="avatar avatar-md bg-primary-lt me-3">
                        <i class="ti @GetVehicleTypeIcon(m_selectedFleetModel.VehicleType)"></i>
                    </span>
                }
                <div class="flex-fill">
                    <div class="fw-bold">@m_selectedFleetModel.DisplayNameWithEngine</div>
                    <div class="text-secondary small">
                        @if (m_selectedFleetModel.VehicleType == VehicleType.JetSki)
                        {
                            <span>@BaseCurrencySymbol@(m_selectedFleetModel.Rate1Hour?.ToString("N0") ?? "0")/@Localizer["Hour"]</span>
                        }
                        else
                        {
                            <span>@BaseCurrencySymbol@m_selectedFleetModel.DailyRate.ToString("N0")/@Localizer["Day"]</span>
                        }
                        &middot; @Localizer["Deposit"]: @BaseCurrencySymbol@m_selectedFleetModel.DepositAmount.ToString("N0")
                    </div>
                </div>
                <button type="button" class="btn btn-ghost-secondary btn-sm" @onclick="ClearFleetModelSelection">
                    <i class="ti ti-x me-1"></i>@Localizer["Change"]
                </button>
            </div>
        </div>
    }

    @* Step 2: Vehicle Details *@
    <form id="create-vehicle-form" @onsubmit="SaveAsync" @onsubmit:preventDefault>
        <VehicleForm @ref="m_vehicleForm"
                     Entity="@m_vehicle"
                     IsNew="true"
                     HasFleetModel="@(m_selectedFleetModel != null)"
                     LastServiceDate="@m_lastServiceDate"
                     LastServiceDateChanged="@((d) => m_lastServiceDate = d)"
                     VehicleTypeChanged="OnVehicleTypeChanged" />

        @* Action Buttons *@
        <div class="mr-card mt-4">
            <div class="mr-card-footer d-flex justify-content-between align-items-center">
                <a href="/vehicles" class="btn btn-ghost-secondary">
                    <i class="ti ti-x me-1"></i>@Localizer["Cancel"]
                </a>
                <button type="submit" class="mr-btn-primary-action" disabled="@m_saving">
                    @if (m_saving)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span>@Localizer["Saving"]...</span>
                    }
                    else
                    {
                        <i class="ti ti-device-floppy"></i>
                        <span>@Localizer["CreateVehicle"]</span>
                    }
                </button>
            </div>
        </div>
    </form>
</div>

@code {
    private Vehicle m_vehicle = new();
    private VehicleType m_vehicleType;
    private DateTime? m_lastServiceDate;
    private bool m_saving;
    private bool m_loadingModels;
    private VehicleForm? m_vehicleForm;
    private FleetModel? m_selectedFleetModel;
    private List<FleetModel> m_availableFleetModels = [];
    private Dictionary<int, string> m_primaryImages = new();

    protected override async Task OnInitializedAsync()
    {
        // Determine vehicle type from route
        var uri = this.NavigationManager.ToBaseRelativePath(this.NavigationManager.Uri);
        var path = uri.Split('?')[0];

        this.m_vehicleType = path.ToLower() switch
        {
            "vehicles/motorbike/new" => VehicleType.Motorbike,
            "vehicles/car/new" => VehicleType.Car,
            "vehicles/jetski/new" => VehicleType.JetSki,
            "vehicles/boat/new" => VehicleType.Boat,
            "vehicles/van/new" => VehicleType.Van,
            _ => VehicleType.Motorbike
        };

        InitializeVehicle();
        await LoadFleetModelsAsync();
    }

    private void InitializeVehicle()
    {
        this.m_vehicle = new Vehicle
        {
            HomeShopId = this.RequestContext.GetShopId(),
            CurrentShopId = this.RequestContext.GetShopId(),
            Status = VehicleStatus.Available,
            VehicleType = this.m_vehicleType,
            Year = DateTime.Now.Year,
            DurationType = this.m_vehicleType == VehicleType.JetSki
                ? RentalDurationType.FixedInterval
                : RentalDurationType.Daily
        };
    }

    private async Task LoadFleetModelsAsync()
    {
        m_loadingModels = true;
        try
        {
            m_availableFleetModels = await FleetModelService.GetAllActiveFleetModelsAsync(m_vehicleType);

            // Load primary images for all fleet models
            m_primaryImages.Clear();
            foreach (var fm in m_availableFleetModels)
            {
                var storeId = await FleetModelImageService.GetPrimaryImageStoreIdAsync(fm.FleetModelId);
                if (!string.IsNullOrEmpty(storeId))
                {
                    m_primaryImages[fm.FleetModelId] = storeId;
                }
            }
        }
        finally
        {
            m_loadingModels = false;
        }
    }

    private void SelectFleetModel(FleetModel fm)
    {
        m_selectedFleetModel = fm;
        m_vehicle.FleetModelId = fm.FleetModelId;
        m_vehicle.PopulateFromFleetModel(fm);
    }

    private void ClearFleetModelSelection()
    {
        m_selectedFleetModel = null;
        m_vehicle.FleetModelId = 0;
    }

    private async Task OnVehicleTypeChanged(VehicleType type)
    {
        this.m_vehicleType = type;
        m_selectedFleetModel = null;
        m_vehicle.FleetModelId = 0;
        await LoadFleetModelsAsync();
    }

    private async Task SaveAsync()
    {
        this.m_saving = true;
        try
        {
            // Set last service date if provided
            this.m_vehicle.LastServiceDate = this.m_lastServiceDate.HasValue
                ? new DateTimeOffset(this.m_lastServiceDate.Value)
                : null;

            var result = await this.VehicleService.CreateVehicleAsync(this.m_vehicle, this.UserName);

            if (result.Success)
            {
                this.ShowSuccess(Localizer["VehicleCreatedSuccess"]);

                // Navigate to edit page
                this.NavigationManager.NavigateTo($"/vehicles/{EncodeId(this.m_vehicle.VehicleId)}/edit");
            }
            else
            {
                this.ShowError(result.Message ?? Localizer["SaveFailed"]);
            }
        }
        finally
        {
            this.m_saving = false;
        }
    }

    private string? GetPrimaryImageUrl(int fleetModelId)
    {
        if (m_primaryImages.TryGetValue(fleetModelId, out var storeId))
        {
            return BinaryStore.GetImageUrl(storeId);
        }
        return null;
    }

    private static string GetVehicleTypeIcon(VehicleType type) => type switch
    {
        VehicleType.Motorbike => "ti-motorbike",
        VehicleType.Car => "ti-car",
        VehicleType.JetSki => "ti-sailboat",
        VehicleType.Boat => "ti-ship",
        VehicleType.Van => "ti-bus",
        _ => "ti-car"
    };

    private string GetVehicleTypeLabel(VehicleType type) => type switch
    {
        VehicleType.Motorbike => Localizer["Motorbike"],
        VehicleType.Car => Localizer["Car"],
        VehicleType.JetSki => Localizer["JetSki"],
        VehicleType.Boat => Localizer["Boat"],
        VehicleType.Van => Localizer["Van"],
        _ => Localizer["Vehicle"]
    };
}
