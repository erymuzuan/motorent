@page "/fleet-models/new"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireTenantStaff")]
@inherits LocalizedComponentBase<CreateFleetModel>
@inject FleetModelService FleetModelService

<MotoRentPageTitle>@Localizer["CreateFleetModel"]</MotoRentPageTitle>

@* Page Header *@
<div class="mr-page-header">
    <div class="container-xl">
        <nav class="mr-breadcrumb">
            <span class="mr-breadcrumb-item"><a href="/"><i class="ti ti-home"></i></a></span>
            <span class="mr-breadcrumb-separator"><i class="ti ti-chevron-right"></i></span>
            <span class="mr-breadcrumb-item"><a href="/fleet-models">@Localizer["FleetModels"]</a></span>
            <span class="mr-breadcrumb-separator"><i class="ti ti-chevron-right"></i></span>
            <span class="mr-breadcrumb-item active">@Localizer["CreateNew"]</span>
        </nav>

        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="mr-page-title">
                    <i class="ti ti-template"></i>
                    @Localizer["CreateFleetModel"]
                </h1>
                <p class="mr-page-subtitle">@Localizer["CreateFleetModelDescription"]</p>
            </div>
            <a href="/fleet-models" class="mr-btn-header-action">
                <i class="ti ti-arrow-left"></i>
                @Localizer["BackToFleetModels"]
            </a>
        </div>
    </div>
</div>

<div class="container-xl">
    <form id="create-fleet-model-form" @onsubmit="this.SaveAsync" @onsubmit:preventDefault>
        <FleetModelForm Entity="@this.m_fleetModel" IsNew="true" />

        @* Action Buttons *@
        <div class="mr-card mt-4">
            <div class="mr-card-footer d-flex justify-content-between align-items-center">
                <a href="/fleet-models" class="btn btn-ghost-secondary">
                    <i class="ti ti-x me-1"></i>@Localizer["Cancel"]
                </a>
                <button type="submit" class="mr-btn-primary-action" disabled="@this.m_saving">
                    @if (this.m_saving)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span>@Localizer["Saving"]...</span>
                    }
                    else
                    {
                        <i class="ti ti-device-floppy"></i>
                        <span>@Localizer["CreateFleetModel"]</span>
                    }
                </button>
            </div>
        </div>
    </form>
</div>

@code {
    private FleetModel m_fleetModel = new()
    {
        Year = DateTime.Now.Year,
        IsActive = true,
        DurationType = RentalDurationType.Daily
    };
    private bool m_saving;

    private async Task SaveAsync()
    {
        this.m_saving = true;
        try
        {
            var result = await this.FleetModelService.CreateFleetModelAsync(this.m_fleetModel, this.UserName);

            if (result.Success)
            {
                this.ShowSuccess(Localizer["FleetModelCreatedSuccess"]);
                this.NavigationManager.NavigateTo($"/fleet-models/{this.EncodeId(this.m_fleetModel.FleetModelId)}/edit");
            }
            else
            {
                this.ShowError(result.Message ?? Localizer["SaveFailed"]);
            }
        }
        finally
        {
            this.m_saving = false;
        }
    }
}
