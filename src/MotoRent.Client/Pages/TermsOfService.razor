@page "/terms"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout Layout.PublicLayout
@inherits LocalizedComponentBase<TermsOfService>

<PageTitle>@Localizer["PageTitle"] - MotoRent</PageTitle>

<div class="legal-page">
    <section class="legal-hero">
        <div class="hero-bg-pattern"></div>
        <div class="container-xl position-relative">
            <div class="text-center">
                <h1 class="legal-headline">@Localizer["PageTitle"]</h1>
                <p class="legal-updated">@Localizer["LastUpdated"]</p>
            </div>
        </div>
    </section>

    <section class="legal-body">
        <div class="container-xl">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="legal-content">
                        <div class="legal-section">
                            <h2>@Localizer["AcceptanceTitle"]</h2>
                            <p>@Localizer["AcceptanceBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["DescriptionTitle"]</h2>
                            <p>@Localizer["DescriptionBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["AccountTitle"]</h2>
                            <p>@Localizer["AccountBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["BillingTitle"]</h2>
                            <p>@Localizer["BillingBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["AcceptableUseTitle"]</h2>
                            <p>@Localizer["AcceptableUseBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["IntellectualPropertyTitle"]</h2>
                            <p>@Localizer["IntellectualPropertyBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["DataProtectionTitle"]</h2>
                            <p>@Localizer["DataProtectionBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["LiabilityTitle"]</h2>
                            <p>@Localizer["LiabilityBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["TerminationTitle"]</h2>
                            <p>@Localizer["TerminationBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["GoverningLawTitle"]</h2>
                            <p>@Localizer["GoverningLawBody"]</p>
                        </div>

                        <div class="legal-section">
                            <h2>@Localizer["ContactTitle"]</h2>
                            <p>@Localizer["ContactBody"]</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    .legal-page {
        --legal-teal: #00897B;
        --legal-teal-dark: #00695C;
        --legal-teal-light: #4DB6AC;
        --legal-bg: #f8fafb;
        --legal-text: #1e293b;
        --legal-text-muted: #64748b;
        font-family: "Kanit", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--legal-bg);
    }

    .legal-hero {
        position: relative;
        padding: 5rem 0 3rem;
        background: linear-gradient(135deg, #00695C 0%, #00897B 50%, #4DB6AC 100%);
        overflow: hidden;
    }

    .legal-hero .hero-bg-pattern {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 20% 80%, rgba(255,255,255,0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 40%);
        opacity: 0.6;
    }

    .legal-headline {
        color: white;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        margin-bottom: 0.75rem;
        text-shadow: 0 2px 20px rgba(0,0,0,0.15);
    }

    .legal-updated {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1rem;
    }

    .legal-body {
        padding: 4rem 0;
    }

    .legal-content {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.06);
    }

    .legal-section {
        margin-bottom: 2.5rem;
    }

    .legal-section:last-child {
        margin-bottom: 0;
    }

    .legal-section h2 {
        font-size: 1.375rem;
        font-weight: 600;
        color: var(--legal-text);
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--legal-teal);
    }

    .legal-section p {
        color: var(--legal-text-muted);
        line-height: 1.8;
        font-size: 0.9375rem;
    }

    @@media (max-width: 767px) {
        .legal-hero {
            padding: 3rem 0 2rem;
        }

        .legal-content {
            padding: 1.5rem;
        }
    }
</style>
