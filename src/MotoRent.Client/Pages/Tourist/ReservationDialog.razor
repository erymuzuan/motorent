@inherits MotoRentComponentBase
@using MotoRent.Domain.Entities
@using MotoRent.Domain.Models
@using MotoRent.Services
@using MotoRent.Client.Controls
@inject BookingService BookingService
@inject InsuranceService InsuranceService

<div class="modal-body">
    @* Step Indicator *@
    @if (!m_bookingComplete)
    {
        <div class="steps steps-counter steps-primary mb-4">
            <a href="#" class="step-item @(m_activeStep == 0 ? "active" : "") @(m_activeStep > 0 ? "step-item-completed" : "")"
               @onclick="@(() => GoToStep(0))" @onclick:preventDefault>
                Rental Details
            </a>
            <a href="#" class="step-item @(m_activeStep == 1 ? "active" : "") @(m_activeStep > 1 ? "step-item-completed" : "")"
               @onclick="@(() => GoToStep(1))" @onclick:preventDefault>
                Your Information
            </a>
            <a href="#" class="step-item @(m_activeStep == 2 ? "active" : "")"
               @onclick="@(() => GoToStep(2))" @onclick:preventDefault>
                Confirm
            </a>
        </div>
    }

    @* Step 1: Dates & Insurance *@
    @if (m_activeStep == 0)
    {
        <div class="d-flex flex-column gap-4">
            @* Duration Type Toggle - Only show if vehicle supports both *@
            @if (m_supportsHourly && !m_isHourlyOnly)
            {
                <div>
                    <h4>Rental Type</h4>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="duration-type" id="duration-daily"
                               checked="@(m_durationType == RentalDurationType.Daily)"
                               @onchange="@(() => SetDurationType(RentalDurationType.Daily))" />
                        <label class="btn btn-outline-primary" for="duration-daily">
                            <i class="ti ti-calendar me-1"></i>Daily
                        </label>

                        <input type="radio" class="btn-check" name="duration-type" id="duration-hourly"
                               checked="@(m_durationType == RentalDurationType.Hourly)"
                               @onchange="@(() => SetDurationType(RentalDurationType.Hourly))" />
                        <label class="btn btn-outline-primary" for="duration-hourly">
                            <i class="ti ti-clock me-1"></i>Hourly
                        </label>
                    </div>
                </div>
            }

            @if (m_durationType == RentalDurationType.Daily)
            {
                @* Daily Rental: Date Selection *@
                <h4>Select Your Rental Period</h4>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label required">Start Date</label>
                        <DatePicker @bind-Value="m_startDateValue" MinDate="DateTime.Today" CssClass="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">End Date</label>
                        <DatePicker @bind-Value="m_endDateValue" MinDate="m_startDateValue" CssClass="form-control" />
                    </div>
                </div>

                @if (m_startDate.HasValue && m_endDate.HasValue)
                {
                    <div class="alert alert-info">
                        <i class="ti ti-calendar me-2"></i>
                        @m_days day(s) - @FormatDate(m_startDate.Value) to @FormatDate(m_endDate.Value)
                    </div>
                }
            }
            else
            {
                @* Hourly Rental: Date, Time, and Duration Selection *@
                <h4>Select Your Rental Time</h4>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label required">Date</label>
                        <DatePicker @bind-Value="m_startDateValue" MinDate="DateTime.Today" CssClass="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">Start Time</label>
                        <input type="time" class="form-control"
                               value="@m_startTimeString"
                               @onchange="@((e) => m_startTimeString = e.Value?.ToString() ?? "10:00")" />
                    </div>
                </div>

                @* Hourly Packages (if available) with date-aware pricing *@
                @if (HourlyPackages.Count > 0)
                {
                    <h5 class="mt-3">Choose a Package</h5>
                    <div class="row g-2">
                        @foreach (var package in HourlyPackages.OrderBy(p => p.Hours))
                        {
                            var pkg = package;
                            var linearPrice = HourlyRate * pkg.Hours;
                            var savings = linearPrice - pkg.Price;
                            <div class="col-6 col-md-4">
                                <div class="card h-100 cursor-pointer @(m_selectedPackage == pkg ? "border-primary border-2" : "")"
                                     @onclick="@(() => SelectPackage(pkg))">
                                    <div class="card-body text-center py-3">
                                        <h4 class="mb-1">@(string.IsNullOrEmpty(pkg.Name) ? $"{pkg.Hours}hr" : pkg.Name)</h4>
                                        <div class="text-muted small">@pkg.Hours hour(s)</div>
                                        <div class="text-primary fw-bold h5 mb-0">@FormatCurrency(pkg.Price)</div>
                                        @if (savings > 0)
                                        {
                                            <div class="text-success small">
                                                <i class="ti ti-discount-2 me-1"></i>Save @FormatCurrency(savings)
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @* Custom Hours Option *@
                        <div class="col-6 col-md-4">
                            <div class="card h-100 cursor-pointer @(m_selectedPackage == null ? "border-primary border-2" : "")"
                                 @onclick="@(() => SelectPackage(null))">
                                <div class="card-body text-center py-3">
                                    <h4 class="mb-1">Custom</h4>
                                    <div class="text-muted small">Choose hours</div>
                                    <div class="text-primary fw-bold h5 mb-0">@FormatCurrency(HourlyRate)/hr</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* Custom Hours Input (show when no package selected or no packages available) *@
                @if (m_selectedPackage == null)
                {
                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <label class="form-label required">Number of Hours</label>
                            <div class="input-group">
                                <input type="number" class="form-control" min="1" max="24"
                                       @bind="m_selectedHours" />
                                <span class="input-group-text">hours</span>
                            </div>
                        </div>
                    </div>
                }

                @* Rental Period Summary *@
                @if (m_startDate.HasValue)
                {
                    <div class="alert alert-info">
                        <i class="ti ti-clock me-2"></i>
                        @GetHourlyRentalSummary()
                    </div>
                }
            }

            <hr />

            <h4>Insurance Options</h4>

            @if (m_loadingInsurance)
            {
                <div class="progress progress-sm">
                    <div class="progress-bar progress-bar-indeterminate"></div>
                </div>
            }
            else
            {
                <div class="form-selectgroup form-selectgroup-boxes d-flex flex-column gap-2">
                    <label class="form-selectgroup-item flex-fill">
                        <input type="radio" name="insurance" value="" class="form-selectgroup-input"
                               checked="@(!m_selectedInsuranceId.HasValue)"
                               @onchange="@(() => m_selectedInsuranceId = null)" />
                        <div class="form-selectgroup-label d-flex align-items-center p-3">
                            <div class="me-3"><span class="form-selectgroup-check"></span></div>
                            <div class="flex-fill">
                                <strong>No Insurance</strong>
                                <div class="text-secondary small">You are responsible for all damages</div>
                            </div>
                        </div>
                    </label>

                    @foreach (var insurance in m_insuranceOptions)
                    {
                        <label class="form-selectgroup-item flex-fill">
                            <input type="radio" name="insurance" value="@insurance.InsuranceId" class="form-selectgroup-input"
                                   checked="@(m_selectedInsuranceId == insurance.InsuranceId)"
                                   @onchange="@(() => m_selectedInsuranceId = insurance.InsuranceId)" />
                            <div class="form-selectgroup-label d-flex align-items-center p-3">
                                <div class="me-3"><span class="form-selectgroup-check"></span></div>
                                <div class="flex-fill">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@insurance.Name</strong>
                                            <div class="text-secondary small">@insurance.Description</div>
                                            <small class="text-muted">
                                                Deductible: @FormatCurrency(insurance.Deductible) | Max: @FormatCurrency(insurance.MaxCoverage)
                                            </small>
                                        </div>
                                        <span class="text-primary">
                                            @if (m_durationType == RentalDurationType.Hourly)
                                            {
                                                @($"+{FormatCurrency(Math.Ceiling(insurance.DailyRate / 8 * EffectiveHours))} for {EffectiveHours}hrs")
                                            }
                                            else
                                            {
                                                @($"+{FormatCurrency(insurance.DailyRate)}/day")
                                            }
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </label>
                    }
                </div>
            }

            @* Color Preference (only if group has available colors) *@
            @if (VehicleGroup != null && VehicleGroup.AvailableColors.Count > 0)
            {
                <hr />
                <h4>Color Preference</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Preferred Color (optional)</label>
                        <select class="form-select" @bind="m_preferredColor">
                            <option value="">No preference</option>
                            @foreach (var color in VehicleGroup.AvailableColors)
                            {
                                <option value="@color">@color</option>
                            }
                        </select>
                        <small class="form-hint">
                            <i class="ti ti-info-circle me-1"></i>
                            Color preference is not guaranteed
                        </small>
                    </div>
                </div>
            }
        </div>
    }

    @* Step 2: Contact Information *@
    @if (m_activeStep == 1)
    {
        <div class="d-flex flex-column gap-3">
            <div>
                <h4>Contact Details</h4>
                <p class="text-secondary">We'll use this information to confirm your reservation</p>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label required">Full Name</label>
                    <input type="text" class="form-control" @bind="m_contactInfo.FullName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Nationality</label>
                    <CountryPicker @bind-Value="m_contactInfo.Nationality" />
                </div>
                <div class="col-md-6">
                    <label class="form-label required">Phone/WhatsApp</label>
                    <input type="tel" class="form-control" @bind="m_contactInfo.Phone" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label required">Email</label>
                    <input type="email" class="form-control" @bind="m_contactInfo.Email" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Passport Number</label>
                    <input type="text" class="form-control" @bind="m_contactInfo.PassportNo" />
                    <small class="form-hint">Required for pickup</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Hotel/Accommodation</label>
                    <input type="text" class="form-control" @bind="m_contactInfo.HotelName" />
                    <small class="form-hint">Where are you staying?</small>
                </div>
                <div class="col-12">
                    <label class="form-label">Special Requests</label>
                    <textarea class="form-control" rows="2" @bind="m_contactInfo.Notes"
                              placeholder="Any special requests or notes..."></textarea>
                </div>
            </div>
        </div>
    }

    @* Step 3: Confirmation *@
    @if (m_activeStep == 2)
    {
        <div class="d-flex flex-column gap-4">
            <h4>Reservation Summary</h4>

            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <small class="text-secondary">Vehicle</small>
                                <div class="fw-bold">@DisplayName</div>
                                @if (!string.IsNullOrEmpty(m_preferredColor))
                                {
                                    <small class="text-secondary">Preferred color: @m_preferredColor (not guaranteed)</small>
                                }
                            </div>
                            <div class="mb-3">
                                <small class="text-secondary">Rental Period</small>
                                <div>
                                    @if (m_durationType == RentalDurationType.Hourly)
                                    {
                                        @GetHourlyRentalSummary()
                                    }
                                    else
                                    {
                                        @($"{FormatDate(m_startDate ?? DateTime.Today)} - {FormatDate(m_endDate ?? DateTime.Today)} ({m_days} days)")
                                    }
                                </div>
                            </div>
                            @if (m_selectedInsurance != null)
                            {
                                <div>
                                    <small class="text-secondary">Insurance</small>
                                    <div>@m_selectedInsurance.Name</div>
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <div>
                                <small class="text-secondary">Contact</small>
                                <div class="fw-bold">@m_contactInfo.FullName</div>
                                <div>@m_contactInfo.Phone</div>
                                <div>@m_contactInfo.Email</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h4 class="card-title mb-3">Pricing Breakdown</h4>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between">
                            @if (m_durationType == RentalDurationType.Hourly)
                            {
                                @if (m_selectedPackage != null)
                                {
                                    <span>Vehicle (@(string.IsNullOrEmpty(m_selectedPackage.Name) ? $"{m_selectedPackage.Hours}hr package" : m_selectedPackage.Name))</span>
                                }
                                else
                                {
                                    <span>Vehicle (@m_selectedHours hrs x @FormatCurrency(HourlyRate))</span>
                                }
                            }
                            else
                            {
                                <span>Vehicle (@m_days days x @FormatCurrency(DailyRate))</span>
                            }
                            <span>@FormatCurrency(m_vehicleTotal)</span>
                        </div>
                        @if (m_selectedInsurance != null)
                        {
                            <div class="d-flex justify-content-between">
                                @if (m_durationType == RentalDurationType.Hourly)
                                {
                                    <span>Insurance (prorated for @EffectiveHours hrs)</span>
                                }
                                else
                                {
                                    <span>Insurance (@m_days days x @FormatCurrency(m_selectedInsurance.DailyRate))</span>
                                }
                                <span>@FormatCurrency(m_insuranceTotal)</span>
                            </div>
                        }
                        <hr class="my-1" />
                        <div class="d-flex justify-content-between">
                            <span class="h4 mb-0">Total</span>
                            <span class="h3 text-primary mb-0">@FormatCurrency(m_totalAmount)</span>
                        </div>
                        <div class="d-flex justify-content-between text-secondary">
                            <span>Security Deposit (refundable)</span>
                            <span>@FormatCurrency(DepositAmount)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info">
                <i class="ti ti-info-circle me-2"></i>
                <strong>Next Steps:</strong> After submitting, you'll receive a confirmation email.
                Please bring your passport and payment to our shop at least 30 minutes before your rental starts.
            </div>

            <label class="form-check">
                <input type="checkbox" class="form-check-input" @bind="m_agreedToTerms" />
                <span class="form-check-label">
                    I agree to the <a href="/terms" target="_blank">Terms and Conditions</a>
                    and <a href="/rental-policy" target="_blank">Rental Policy</a>
                </span>
            </label>
        </div>
    }

    @* Booking Complete Success Screen *@
    @if (m_bookingComplete && m_createdBooking != null)
    {
        <div class="text-center py-4">
            <div class="mb-4">
                <span class="avatar avatar-xl bg-success-lt rounded-circle">
                    <i class="ti ti-check fs-1 text-success"></i>
                </span>
            </div>

            <h2 class="text-success mb-3">Booking Confirmed!</h2>

            <div class="card mb-4">
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-secondary">Your Booking Reference</small>
                        <div class="h1 text-primary mb-0">@m_createdBooking.BookingRef</div>
                    </div>
                    <p class="text-secondary mb-0">
                        Please save this reference number. You'll need it when you arrive for pickup.
                    </p>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body text-start">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <small class="text-secondary">Vehicle</small>
                            <div class="fw-bold">@DisplayName</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <small class="text-secondary">Rental Period</small>
                            <div>
                                @if (m_durationType == RentalDurationType.Hourly)
                                {
                                    @GetHourlyRentalSummary()
                                }
                                else
                                {
                                    @($"{FormatDate(m_startDate ?? DateTime.Today)} - {FormatDate(m_endDate ?? DateTime.Today)}")
                                }
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <small class="text-secondary">Customer</small>
                            <div class="fw-bold">@m_contactInfo.FullName</div>
                            <div class="small">@m_contactInfo.Phone</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <small class="text-secondary">Total Amount</small>
                            <div class="h4 text-primary mb-0">@FormatCurrency(m_totalAmount)</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info text-start">
                <div class="d-flex align-items-start">
                    <i class="ti ti-info-circle me-2 mt-1"></i>
                    <div>
                        <strong>Next Steps:</strong>
                        <ul class="mb-0 mt-2 ps-3">
                            <li>A confirmation email will be sent to <strong>@m_contactInfo.Email</strong></li>
                            <li>Bring your passport and payment to our shop at least 30 minutes before pickup</li>
                            <li>Show your booking reference <strong>@m_createdBooking.BookingRef</strong> at the counter</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal-footer">
    @if (m_bookingComplete)
    {
        <button type="button" class="btn btn-primary" @onclick="Close">
            <i class="ti ti-check me-1"></i>
            Done
        </button>
    }
    else
    {
        <button type="button" class="btn btn-ghost-secondary" @onclick="Cancel">Cancel</button>
        @if (m_activeStep > 0)
        {
            <button type="button" class="btn btn-outline-primary" @onclick="PreviousStep">
                <i class="ti ti-arrow-left me-1"></i>
                Back
            </button>
        }
        @if (m_activeStep < 2)
        {
            <button type="button" class="btn btn-primary" disabled="@(!CanProceed)" @onclick="NextStep">
                Next
                <i class="ti ti-arrow-right ms-1"></i>
            </button>
        }
        else
        {
            <button type="button" class="btn btn-primary" disabled="@(!CanSubmit || m_submitting)" @onclick="SubmitBooking">
                @if (m_submitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                Submit Booking
            </button>
        }
    }
</div>

@code {
    [CascadingParameter] private ModalInstance? ModalInstance { get; set; }
    [Parameter] public Motorbike? Motorbike { get; set; }
    [Parameter] public VehicleGroup? VehicleGroup { get; set; }
    [Parameter] public DateRangeSelection? DateRange { get; set; }

    private int m_activeStep;
    private bool m_submitting;
    private bool m_loadingInsurance = true;

    // Step 1: Dates & Insurance
    private DateTime? m_startDate;
    private DateTime? m_endDate;

    // Non-nullable wrappers for DatePicker component
    private DateTime m_startDateValue
    {
        get => m_startDate ?? DateTime.Today;
        set
        {
            m_startDate = value;
            InvokeAsync(StateHasChanged);
        }
    }
    private DateTime m_endDateValue
    {
        get => m_endDate ?? DateTime.Today;
        set
        {
            m_endDate = value;
            InvokeAsync(StateHasChanged);
        }
    }
    private List<Insurance> m_insuranceOptions = [];
    private int? m_selectedInsuranceId;
    private Insurance? m_selectedInsurance => this.m_insuranceOptions.FirstOrDefault(i => i.InsuranceId == this.m_selectedInsuranceId);
    private string? m_preferredColor;

    // Hourly rental (VehicleGroup supports hourly, legacy Motorbike does not)
    private RentalDurationType m_durationType = RentalDurationType.Daily;
    private bool m_supportsHourly => this.VehicleGroup?.SupportsHourlyRental ?? false;
    private bool m_isHourlyOnly => this.VehicleGroup?.IsHourlyOnly ?? false;
    private int m_selectedHours = 4;
    private TimeSpan m_startTime = new(10, 0, 0);
    private string m_startTimeString
    {
        get => this.m_startTime.ToString(@"hh\:mm");
        set => TimeSpan.TryParse(value, out this.m_startTime);
    }
    private HourlyPackagePrice? m_selectedPackage;
    private List<HourlyPackagePrice> HourlyPackages => this.VehicleGroup?.HourlyPackages ?? [];
    private decimal HourlyRate => this.VehicleGroup?.MinHourlyRate ?? 0;
    private int EffectiveHours => this.m_selectedPackage?.Hours ?? this.m_selectedHours;

    // Step 2: Contact Info
    private ContactInfo m_contactInfo = new();

    // Step 3: Confirmation
    private bool m_agreedToTerms;

    // Booking completion
    private bool m_bookingComplete;
    private Booking? m_createdBooking;

    // Display helpers that work with both Motorbike and VehicleGroup
    private string DisplayName => this.VehicleGroup?.DisplayName
        ?? (this.Motorbike != null ? $"{this.Motorbike.Brand} {this.Motorbike.Model} {this.Motorbike.Year}" : "");
    private decimal DailyRate => this.VehicleGroup?.MinDailyRate ?? this.Motorbike?.DailyRate ?? 0;
    private decimal DepositAmount => this.VehicleGroup?.MinDepositAmount ?? this.Motorbike?.DepositAmount ?? 0;
    private bool IsGroupReservation => this.VehicleGroup != null;

    // FleetModelId - from VehicleGroup (Motorbike doesn't have FleetModelId)
    private int GetFleetModelId() => this.VehicleGroup?.FleetModelId ?? 0;

    // Calculations
    private int m_days => this.m_startDate.HasValue && this.m_endDate.HasValue
        ? Math.Max(1, (this.m_endDate.Value - this.m_startDate.Value).Days + 1)
        : 0;
    private decimal m_vehicleTotal => this.m_durationType switch
    {
        // Use base package price (dynamic pricing adjustments applied via Pricing Rules)
        RentalDurationType.Hourly when this.m_selectedPackage != null =>
            this.m_selectedPackage.Price,
        RentalDurationType.Hourly => this.HourlyRate * this.m_selectedHours,
        _ => this.DailyRate * this.m_days
    };
    private decimal m_insuranceTotal => this.m_durationType switch
    {
        RentalDurationType.Hourly => Math.Ceiling((this.m_selectedInsurance?.DailyRate ?? 0) / 8 * this.EffectiveHours),
        _ => (this.m_selectedInsurance?.DailyRate ?? 0) * this.m_days
    };
    private decimal m_totalAmount => this.m_vehicleTotal + this.m_insuranceTotal;

    private bool CanProceed => this.m_activeStep switch
    {
        0 => this.m_durationType == RentalDurationType.Hourly
            ? this.m_startDate.HasValue && (this.m_selectedPackage != null || this.m_selectedHours > 0)
            : this.m_startDate.HasValue && this.m_endDate.HasValue,
        1 => !string.IsNullOrWhiteSpace(this.m_contactInfo.FullName) &&
             !string.IsNullOrWhiteSpace(this.m_contactInfo.Phone) &&
             !string.IsNullOrWhiteSpace(this.m_contactInfo.Email),
        _ => true
    };

    private bool CanSubmit => this.m_agreedToTerms && this.CanProceed;

    protected override async Task OnInitializedAsync()
    {
        this.m_startDate = this.DateRange?.Start ?? DateTime.Today;
        this.m_endDate = this.DateRange?.End ?? DateTime.Today;

        // Set duration type based on vehicle capability
        if (this.m_isHourlyOnly)
        {
            this.m_durationType = RentalDurationType.Hourly;
            // Select first package by default
            this.m_selectedPackage = this.HourlyPackages.FirstOrDefault();
            if (this.m_selectedPackage != null)
                this.m_selectedHours = this.m_selectedPackage.Hours;
        }

        await this.LoadInsuranceOptions();
    }

    private async Task LoadInsuranceOptions()
    {
        this.m_loadingInsurance = true;
        try
        {
            var result = await this.InsuranceService.GetActiveInsurancesAsync();
            this.m_insuranceOptions = result;
        }
        finally
        {
            this.m_loadingInsurance = false;
        }
    }

    private void Cancel() => this.ModalInstance?.Cancel();

    private void Close() => this.ModalInstance?.Close(this.m_createdBooking?.BookingRef);

    private void GoToStep(int step)
    {
        if (step <= this.m_activeStep)
            this.m_activeStep = step;
    }

    private void NextStep()
    {
        if (this.CanProceed && this.m_activeStep < 2)
            this.m_activeStep++;
    }

    private void PreviousStep()
    {
        if (this.m_activeStep > 0)
            this.m_activeStep--;
    }

    private async Task SubmitBooking()
    {
        if (!this.CanSubmit) return;

        this.m_submitting = true;
        try
        {
            // Calculate start/end dates based on duration type
            DateTimeOffset startDateOffset, endDateOffset;
            if (this.m_durationType == RentalDurationType.Hourly)
            {
                var startDateTime = DateTime.SpecifyKind(this.m_startDate!.Value.Date + this.m_startTime, DateTimeKind.Unspecified);
                startDateOffset = new DateTimeOffset(startDateTime, TimeSpan.Zero);
                endDateOffset = startDateOffset.AddHours(this.EffectiveHours);
            }
            else
            {
                startDateOffset = new DateTimeOffset(DateTime.SpecifyKind(this.m_startDate!.Value.Date, DateTimeKind.Unspecified), TimeSpan.Zero);
                endDateOffset = new DateTimeOffset(DateTime.SpecifyKind(this.m_endDate!.Value.Date, DateTimeKind.Unspecified), TimeSpan.Zero);
            }

            var request = new CreateBookingRequest
            {
                PreferredShopId = this.RequestContext.GetShopId(),
                CustomerName = this.m_contactInfo.FullName,
                CustomerPhone = this.m_contactInfo.Phone,
                CustomerEmail = this.m_contactInfo.Email,
                CustomerNationality = this.m_contactInfo.Nationality,
                CustomerPassportNo = this.m_contactInfo.PassportNo,
                HotelName = this.m_contactInfo.HotelName,
                Notes = this.m_contactInfo.Notes,
                StartDate = startDateOffset,
                EndDate = endDateOffset,
                BookingSource = "TouristPortal",
                Items =
                [
                    new BookingItemRequest
                    {
                        FleetModelId = this.GetFleetModelId(),
                        FleetModelDisplayName = this.DisplayName,
                        PreferredVehicleId = this.IsGroupReservation ? null : this.Motorbike?.MotorbikeId,
                        PreferredColor = this.m_preferredColor,
                        InsuranceId = this.m_selectedInsuranceId,
                        InsuranceName = this.m_selectedInsurance?.Name,
                        DurationType = this.m_durationType,
                        DailyRate = this.m_durationType == RentalDurationType.Daily ? this.DailyRate : 0,
                        HourlyRate = this.m_durationType == RentalDurationType.Hourly ? this.HourlyRate : null,
                        RentalHours = this.m_durationType == RentalDurationType.Hourly ? this.EffectiveHours : null,
                        StartTime = this.m_durationType == RentalDurationType.Hourly ? this.m_startTime : null,
                        InsuranceRate = this.m_insuranceTotal,
                        DepositAmount = this.DepositAmount,
                        ItemTotal = this.m_totalAmount,
                        VehicleDisplayName = this.DisplayName
                    }
                ]
            };

            var result = await this.BookingService.CreateBookingAsync(request, this.m_contactInfo.Email);

            if (result.Success && result.Booking != null)
            {
                this.m_createdBooking = result.Booking;
                this.m_bookingComplete = true;
            }
            else
            {
                this.ShowError($"Booking failed: {result.Error}");
            }
        }
        finally
        {
            this.m_submitting = false;
        }
    }

    private void SetDurationType(RentalDurationType type)
    {
        this.m_durationType = type;
        if (type == RentalDurationType.Hourly)
        {
            this.m_selectedPackage = this.HourlyPackages.FirstOrDefault();
            if (this.m_selectedPackage != null)
                this.m_selectedHours = this.m_selectedPackage.Hours;
        }
        this.StateHasChanged();
    }

    private void SelectPackage(HourlyPackagePrice? package)
    {
        this.m_selectedPackage = package;
        if (package != null)
            this.m_selectedHours = package.Hours;
        this.StateHasChanged();
    }

    private string GetHourlyRentalSummary()
    {
        if (!this.m_startDate.HasValue) return "Select a date";

        var startDateTime = this.m_startDate.Value.Date + this.m_startTime;
        var hours = this.EffectiveHours;
        var endDateTime = startDateTime.AddHours(hours);

        return $"{hours} hour(s) - {startDateTime:d MMM} {startDateTime:h:mm tt} to {endDateTime:h:mm tt}";
    }

    private class ContactInfo
    {
        public string FullName { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Nationality { get; set; }
        public string? PassportNo { get; set; }
        public string? HotelName { get; set; }
        public string? Notes { get; set; }
    }

    public class DateRangeSelection
    {
        public DateTime? Start { get; set; }
        public DateTime? End { get; set; }

        public DateRangeSelection() { }
        public DateRangeSelection(DateTime? start, DateTime? end)
        {
            this.Start = start;
            this.End = end;
        }
    }
}
