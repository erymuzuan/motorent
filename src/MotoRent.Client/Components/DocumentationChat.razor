@using System.Net.Http.Json
@inherits LocalizedComponentBase<DocumentationChat>
@inject HttpClient HttpClient
@inject MarkdownService MarkdownService

<div class="card @(this.m_expanded ? "chat-expanded" : "chat-collapsed")">
    <div class="card-header cursor-pointer" @onclick="this.ToggleExpand">
        <h3 class="card-title">
            <i class="ti ti-sparkles me-2"></i>@Localizer["AskGemini"]
        </h3>
        <div class="card-actions">
            <i class="ti @(this.m_expanded ? "ti-chevron-down" : "ti-chevron-up")"></i>
        </div>
    </div>
    
    @if (this.m_expanded)
    {
        <div class="card-body chat-body d-flex flex-column">
            <div class="messages flex-fill overflow-auto mb-3" @ref="this.m_messagesRef">
                @foreach (var msg in this.m_messages)
                {
                    <div class="chat-message @(msg.IsUser ? "message-user" : "message-ai") mb-2">
                        <div class="message-content p-2 rounded shadow-sm">
                            @if (msg.IsLoading)
                            {
                                <div class="animated-dots">@Localizer["Thinking"]</div>
                            }
                            else if (msg.IsUser)
                            {
                                @msg.Text
                            }
                            else
                            {
                                <div class="markdown">
                                    @((MarkupString)this.FormatMessage(msg.Text))
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            
            <div class="input-group align-items-end">
                <textarea class="form-control chat-input" rows="3" placeholder="@Localizer["AskQuestionPlaceholder"]"
                          @bind="this.m_currentInput" @onkeyup="this.HandleKeyUp" disabled="@this.Loading"></textarea>
                <button class="btn btn-primary align-self-stretch" @onclick="this.SendMessageAsync" disabled="@(this.Loading || string.IsNullOrWhiteSpace(this.m_currentInput))">
                    <i class="ti ti-send"></i>
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool m_expanded;
    private string m_currentInput = "";
    private bool Loading { get; set; }
    private List<ChatMessage> m_messages = [];
    private ElementReference m_messagesRef;

    private void ToggleExpand() => this.m_expanded = !this.m_expanded;

    private string FormatMessage(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";

        // Look for "Sources: [file1.md, file2.md]"
        var parts = text.Split("Sources:", StringSplitOptions.TrimEntries);
        var content = this.MarkdownService.ToHtml(parts[0]);

        if (parts.Length > 1)
        {
            var sourcesPart = parts[1].Trim('[', ']', ' ');
            var files = sourcesPart.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            var sourcesHtml = "<div class='mt-2 small text-secondary'><strong>Sources:</strong> ";
            foreach (var file in files)
            {
                sourcesHtml += $"<a href='/learn/{file}' class='badge bg-blue-lt me-1'>{file}</a> ";
            }
            sourcesHtml += "</div>";

            return content + sourcesHtml;
        }

        return content;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await this.SendMessageAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(this.m_currentInput) || this.Loading) return;

        var question = this.m_currentInput;
        this.m_currentInput = "";
        this.m_messages.Add(new ChatMessage(question, true));
        
        this.Loading = true;
        var aiMsg = new ChatMessage("", false, true);
        this.m_messages.Add(aiMsg);
        
        try
        {
            var absoluteUri = this.NavigationManager.ToAbsoluteUri("api/help/ask").ToString();
            using var response = await this.HttpClient.PostAsJsonAsync(absoluteUri, new AskRequest(question));

            if (response.IsSuccessStatusCode)
            {
                var askResponse = await response.Content.ReadFromJsonAsync<AskResponse>();
                aiMsg.Text = askResponse?.Answer ?? "Sorry, I couldn't get an answer.";
            }
            else if ((int)response.StatusCode == 429)
            {
                var rateLimitResponse = await response.Content.ReadFromJsonAsync<AskResponse>();
                aiMsg.Text = rateLimitResponse?.Answer ?? "You've reached your question limit for today. Please try again tomorrow.";
            }
            else
            {
                aiMsg.Text = "Sorry, something went wrong. Please try again later.";
            }

            aiMsg.IsLoading = false;
        }
        catch (Exception)
        {
            aiMsg.Text = "Error communicating with AI.";
            aiMsg.IsLoading = false;
        }
        finally
        {
            this.Loading = false;
        }
    }

    private class ChatMessage(string text, bool isUser, bool isLoading = false)
    {
        public string Text { get; set; } = text;
        public bool IsUser { get; set; } = isUser;
        public bool IsLoading { get; set; } = isLoading;
    }

    private record AskRequest(string Question);
    private record AskResponse(string Answer);
}
