@using MotoRent.Client.Components.Till
@inherits LocalizedDialogBase<VoidReceiptResult, VoidReceiptDialog>
@using MotoRent.Domain.Entities

<div class="void-receipt-dialog p-2">
    @* Header *@
    <div class="text-center mb-4">
        <div class="avatar avatar-xl bg-danger-lt mb-3">
            <i class="ti ti-receipt-off fs-1"></i>
        </div>
        <h3 class="mb-1">@Localizer["VoidReceipt"]</h3>
        <p class="text-muted mb-0">@Receipt.ReceiptNo</p>
    </div>

    @* Receipt Summary Card *@
    <div class="card card-sm mb-4">
        <div class="card-body py-3">
            <div class="row align-items-center">
                <div class="col">
                    <div class="d-flex align-items-center">
                        <span class="avatar avatar-sm me-3 @GetReceiptTypeAvatarClass()">
                            <i class="@GetReceiptTypeIcon()"></i>
                        </span>
                        <div>
                            <div class="fw-medium">@GetReceiptTypeDisplay(Receipt.ReceiptType)</div>
                            <div class="text-muted small">@Receipt.CustomerName</div>
                        </div>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="h3 mb-0 text-danger">@FormatThb(Receipt.GrandTotal)</div>
                </div>
            </div>
        </div>
    </div>

    @* Reason Input *@
    <div class="mb-4">
        <label class="form-label">@Localizer["VoidReason"] <span class="text-danger">*</span></label>
        <textarea class="form-control @(m_reasonError != null ? "is-invalid" : "")"
                  rows="2"
                  placeholder="@Localizer["EnterVoidReason"]"
                  @bind="m_reason"
                  @bind:event="oninput"></textarea>
        @if (m_reasonError != null)
        {
            <div class="invalid-feedback">@m_reasonError</div>
        }
    </div>

    @* Effect Summary *@
    <div class="alert alert-warning py-2 mb-4">
        <div class="d-flex align-items-center">
            <i class="ti ti-alert-triangle me-2"></i>
            <span class="small">@Localizer["TillBalanceWillDecrease"] <strong>@FormatThb(GetTotalPaymentsAmount())</strong></span>
        </div>
    </div>

    @* Action Buttons *@
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-ghost-secondary flex-fill" @onclick="OnCancel">
            @Localizer["Cancel"]
        </button>
        <button type="button" class="btn btn-danger flex-fill" @onclick="OnConfirmVoid">
            <i class="ti ti-x me-1"></i>
            @Localizer["VoidReceipt"]
        </button>
    </div>
</div>

@code {
    [Parameter]
    public Receipt Receipt { get; set; } = null!;

    private string m_reason = "";
    private string? m_reasonError;

    private void OnConfirmVoid()
    {
        // Validate reason
        if (string.IsNullOrWhiteSpace(m_reason))
        {
            m_reasonError = Localizer["ReasonRequired"];
            return;
        }

        if (m_reason.Length < 5)
        {
            m_reasonError = Localizer["ReasonTooShort"];
            return;
        }

        m_reasonError = null;

        var result = new VoidReceiptResult
        {
            ReceiptId = Receipt.ReceiptId,
            Reason = m_reason.Trim()
        };

        ModalService.Close(ModalResult.Ok(result));
    }

    private void OnCancel()
    {
        ModalService.Close(ModalResult.Cancel());
    }

    private decimal GetTotalPaymentsAmount()
    {
        return Receipt.Payments.Sum(p => p.AmountInBaseCurrency);
    }

    private string GetReceiptTypeDisplay(string type)
    {
        return type switch
        {
            ReceiptTypes.CheckIn => Localizer["CheckIn"],
            ReceiptTypes.Settlement => Localizer["Settlement"],
            ReceiptTypes.BookingDeposit => Localizer["BookingDeposit"],
            _ => type
        };
    }

    private string GetReceiptTypeIcon()
    {
        return Receipt.ReceiptType switch
        {
            ReceiptTypes.CheckIn => "ti ti-login",
            ReceiptTypes.Settlement => "ti ti-logout",
            ReceiptTypes.BookingDeposit => "ti ti-calendar-check",
            _ => "ti ti-receipt"
        };
    }

    private string GetReceiptTypeAvatarClass()
    {
        return Receipt.ReceiptType switch
        {
            ReceiptTypes.CheckIn => "bg-primary-lt",
            ReceiptTypes.Settlement => "bg-success-lt",
            ReceiptTypes.BookingDeposit => "bg-info-lt",
            _ => "bg-secondary-lt"
        };
    }

    private string FormatThb(decimal amount)
    {
        return $"{BaseCurrencySymbol}{amount:N0}";
    }
}
