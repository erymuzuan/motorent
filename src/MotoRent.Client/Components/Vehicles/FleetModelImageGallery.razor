@using MotoRent.Domain.Entities
@using MotoRent.Domain.Storage
@using MotoRent.Services

@inherits LocalizedComponentBase<FleetModelImageGallery>
@inject FleetModelImageService FleetModelImageService
@inject IBinaryStore BinaryStore

<div class="mr-form-panel mb-3">
    <div class="mr-form-panel-header">
        <div class="mr-form-panel-header-icon">
            <i class="ti ti-photo"></i>
        </div>
        <h3 class="mr-form-panel-title">@Localizer["ModelImages"]</h3>
        @if (m_images.Count == 0)
        {
            <span class="badge bg-danger ms-2">@Localizer["Required"]</span>
        }
    </div>
    <div class="mr-form-panel-body p-0">
        @if (m_loading)
        {
            <div class="d-flex justify-content-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (m_images.Count == 0)
            {
                @* Empty state - nice upload area *@
                <div class="empty-state">
                    <ImageUpload StoreId="@m_newImageStoreId"
                                 StoreIdChanged="OnImageUploaded"
                                 HideImage="true">
                        <div class="empty-state-content">
                            <div class="empty-state-icon">
                                <i class="ti ti-camera-plus"></i>
                            </div>
                            <div class="empty-state-title">@Localizer["AddModelImage"]</div>
                            <div class="empty-state-hint">@Localizer["ClickOrDragToUpload"]</div>
                        </div>
                    </ImageUpload>
                </div>
            }
            else
            {
                @* Show uploaded image *@
                <div class="uploaded-image-container">
                    <div class="uploaded-image-wrapper">
                        <img src="@GetImageUrl(m_images[0])"
                             alt="@m_images[0].Caption"
                             class="uploaded-image" />
                    </div>
                    <div class="uploaded-image-actions">
                        <ImageUpload StoreId="@m_newImageStoreId"
                                     StoreIdChanged="OnImageUploaded"
                                     HideImage="true">
                            <button type="button" class="btn btn-sm btn-light" disabled="@m_saving">
                                <i class="ti ti-camera-plus me-1"></i>
                                @Localizer["ChangeImage"]
                            </button>
                        </ImageUpload>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public int FleetModelId { get; set; }

    [Parameter]
    public EventCallback<string?> PrimaryImageChanged { get; set; }

    [Parameter]
    public EventCallback ImagesChanged { get; set; }

    private List<FleetModelImage> m_images = [];
    private bool m_loading = true;
    private bool m_saving;
    private string? m_newImageStoreId;

    protected override async Task OnParametersSetAsync()
    {
        if (this.FleetModelId > 0)
        {
            await LoadImagesAsync();
        }
        else
        {
            this.m_loading = false;
        }
    }

    private async Task LoadImagesAsync()
    {
        this.m_loading = true;
        try
        {
            this.m_images = await this.FleetModelImageService.GetImagesForFleetModelAsync(this.FleetModelId);
        }
        finally
        {
            this.m_loading = false;
        }
    }

    private async Task OnImageUploaded(string? storeId)
    {
        if (string.IsNullOrEmpty(storeId)) return;

        this.m_saving = true;
        try
        {
            // Delete existing image first (only allow 1 image)
            if (this.m_images.Count > 0)
            {
                var existingImage = this.m_images[0];
                await this.FleetModelImageService.DeleteImageAsync(existingImage.FleetModelImageId, this.UserName);
            }

            // Add new image
            var result = await this.FleetModelImageService.AddImageAsync(
                this.FleetModelId, storeId, null, this.UserName);

            if (result.Success)
            {
                await LoadImagesAsync();
                this.m_newImageStoreId = null;
                await NotifyChanges();
            }
            else
            {
                this.ShowError(result.Message ?? "Failed to add image");
            }
        }
        finally
        {
            this.m_saving = false;
        }
    }

    private async Task NotifyChanges()
    {
        var primary = this.m_images.FirstOrDefault(i => i.IsPrimary);
        await this.PrimaryImageChanged.InvokeAsync(primary?.StoreId);
        await this.ImagesChanged.InvokeAsync();
    }

    private string GetImageUrl(FleetModelImage image)
    {
        if (string.IsNullOrEmpty(image.StoreId))
            return "/images/no-image.png";

        return this.BinaryStore.GetImageUrl(image.StoreId);
    }
}
