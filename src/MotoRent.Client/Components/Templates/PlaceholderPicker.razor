@using MotoRent.Domain.Entities
@using MotoRent.Client.Services
@inherits LocalizedComponentBase<PlaceholderPicker>
@inject DesignerState DesignerState

<div class="placeholder-picker mb-3">
    <button type="button" class="btn btn-sm btn-outline-secondary w-100"
            @onclick="() => this.m_expanded = !this.m_expanded">
        <i class="ti ti-code me-1"></i>
        @this.Localizer["InsertPlaceholder"]
        <i class="ti @(this.m_expanded ? "ti-chevron-up" : "ti-chevron-down") ms-auto"></i>
    </button>

    @if (this.m_expanded)
    {
        <div class="placeholder-panel mt-2 border rounded p-2">
            @foreach (var group in m_placeholderGroups)
            {
                var isRelevant = this.IsRelevantGroup(group.Key);
                <div class="mb-2">
                    <div class="placeholder-category @(isRelevant ? "text-primary" : "text-muted") small fw-bold mb-1">
                        <i class="ti @GetCategoryIcon(group.Key) me-1"></i>
                        @this.Localizer[group.Key]
                        @if (isRelevant)
                        {
                            <span class="badge bg-primary-lt ms-1">@this.Localizer["Relevant"]</span>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var placeholder in group.Value)
                        {
                            <button type="button"
                                    class="btn btn-sm placeholder-badge @(isRelevant ? "btn-outline-primary" : "btn-outline-secondary")"
                                    title="@($"{{{{{placeholder}}}}}")"
                                    @onclick="() => this.InsertPlaceholder(placeholder)">
                                @placeholder.Split('.').Last()
                            </button>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(this.m_insertedMessage))
            {
                <div class="text-success small mt-1">
                    <i class="ti ti-check me-1"></i>@this.m_insertedMessage
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<string> OnInsert { get; set; }

    private bool m_expanded;
    private string? m_insertedMessage;

    private static readonly Dictionary<string, string[]> m_placeholderGroups = PlaceholderDefinitions.Groups;

    private bool IsRelevantGroup(string groupKey)
    {
        return groupKey switch
        {
            "Organization" or "Staff" => true,
            "Booking" => this.DesignerState.DocumentType == DocumentType.BookingConfirmation,
            "Rental" => this.DesignerState.DocumentType == DocumentType.RentalAgreement,
            "Receipt" => this.DesignerState.DocumentType == DocumentType.Receipt,
            _ => false
        };
    }

    private static string GetCategoryIcon(string category) => PlaceholderDefinitions.GetCategoryIcon(category);

    private async Task InsertPlaceholder(string token)
    {
        var formatted = $"{{{{{token}}}}}";
        await this.OnInsert.InvokeAsync(formatted);
        this.m_insertedMessage = $"{formatted}";
        this.StateHasChanged();
        _ = Task.Delay(2000).ContinueWith(_ =>
        {
            this.m_insertedMessage = null;
            this.InvokeAsync(this.StateHasChanged);
        });
    }
}
